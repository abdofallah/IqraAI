{
  "Server": {
    // The Unique UUID for this specific Backend Server instance.
    // Obtained when registering this server in the Admin Dashboard -> Infrastructure -> Servers.
    "Id": "<server_id_from_admin_dashboard>",
    // The Region Identifier (e.g., "us-east-1") this server belongs to.
    "RegionId": "<region_identifier>",
    // The maximum number of simultaneous calls this server should handle before the Load Balancer (Proxy) stops sending new traffic.
    "ExpectedMaxConcurrentCalls": 25,
    // CRITICAL: The OS-level name of the network interface to bind for RTP Audio (UDP).
    // Linux: Run `ip addr` (e.g., "eth0", "ens5").
    // Windows: Run `ipconfig` (e.g., "Ethernet", "vEthernet (WSL)").
    "NetworkInterfaceName": "<network_interface_name>",
    // Estimated download bandwidth available to this server (used for capacity planning).
    "MaxNetworkDownloadMbps": 200,
    // Estimated upload bandwidth available to this server (used for capacity planning).
    "MaxNetworkUploadMbps": 50,
    // The Cluster Handshake Token.
    // MUST match the 'API Secret' in the Admin Dashboard for the Region's Server.
    "ApiKey": "<cluster_api_secret_token>",
    // A strong random string used to sign payloads sent to Telephony Webhooks/Web Sessions URL for security verification.
    "WebhookTokenSecret": "<webhook_payload_signing_key>"
  },

  "Cors": {
    // Allowed origins for browser-based connections (WebRTC signaling).
    "AllowedOrigins": [
      "<admin_dashboard_url>"
    ]
  },

  // SHARED CONFIGURATION: Global Redis for Cluster State.
  "RedisDatabase": {
    "ConnectionString": "<redis_connection_string>",
    // Database Index used to track which RAG collections are currently loaded in memory.
    "RAGCollectionsLoadedDatabaseIndex": 10,
    // Database Index used for Server Heartbeats (Pub/Sub).
    "ServerLiveStatusChannelDatabaseIndex": 7,
    // Database Index used for Distributed Locks (RedLock).
    "DistributedLockDatabaseIndex": 8
  },

  // BACKEND SPECIFIC: Local Redis for L1 Caching.
  // This instance should ideally be running on the same machine (localhost) to minimize audio retrieval latency.
  "LocalRedisDatabase": {
    "ConnectionString": "127.0.0.1:6379",
    "TTSAudioCacheIndex": 14
  },

  // SHARED CONFIGURATION: This block must match the Frontend/Backend configuration.
  "Milvus": {
    // URL for the Milvus Vector Database.
    "Endpoint": "<milvus_endpoint>",
    // Database name in Milvus.
    "Database": "<milvus_database_name>",
    // Milvus Username.
    "Username": "<milvus_username>",
    // Milvus Password.
    "Password": "<milvus_password>",
    // Interval (seconds) to check for expired vector collections.
    "ExpiryCheckIntervalSeconds": 300,
    // Timeout (minutes) to unload vector collections that haven't been queried.
    "CollectionStaleTimeoutMinutes": 30
  },

  // SHARED CONFIGURATION: Primary Metadata Storage.
  "MongoDatabase": {
    "ConnectionString": "<mongodb_connection_string>"
  },

  // SHARED CONFIGURATION: Decryption Keys.
  "Integrations": {
    // AES Key to decrypt third-party API keys (OpenAI, Twilio) needed for execution.
    "EncryptionKey": "<integration_encryption_key>"
  },

  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}