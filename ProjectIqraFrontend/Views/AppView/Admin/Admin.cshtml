@using IqraCore.Entities.Server.Configuration
@inject FrontendAppConfig FrontendAppConfig

<html data-bs-theme="dark">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard | Iqra AI</title>

    <link href="~/libs/bootstrap-5.3.3-dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/libs/fontawesome-pro-6.5.1-web-dist/css/fontawesome.min.css" rel="stylesheet">
    <link href="~/libs/fontawesome-pro-6.5.1-web-dist/css/regular.min.css" rel="stylesheet">

    <link href="~/css/structure.css" rel="stylesheet">
    <link href="~/css/style.css" rel="stylesheet">

    <link rel="icon" type="image/png" href="/img/favicon/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/img/favicon/favicon.svg" />
    <link rel="shortcut icon" href="/img/favicon/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/img/favicon/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="Iqra" />
    <link rel="manifest" href="/img/favicon/site.webmanifest" />

    <style id="dynamicCSS"></style>
</head>

<body id="body-pd" class="body-pd">
    <div id="page-loader">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>

    <header class="header header-body-pd" id="header">
        <div class="header_toggle"> <i class='fa-regular fa-bars fa-bars' id="header-toggle"></i> </div>
    </header>

    <div class="l-navbar show" id="nav-bar">
        <nav class="nav">
            <div class="upper-navigation">
                <a href="/" class="nav_logo">
                    <img class="nav_logo-icon" src="~/img/logo/logo-colored-light.png">
                </a>
                <div class="nav_list">
                    <a class="nav_link active" for="app-tab" nav-url-path="app" is-default="true">
                        <i class='fa-regular fa-cube nav_icon'></i>
                        <span class="nav_name">App</span>
                    </a>
                    <a class="nav_link" for="infrastructure-tab" nav-url-path="infrastructure">
                        <i class='fa-regular fa-server nav_icon'></i>
                        <span class="nav_name">Infrastructure</span>
                    </a>
                    <a class="nav_link" for="users-tab" nav-url-path="users">
                        <i class='fa-regular fa-user nav_icon'></i>
                        <span class="nav_name">Users</span>
                    </a>
                    <a class="nav_link" for="business-tab" nav-url-path="business">
                        <i class='fa-regular fa-briefcase nav_icon'></i>
                        <span class="nav_name">Businesses</span>
                    </a>
                    @{
                        if (FrontendAppConfig.IsCloudVersion)
                        {
                            <a class="nav_link" for="billing-tab" nav-url-path="billing">
                                <i class='fa-regular fa-file-invoice-dollar nav_icon'></i>
                                <span class="nav_name">Billing</span>
                            </a>
                        }
                    }
                    <a class="nav_link" for="llm-provider-tab" nav-url-path="llmprovider">
                        <i class='fa-regular fa-message-text nav_icon'></i>
                        <span class="nav_name">LLM Provider</span>
                    </a>
                    <a class="nav_link" for="tts-provider-tab" nav-url-path="ttsprovider">
                        <i class='fa-regular fa-volume-high nav_icon'></i>
                        <span class="nav_name">TTS Provider</span>
                    </a>
                    <a class="nav_link" for="stt-provider-tab" nav-url-path="sttprovider">
                        <i class='fa-regular fa-microphone nav_icon'></i>
                        <span class="nav_name">STT Provider</span>
                    </a>
                    <a class="nav_link" for="embedding-provider-tab" nav-url-path="embeddingprovider">
                        <i class='fa-regular fa-atom-simple nav_icon'></i>
                        <span class="nav_name">Embedding Provider</span>
                    </a>
                    <a class="nav_link" for="rerank-provider-tab" nav-url-path="rerankprovider">
                        <i class='fa-regular fa-sort-amount-up-alt nav_icon'></i>
                        <span class="nav_name">Rerank Provider</span>
                    </a>
                    <a class="nav_link" for="languages-tab" nav-url-path="languages">
                        <i class='fa-regular fa-language nav_icon'></i>
                        <span class="nav_name">Languages</span>
                    </a>
                    <a class="nav_link" for="integrations-tab" nav-url-path="integrations">
                        <i class='fa-regular fa-cube nav_icon'></i>
                        <span class="nav_name">Integrations</span>
                    </a>
                </div>
            </div>
            <div class="bottom-navigation">
                <a href="/logout" class="nav_link mt-0">
                    <i class='fa-regular fa-right-from-bracket nav_icon'></i>
                    <span class="nav_name">Log out</span>
                </a>
            </div>
        </nav>
    </div>

    <div class="w-100 main-container-wrapper" id="tabs-list">

        <!-- App Container -->
        <partial name="_AppTab.cshtml" />

        <!-- Infrastructure Container -->
        <partial name="_InfrastructureTab.cshtml" />

        <!-- Users Container -->
        <partial name="_UsersTab.cshtml" />

        <!-- Business Container -->
        <partial name="_BusinessTab.cshtml" />
        
        <!-- Billing Container -->
        <partial name="_BillingTab.cshtml" />
        
        <!-- LLM Provider Container -->
        <partial name="_LLMProviderTab.cshtml" />
        
        <!-- TTS Provider Container -->
        <partial name="_TTSProviderTab.cshtml" />
        
        <!-- STT Provider Container -->
        <partial name="_STTProviderTab.cshtml" />
        
        <!-- Embedding Provider Container -->
        <partial name="_EmbeddingProviderTab.cshtml" />
        
        <!-- Rerank Provider Container -->
        <partial name="_RerankProviderTab.cshtml" />
        
        <!-- Languages Contaienr -->
        <partial name="_LanguagesTab.cshtml" />
        
        <!-- Integrations Container -->
        <partial name="_IntegrationsTab.cshtml" />
        
    </div>

    <!-- Modals -->
    <div class="modal fade" id="adjustCreditModal" tabindex="-1" aria-labelledby="adjustCreditModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h1 class="modal-title fs-5" id="adjustCreditModalLabel">Adjust User Credit</h1>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p>Current Balance for <strong id="adjustCreditUserName"></strong>: <span id="adjustCreditCurrentBalance"></span></p>
                    <input type="hidden" id="adjustCreditUserEmailInput">
                    <div class="mb-3">
                        <label for="adjustmentTypeSelect" class="form-label">Adjustment Type</label>
                        <select class="form-select" id="adjustmentTypeSelect">
                            <option value="ManualCreditAdjustment">Add Credit (Manual)</option>
                            <option value="ManualDebitAdjustment">Remove Credit (Manual)</option>
                            <option value="Refund">Refund</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="adjustmentAmountInput" class="form-label">Amount</label>
                        <input type="number" step="0.01" class="form-control" id="adjustmentAmountInput" placeholder="e.g., 10.00">
                    </div>
                    <div class="mb-3">
                        <label for="adjustmentReasonInput" class="form-label">Reason / Description <span class="text-danger">*</span></label>
                        <textarea class="form-control" id="adjustmentReasonInput" rows="3" placeholder="e.g., Goodwill gesture, Correction for billing error" required></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" id="confirmCreditAdjustmentButton">Apply Adjustment</button>
                </div>
            </div>
        </div>
    </div>

    <!-- libs -->
    <script src="~/js/jquery-3.7.1.min.js"></script>
    <script src="~/libs/bootstrap-5.3.3-dist/js/bootstrap.bundle.js"></script>
    <script src="~/libs/chart.js-4.4.2-dist/chart.umd.js"></script>

    <!-- Custom Scripts -->
    <script src="~/js/countries_list.js"></script>
    <script src="~/js/alert_manager.js"></script>
    <script src="~/js/confirm_dialog.js"></script>
    <script src="~/js/multilanguage_dropdown.js"></script>
    <script src="~/js/script.js"></script>

    <!-- Global -->
    <script>
        var AlertManager = new BootstrapAlertManager();

        let CurrentAppConfigData = null;
        let CurrentAppPermissionsData = null;
        let CurrentAppEmailTemplatesData = null;
        var CurrentUsersList = null;
        var CurrentBusinessesList = null;
        @{
            if (FrontendAppConfig.IsCloudVersion)
            {
                <text>var CurrentPlansList = null;</text>
            }
            else
            {
                <text>var CurrentPlansList = {};</text>
            }
        }
        var CurrentLLMProvidersList = null;
        var CurrentSTTProvidersList = null;
        var CurrentTTSProvidersList = null;
        var CurrentEmbeddingProvidersList = null;
        var CurrentRerankProvidersList = null;
        var CurrentLanguagesList = null;
        let CurrentIntegrationsList = null;

        // Other Functions

        function DisableFullPermissionHelper(disableFullElement, subDisableElementsArray, dialogOptions) {
            disableFullElement.on("change", (event) => {
                event.preventDefault();
                event.stopPropagation();

                let current = $(event.currentTarget);

                let isChecked = current.is(':checked');
                if (isChecked) {
                    var confirmDialog = new BootstrapConfirmDialog(dialogOptions);

                    confirmDialog.show().then((isConfirmed) => {
                        if (isConfirmed) {
                            subDisableElementsArray.forEach((element) => {
                                element.prop("checked", false).prop("disabled", true).change();
                            })
                        } else {
                            disableFullElement.prop("checked", false);
                            disableFullElement.parent().parent().find("input[type=text]").val("").addClass("d-none");
                        }
                    });
                }
                else {
                    subDisableElementsArray.forEach((element) => {
                        element.prop("checked", false).prop("disabled", false).change();
                    });
                }
            });
        }

        function SetPermissionInput(checkboxElement, reasonInputElement, disabledAt, disabledReason) {
            if (disabledAt) {
                checkboxElement.prop("checked", true).change();
                if (disabledReason) {
                    reasonInputElement.val(disabledReason);
                }
            } else {
                checkboxElement.prop("checked", false).change();
                reasonInputElement.val("");
            }
        }
    </script>

    <!-- PageLoader -->
    <script>
        var EverythingInitalized = false;
        const pageLoader = $("#page-loader");

        var PageLoaderInterval = setInterval(
            () => {
                if (
                    CurrentAppConfigData != null
                    &&
                    CurrentAppPermissionsData != null
                    &&
                    CurrentAppEmailTemplatesData != null
                    &&
                    CurrentUsersList != null
                    &&
                    CurrentBusinessesList != null
                    &&
                    CurrentPlansList != null
                    &&
                    CurrentLLMProvidersList != null
                    &&
                    CurrentSTTProvidersList != null
                    &&
                    CurrentTTSProvidersList != null
                    &&
                    CurrentEmbeddingProvidersList != null
                    &&
                    CurrentRerankProvidersList != null
                    &&
                    CurrentLanguagesList != null
                    &&
                    CurrentIntegrationsList != null
                    &&
                    EverythingInitalized == true
                ) {
                    clearInterval(PageLoaderInterval);

                    pageLoader.css("opacity", "0");
                    setTimeout(() => {
                        pageLoader.addClass("d-none");
                    }, 300);
                }
            }
            , 100);

        function RunActionAfterUsersLoad(action) {
            var usersCheckInterval = setInterval(
                () => {
                    if (CurrentUsersList != null) {
                        clearInterval(usersCheckInterval);
                        action();
                    }
                }
                , 100);
        }

        function RunActionAfterBusinessesLoad(action) {
            var businessesCheckInterval = setInterval(
                () => {
                    if (CurrentBusinessesList != null) {
                        clearInterval(businessesCheckInterval);
                        action();
                    }
                }
                , 100);
        }

        @{
            if (FrontendAppConfig.IsCloudVersion)
            {
                <text>
                    function RunActionAfterPlansLoad(action) {
                        var plansCheckInterval = setInterval(
                            () => {
                                if (CurrentPlansList != null) {
                                    clearInterval(plansCheckInterval);
                                    action();
                                }
                            }
                        , 100);
                    }
                </text>
            }
        }

        function RunActionAfterLLMProvidersLoad(action) {
            var LLMProvidersCheckInterval = setInterval(
                () => {
                    if (CurrentLLMProvidersList != null) {
                        clearInterval(LLMProvidersCheckInterval);
                        action();
                    }
                }
                , 100);
        }

        function RunActionAfterSTTProvidersLoad(action) {
            var STTProvidersCheckInterval = setInterval(
                () => {
                    if (CurrentSTTProvidersList != null) {
                        clearInterval(STTProvidersCheckInterval);
                        action();
                    }
                }
                , 100);
        }

        function RunActionAfterTTSProvidersLoad(action) {
            var TTSProvidersCheckInterval = setInterval(
                () => {
                    if (CurrentTTSProvidersList != null) {
                        clearInterval(TTSProvidersCheckInterval);
                        action();
                    }
                }
                , 100);
        }

        function RunActionAfterEmbeddingProvidersLoad(action) {
            var EmbeddingProvidersCheckInterval = setInterval(
                () => {
                    if (CurrentEmbeddingProvidersList != null) {
                        clearInterval(EmbeddingProvidersCheckInterval);
                        action();
                    }
                }
                , 100);
        }

        function RunActionAfterRerankProvidersLoad(action) {
            var RerankProvidersCheckInterval = setInterval(
                () => {
                    if (CurrentRerankProvidersList != null) {
                        clearInterval(RerankProvidersCheckInterval);
                        action();
                    }
                }
                , 100);
        }

        function RunActionAfterLanguagesLoad(action) {
            var languagesCheckInterval = setInterval(
                () => {
                    if (CurrentLanguagesList != null) {
                        clearInterval(languagesCheckInterval);
                        action();
                    }
                }
                , 100);
        }

        function RunActionAfterIntegrationsLoad(action) {
            var integrationsCheckInterval = setInterval(
                () => {
                    if (CurrentIntegrationsList != null) {
                        clearInterval(integrationsCheckInterval);
                        action();
                    }
                }
                , 100);
        }
    </script>

    <!-- Scripts -->
    <script src="~/scripts/app/admin/app_tab.js"></script>
    <script src="~/scripts/app/admin/users_tab.js"></script>
    <script src="~/scripts/app/admin/businesses_tab.js"></script>
    @{
        if (FrontendAppConfig.IsCloudVersion)
        {
            <script src="~/scripts/app/admin/billing_tab.js"></script>
        }
    }
    <script src="~/scripts/app/admin/infrastructure_tab.js"></script>
    <script src="~/scripts/app/admin/llm_provider_tab.js"></script>
    <script src="~/scripts/app/admin/stt_provider_tab.js"></script>
    <script src="~/scripts/app/admin/tts_provider_tab.js"></script>
    <script src="~/scripts/app/admin/embedding_provider_tab.js"></script>
    <script src="~/scripts/app/admin/rerank_provider_tab.js"></script>
    <script src="~/scripts/app/admin/languages_tab.js"></script>
    <script src="~/scripts/app/admin/integrations_tab.js"></script>

    <script>
        // Init App Tab
        initAppTab();

        // Init Infrastructure Tab
        initInfrastructureTab();

        // Fetch Initial Data
        FetchUsersFromAPI(
            UsersTabListTabPage, UsersTabListTabPageSize,
            (users) => {
                CurrentUsersList = users;
            },
            (usersError) => {
                AlertManager.createAlert({
                    type: "danger",
                    message: "Error occured while fetching users. Check browser console for logs.",
                    timeout: 5000,
                });

                console.log("Error occured while fetching users: ", usersError);
            },
        );

        @{
            if (FrontendAppConfig.IsCloudVersion)
            {
                <text>
                    FetchPlansFromAPI(
                        PlansListTablePage, PlansListTablePageSize,
                        (plans) => {
                            CurrentPlansList = plans;
                        },
                        (error) => {
                            AlertManager.createAlert({
                                type: "danger",
                                message: "Error occured while fetching plans. Check browser console for logs.",
                                timeout: 5000
                            });

                            console.error("Error occured while fetching plans:", error);
                        }
                    );
                </text>
            }
        }
 
        @{
            if (FrontendAppConfig.IsCloudVersion)
            {
                <text>
                    // Users Tab
                    RunActionAfterUsersLoad(() => {
                        RunActionAfterPlansLoad(() => {
                            initUsersTab();
                        });
                    });

                    // Billing/Plan Tab
                    RunActionAfterPlansLoad(() => {
                        InitBillingPlansTab();
                    });
                </text>
            }
            else
            {
                <text>
                    // Users Tab
                    RunActionAfterUsersLoad(() => {
                        initUsersTab();
                    });
                </text>
            }
        }

        EverythingInitalized = true;
    </script>
</body>

</html>