<div class="main-container fade w-100 d-none" id="tts-provider-tab">
    <h3 class="fw-bold tab-title mb-3"><i class='fa-regular fa-volume-high nav_icon'></i> <span>TTS Provider</span></h3>

    <div class="inner-header-container mb-3">
        <!-- List Header -->
        <ul class="nav w-100 fade show" id="tts-provider-list-inner-header" role="tablist">
            <li class="nav-item me-2" role="presentation">
                <button class="nav-link active" id="tts-provider-list-tab" data-bs-toggle="pill" data-bs-target="#tts-provider-list" type="button" role="tab" aria-controls="tts-provider-list" aria-selected="true">List</button>
            </li>
        </ul>

        <!-- Manager Header -->
        <div class="w-100 fade d-none" id="tts-provider-manager-inner-header">
            <nav class="mb-3" aria-label="breadcrumb" id="tts-provider-manage-breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item">
                        <a href="#" id="switchBackToTTSProviderListTabFromManageTab">Providers</a>
                    </li>
                    <li class="breadcrumb-item active" aria-current="page">
                        <span id="currentManageTTSProviderName">Provider</span>
                    </li>
                </ol>
            </nav>
            <div class="d-flex flex-row align-items-center justify-content-between w-100">
                <ul class="nav fade show" id="tts-provider-manager-inner-tab" role="tablist">
                    <li class="nav-item me-2" role="presentation">
                        <button class="nav-link active" id="tts-provider-manager-general-tab" data-bs-toggle="pill" data-bs-target="#tts-provider-manager-general" type="button" role="tab" aria-controls="tts-provider-manager-general" aria-selected="true">General</button>
                    </li>
                    <li class="nav-item me-2" role="presentation">
                        <button class="nav-link" id="tts-provider-manager-models-tab" data-bs-toggle="pill" data-bs-target="#tts-provider-manager-models" type="button" role="tab" aria-controls="tts-provider-manager-models" aria-selected="true">Models</button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="tts-provider-manager-integrations-tab" data-bs-toggle="pill" data-bs-target="#tts-provider-manager-integrations" type="button" role="tab" aria-controls="tts-provider-manager-integrations" aria-selected="false">Integrations</button>
                    </li>
                </ul>
                <button class="btn btn-primary btn-sm btn-ic-span-align" id="saveManageTTSProviderButton" disabled>
                    <i class='fa-regular fa-floppy-disk'></i>
                    <span> Save</span>
                </button>
            </div>
        </div>
        
        <!-- Manager Model Header -->
        <div class="w-100 fade d-none" id="tts-provider-manager-model-inner-header">
            <div class="d-flex flex-row align-items-center justify-content-between">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item" aria-current="page">
                        <span id="currentManageModelTTSProviderName">Provider</span>
                    </li>
                    <li class="breadcrumb-item">
                        <a href="#" id="switchBackToTTSProviderManagerModelsListTabFromModelTab">Models</a>
                    </li>
                    <li class="breadcrumb-item active" aria-current="page">
                        <span id="currentManageTTSProviderModelName">Model</span>
                    </li>
                </ol>
                <button class="btn btn-primary btn-sm btn-ic-span-align" id="saveManageTTSProviderModelButton">
                    <i class='fa-regular fa-floppy-disk'></i>
                    <span> Save</span>
                </button>
            </div>
        </div>
    </div>

    <div class="inner-container">
        <!-- Tab Content -->
        <div class="tab-content" id="tts-provider-tab-content">
            <!-- List -->
            <div class="tab-pane fade w-100 show active" id="tts-provider-list" role="tabpanel" aria-labelledby="tts-provider-list-tab" tabindex="0">

                <!-- Table Tab -->
                <div class="fade w-100 show" id="ttsProviderListTableTab">
                    <div class="mb-4 d-flex flex-row align-items-center justify-content-between">
                        <div class="input-group w-100">
                            <input type="text" class="form-control" placeholder="TTS Provider Name or Id" aria-label="TTS Provider Name or Id" aria-describedby="searchTTSProviderButton">
                            <button class="input-group-button btn btn-primary" id="searchTTSProviderButton">
                                <i class='fa-regular fa-magnifying-glass'></i>
                            </button>
                        </div>
                    </div>
                    <table id="ttsProviderListTable" class="table w-100">
                        <thead>
                            <tr>
                                <th scope="col">#</th>
                                <th scope="col">Name</th>
                                <th scope="col">Disabled</th>
                                <th scope="col">Models</th>
                                <th scope="col">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <!-- Dynamically Generated -->
                        </tbody>
                    </table>
                </div>

                <!-- Provider Manage Tab -->
                <div class="fade w-100 d-none" id="ttsProviderManageTab">
                    <!-- Tab Content -->
                    <div class="tab-content" id="tts-provider-manager-manage-tab-content">
                        <!-- General Tab -->
                        <div class="tab-pane fade w-100 show active" id="tts-provider-manager-general" role="tabpanel" aria-labelledby="tts-provider-manager-general-tab" tabindex="0">
                            <div class="mb-3">
                                <label class="form-label" for="manageTTSProviderIdInput">Identifier</label>
                                <input type="text" class="form-control" id="manageTTSProviderIdInput" placeholder="Identifier" disabled>
                            </div>
                            <div class="mb-3">
                                <label class="form-label" for="manageTTSProviderIntegrationSelect">Integration</label>
                                <select class="form-select" id="manageTTSProviderIntegrationSelect">
                                    <option value="">Select Integration</option>
                                </select>
                            </div>
                            <div class="form-check form-switch mb-3">
                                <input class="form-check-input" type="checkbox" role="switch" id="manageTTSProviderDisabledInput">
                                <label class="form-check-label" for="manageTTSProviderDisabledInput">Disabled</label>
                            </div>
                        </div>

                        <!-- Models Tab -->
                        <div class="tab-pane fade w-100" id="tts-provider-manager-models" role="tabpanel" aria-labelledby="tts-provider-manager-models-tab" tabindex="0">

                            <!-- Models List Tab -->
                            <div class="fade w-100 show" id="ttsProviderManagerModelsListTab">
                                <div class="mb-4 d-flex flex-row align-items-center justify-content-between">
                                    <div style="min-width: 200px" class="me-4">
                                        <button class="w-100 mb-0 text-decoration-none fw-bold btn btn-primary" id="addNewTTSProviderModelButton">
                                            <span>+ Add New Model</span>
                                        </button>
                                    </div>
                                    <div class="input-group w-100">
                                        <input type="text" class="form-control" placeholder="Model Name or Id" aria-label="Model Name or Id" aria-describedby="searchTTSProviderModelButton">
                                        <button class="input-group-button btn btn-primary" id="searchTTSProviderModelButton">
                                            <i class='fa-regular fa-magnifying-glass'></i>
                                        </button>
                                    </div>
                                </div>
                                <table id="ttsProviderModelListTable" class="table w-100">
                                    <thead>
                                        <tr>
                                            <th scope="col">#</th>
                                            <th scope="col">Name</th>
                                            <th scope="col">Languages</th>
                                            <th scope="col">Disabled</th>
                                            <th scope="col">Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <!-- Dynamically Generated -->
                                    </tbody>
                                </table>
                            </div>

                            <!-- Model Manage Tab -->
                            <div class="fade w-100 d-none" id="ttsProviderManagerModelManageTab">
                                <!-- Basic Information -->
                                <div class="mb-3">
                                    <label class="form-label" for="manageTTSProviderModelIdInput">Identifier</label>
                                    <input type="text" class="form-control" id="manageTTSProviderModelIdInput" placeholder="Model Identifier">
                                </div>
                                <div class="mb-3">
                                    <label class="form-label" for="manageTTSProviderModelNameInput">Name</label>
                                    <input type="text" class="form-control" id="manageTTSProviderModelNameInput" placeholder="Model Name">
                                </div>

                                <!-- Price Settings -->
                                <div class="mb-3">
                                    <label class="form-label">Price Per Unit</label>
                                    <div class="input-group">
                                        <input type="number" class="form-control" placeholder="Price" id="manageTTSProviderModelPriceInput">
                                        <input type="text" class="form-control" style="max-width: 200px" placeholder="Unit (e.g., per character)" id="manageTTSProviderModelPriceUnitInput">
                                    </div>
                                </div>

                                <!-- Language Support -->
                                <div class="mb-3">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <label class="form-label mb-0">Supported Languages</label>
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" role="switch" id="manageTTSProviderModelMultilingualInput">
                                            <label class="form-check-label" for="manageTTSProviderModelMultilingualInput">Multilingual</label>
                                        </div>
                                    </div>
                                    <div id="manageTTSProviderModelLanguagesContainer">
                                        <!-- Will be populated with language checkboxes -->
                                    </div>
                                </div>

                                <div class="form-check form-switch mb-3">
                                    <input class="form-check-input" type="checkbox" role="switch" id="manageTTSProviderModelDisabledInput">
                                    <label class="form-check-label" for="manageTTSProviderModelDisabledInput">Disabled</label>
                                </div>
                            </div>
                        </div>

                        <!-- Integrations Tab -->
                        <div class="tab-pane fade w-100" id="tts-provider-manager-integrations" role="tabpanel" aria-labelledby="tts-provider-manager-integrations-tab" tabindex="0">
                            <div class="mb-4 d-flex flex-row align-items-center justify-content-between">
                                <div style="min-width: 200px" class="me-4">
                                    <button class="w-100 mb-0 text-decoration-none fw-bold btn btn-primary" id="addNewTTSProviderIntegrationFieldButton">
                                        <span>+ Add New Field</span>
                                    </button>
                                </div>
                                <div class="input-group w-100">
                                    <input type="text" class="form-control" placeholder="Search Field" aria-label="Search Field" aria-describedby="searchTTSProviderIntegrationFieldButton">
                                    <button class="input-group-button btn btn-primary" id="searchTTSProviderIntegrationFieldButton">
                                        <i class='fa-regular fa-magnifying-glass'></i>
                                    </button>
                                </div>
                            </div>
                            <div id="ttsProviderIntegrationFieldsList">
                                <!-- Fields will be dynamically added here -->
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
