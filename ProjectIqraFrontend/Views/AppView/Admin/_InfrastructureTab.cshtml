                                    <button class="nav-link active" data-metric="cpu" data-bs-toggle="pill" type="button">CPU</button>
                                </li>
                                <li class="nav-item me-2" role="presentation">
                                    <button class="nav-link" data-metric="ram" data-bs-toggle="pill" type="button">RAM</button>
                                </li>
                                <li class="nav-item me-2" role="presentation">
                                    <button class="nav-link" data-metric="network" data-bs-toggle="pill" type="button">Network</button>
                                </li>
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link" id="serverDynamicMetricTab" data-metric="dynamic" data-bs-toggle="pill" type="button">Load</button>
                                </li>
                            </ul>
                            <!-- Canvas -->
                            <div class="position-relative" style="height: 300px; width: 100%;">
                                <canvas id="serverMetricsChart"></canvas>

                                <div id="serverMetricsChartNoData" class="d-none position-absolute top-50 start-50 translate-middle text-center">
                                    <i class="fa-regular fa-chart-scatter fa-3x text-secondary mb-3"></i>
                                    <h6 class="text-muted">No historical data found</h6>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Server Settings -->
                <div class="tab-pane fade show active w-100" id="server-manager-settings" role="tabpanel">

                    <!-- Configuration -->
                    <div class="card bg-dark mw-100 mb-4" style="max-width: 800px;">
                        <div class="card-body">
                            <h5 class="card-title mb-3">Configuration</h5>
                            <div class="mb-3">
                                <label class="form-label">Endpoint / IP <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="editServerEndpoint" placeholder="e.g. 10.0.0.1">
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Server Type <span class="text-danger">*</span></label>
                                <select class="form-select" id="editServerType">
                                    <option value="2">Backend (Media & Logic)</option>
                                    <option value="1">Proxy (Signaling)</option>
                                </select>
                            </div>
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">API Secret <span class="text-danger">*</span></label>
                                    <input type="password" class="form-control" id="editServerApiKey">
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">SIP Port</label>
                                    <input type="number" class="form-control" id="editServerSipPort" value="5060">
                                </div>
                            </div>
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="editServerIsDev">
                                <label class="form-check-label" for="editServerIsDev">Development Server</label>
                            </div>
                        </div>
                    </div>

                    <!-- Controls -->
                    <div class="card bg-dark mb-4" id="serverControlsCard">
                        <div class="card-body">
                            <h5 class="card-title text-danger mb-4">Node Controls</h5>
                            <!-- Maintenance -->
                            <div class="d-flex justify-content-between align-items-center mb-4">
                                <div>
                                    <h6 class="mb-1 text-warning">Maintenance Mode</h6>
                                    <p class="text-muted small mb-0">Stop routing new calls to this node.</p>
                                    <div class="small text-info d-none" id="serverMaintenanceReasonDisplay"><i class="fa-solid fa-circle-info me-1"></i> Reason: <span></span></div>
                                </div>
                                <div class="form-check form-switch">
                                    <input class="form-check-input status-toggle" type="checkbox" role="switch" id="editServerMaintenanceMode" data-type="maintenance" style="width: 3em; height: 1.5em;">
                                </div>
                            </div>
                            <!-- Disabled -->
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="mb-1 text-secondary">Disable Node</h6>
                                    <p class="text-muted small mb-0">Permanently disable this node.</p>
                                    <div class="small text-info d-none" id="serverDisabledReasonDisplay"><i class="fa-solid fa-circle-info me-1"></i> Reason: <span></span></div>
                                </div>
                                <div class="form-check form-switch">
                                    <input class="form-check-input status-toggle" type="checkbox" role="switch" id="editServerDisabled" data-type="disabled" style="width: 3em; height: 1.5em;">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ========================================================================================== -->
<!-- MODALS -->
<!-- ========================================================================================== -->

<!-- Add Region Modal -->
<div class="modal fade" id="infraAddRegionModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark border-secondary">
            <div class="modal-header border-bottom border-secondary">
                <h5 class="modal-title">Add New Region</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Country</label>
                    <select class="form-select" id="infraNewRegionCountry">
                        <option value="" disabled selected>Select Country</option>
                        <!-- Populated via JS using CountriesList -->
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">Region Name</label>
                    <input type="text" class="form-control" id="infraNewRegionId" placeholder="e.g. east, west-2, 1">
                    <div class="form-text text-white-50">
                        Resulting ID: <span id="infraNewRegionPreview" class="text-info font-monospace">...</span>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-top border-secondary">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="infraBtnConfirmAddRegion">Create Region</button>
            </div>
        </div>
    </div>
</div>

<!-- Status Change Reason Modal -->
<div class="modal fade" id="infraStatusReasonModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark border-secondary">
            <div class="modal-header border-bottom border-secondary">
                <h5 class="modal-title" id="infraStatusModalTitle">Change Status</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted mb-3" id="infraStatusModalMessage">Please provide a reason for this action.</p>
                <div class="mb-3">
                    <label class="form-label">Public Reason <i class="fa-solid fa-globe text-muted ms-1" title="Visible to users"></i></label>
                    <input type="text" class="form-control" id="infraStatusPublicReason" placeholder="e.g., Scheduled Maintenance">
                </div>
                <div class="mb-3">
                    <label class="form-label">Private Reason <i class="fa-solid fa-lock text-muted ms-1" title="Internal only"></i></label>
                    <input type="text" class="form-control" id="infraStatusPrivateReason" placeholder="e.g., Ticket #1234">
                </div>
            </div>
            <div class="modal-footer border-top border-secondary">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="infraStatusConfirmButton">Confirm Change</button>
            </div>
        </div>
    </div>
</div>