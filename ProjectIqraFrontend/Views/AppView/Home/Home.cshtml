@using IqraCore.Entities.Server.Configuration
@inject FrontendAppConfig FrontendAppConfig
<!DOCTYPE html>
<html data-bs-theme="dark">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Dashboard | Iqra AI</title>

    <link href="~/libs/bootstrap-5.3.3-dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/libs/fontawesome-pro-6.5.1-web-dist/css/fontawesome.min.css" rel="stylesheet">
    <link href="~/libs/fontawesome-pro-6.5.1-web-dist/css/regular.min.css" rel="stylesheet">
    <link href="~/libs/daterangepicker-dist/daterangepicker.css" rel="stylesheet">

    <link href="~/css/structure.css" rel="stylesheet">
    <link href="~/css/style.css" rel="stylesheet">

    <link rel="icon" type="image/png" href="/img/favicon/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/img/favicon/favicon.svg" />
    <link rel="shortcut icon" href="/img/favicon/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/img/favicon/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="Iqra" />
    <link rel="manifest" href="/img/favicon/site.webmanifest" />

    <style id="dynamicCSS"></style>
    <style id="dynamicBusinessCardH4CSS"></style>
</head>

<body id="body-pd" class="body-pd">
    <div id="page-loader">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>

    <header class="header header-body-pd" id="header">
        <div class="header_toggle">
            <i class='fa-regular fa-bars fa-bars' id="header-toggle"></i>
        </div>
        <div class="header_notification">
            <div class="btn-group">
                <button type="button" id="header-notification" class="dropdown-toggle position-relative" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="fa-regular fa-bell fa-bell"></i>
                    <span id="notification-counter" class="position-absolute translate-middle badge rounded-pill bg-danger" style="display: none; top: 10px; left: 25px;">
                        0
                    </span>
                </button>
                <div class="dropdown-menu dropdown-menu-end dropdown-menu-lg p-0">
                    <div class="p-3 border-bottom d-flex justify-content-between align-items-center">
                        <h6 class="mb-0">Notifications</h6>
                        <a href="#" id="mark-all-read" class="text-muted small">Mark all as read</a>
                    </div>

                    <!-- The list will be dynamically populated here -->
                    <div class="p-0" id="notifications-list" style="max-height: 400px; overflow-y: auto;">
                        <!-- Example of an empty state -->
                        <div id="notification-empty-state" class="text-center p-4 text-muted">
                            <i class="fa-regular fa-check-circle fa-2x mb-2"></i>
                            <p>You're all caught up!</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- Sidebar -->
    <div class="l-navbar show" id="nav-bar">
        <nav class="nav">
            <div class="upper-navigation w-100">
                <a href="/" class="nav_logo">
                    <img class="nav_logo-icon" src="~/img/logo/logo-colored-light.png">
                </a>
                <div class="nav_list">
                    <a class="nav_link active" for="business-tab" nav-url-path="businesses" is-default="true">
                        <i class='fa-regular fa-briefcase nav_icon'></i>
                        <span class="nav_name">Businesses</span>
                    </a>
                    <a class="nav_link" for="usage-tab" nav-url-path="usage">
                        <i class='fa-regular fa-chart-line nav_icon'></i>
                        <span class="nav_name">Usage</span>
                    </a>
                    <a class="nav_link" for="api-keys-tab" nav-url-path="api-keys">
                        <i class='fa-regular fa-key nav_icon'></i>
                        <span class="nav_name">API Keys</span>
                    </a>
                    @{
                        if (FrontendAppConfig.IsCloudVersion)
                        {
                            <a class="nav_link" for="billing-tab" nav-url-path="billing">
                                <i class='fa-regular fa-credit-card nav_icon'></i>
                                <span class="nav_name">Billing</span>
                            </a>
                            <a class="nav_link" for="white-label-tab" nav-url-path="whitelabel">
                                <i class='fa-regular fa-tags nav_icon'></i>
                                <span class="nav_name">White Label</span>
                            </a>
                        }
                    }
                </div>
            </div>
            <div class="bottom-navigation w-100">
                <a href="https://docs.iqra.bot/" target="_blank" class="nav_link mt-0">
                    <i class='fa-regular fa-circle-question nav_icon'></i>
                    <span class="nav_name">Documentation</span>
                </a>
                <a href="/logout" class="nav_link mt-2">
                    <i class='fa-regular fa-right-from-bracket nav_icon'></i>
                    <span class="nav_name">Log out</span>
                </a>
            </div>
        </nav>
    </div>

    <!-- Main Container -->
    <div class="w-100 main-container-wrapper" id="tabs-list">

        <!-- Bussiness Container -->
        <partial name="_BusinessesTab.cshtml" />

        <!-- Usage Container -->
        <partial name="_UsageTab.cshtml" />

        <!-- API Keys Container -->
        <partial name="_APIKeysTab.cshtml" />

        @{
            if (FrontendAppConfig.IsCloudVersion)
            {
                <!-- Billing Container -->
                <partial name="_BillingTab.cshtml" />
                
                <!-- White Label Container -->
                <partial name="_WhiteLabelTab.cshtml" />
            }
        }

    </div>

    <!-- libs -->
    <script defer src="https://umscriptami.badal.om/script.js" data-website-id="8f350117-f10d-4bdb-a6d6-63d4117a21c3"></script>
    <script src="~/js/jquery-3.7.1.min.js"></script>
    <script src="~/libs/bootstrap-5.3.3-dist/js/bootstrap.bundle.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="~/js/moment-with-locales.js"></script>
    <script src="~/js/moment-timezone-with-data.js"></script>
    <script src="~/libs/daterangepicker-dist/daterangepicker.js"></script>

    <!-- Custom Scripts -->
    <script src="~/js/ui_helpers.js"></script>
    <script src="~/js/countries_list.js"></script>
    <script src="~/js/alert_manager.js"></script>
    <script src="~/js/notifications_manager.js"></script>
    <script src="~/js/confirm_dialog.js"></script>
    <script src="~/js/script.js"></script>

    <!-- Variables -->
    <script>
        var isBusinessAnimationEnabled = true;
    </script>

    <!-- Global -->
    <script>
        const AlertManager = new BootstrapAlertManager();
        window.AlertManager = AlertManager; // needed for iframes

        const notificationManager = new NotificationsManager();

        var MasterUserData = null;
        @{
            if (FrontendAppConfig.IsCloudVersion)
            {
                <text>var UserPlanData = null;</text>
            }
            else
            {
                <text>var UserPlanData = {};</text>
            }
        }  
        var SpecificationLanguagesListData = null;
        var CurrentBusinessesList = null;

        // API Related Calls
        function FetchMasterUserDataFromAPI(successCallback, errorCallback) {
            $.ajax({
                url: '/app/user',
                type: 'GET',
                success: (response) => {
                    if (!response.success) {
                        errorCallback(response);
                        return;
                    }

                    successCallback(response.data);
                },
                error: (error) => {
                    errorCallback(error);
                }
            });
        }

        @{
            if (FrontendAppConfig.IsCloudVersion)
            {
                <text>
                    function FetchUserBillingPlanDataFromAPI(successCallback, errorCallback) {
                        $.ajax({
                            url: '/app/user/billing/plan',
                            type: 'GET',
                            success: (response) => {
                                if (!response.success) {
                                    errorCallback(response);
                                    return;
                                }
                                successCallback(response.data);
                            },
                            error: (error) => {
                                errorCallback(error);
                            }
                        });
                    }
                </text>
            }
        }

        function FetchSpecificationLanguagesDataFromAPI(successCallback, errorCallback) {
            $.ajax({
                url: '/app/specification/languages/',
                type: 'GET',
                success: (response) => {
                    if (!response.success) {
                        errorCallback(response);
                        return;
                    }

                    successCallback(response.data);
                },
                error: (error) => {
                    errorCallback(error);
                }
            });
        }

        function FetchUserBusinessesFromAPI(successCallback, errorCallback) {
            $.ajax({
                url: '/app/user/businesses',
                type: 'GET',
                success: (response) => {
                    if (!response.success) {
                        errorCallback(response);
                        return;
                    }

                    successCallback(response.data);
                },
                error: (error) => {
                    errorCallback(error);
                }
            });
        }

        function MarkNotificationAsReadAPI(notificationId, successCallback, errorCallback) {
            $.ajax({
                url: '/app/user/notification/read',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({ notificationId: notificationId }),
                success: successCallback,
                error: errorCallback
            });
        }

        function MarkNotificationActionClickedAPI(notificationId, actionId, successCallback, errorCallback) {
            $.ajax({
                url: '/app/user/notification/action/click',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({ notificationId: notificationId, actionId: actionId }),
                success: successCallback,
                error: errorCallback
            });
        }

        function MarkAllNotificationsAsReadAPI(successCallback, errorCallback) {
            $.ajax({
                url: '/app/user/notification/read-all',
                type: 'POST',
                success: successCallback,
                error: errorCallback
            });
        }
    </script>

    <!-- PageLoader -->
    <script>
        const pageLoader = $("#page-loader");

        var PageLoaderInterval = setInterval(
            () => {
                if (
                    MasterUserData != null
                    &&
                    UserPlanData != null
                    &&
                    CurrentBusinessesList != null
                    &&
                    SpecificationLanguagesListData != null
                ) {
                    clearInterval(PageLoaderInterval);

                    pageLoader.css("opacity", "0");
                    setTimeout(() => {
                        pageLoader.addClass("d-none");
                    }, 300);
                }
            }
            , 100);

        function RunActionAfterBusinessesDataLoad(action) {
            var businessDataCheckInterval = setInterval(
                () => {
                    if (CurrentBusinessesList != null) {
                        clearInterval(businessDataCheckInterval);
                        action();
                    }
                }
                , 100);
        }
    </script>

    <!-- Scripts -->
    <script src="~/scripts/app/home/businesses_tab.js"></script>
    <script src="~/scripts/app/home/usage_tab.js"></script>
    <script src="~/scripts/app/home/api_keys_tab.js"></script>
    @{
        if (FrontendAppConfig.IsCloudVersion)
        {
            <script src="~/scripts/app/home/billing_tab.js"></script>
            <script src="~/scripts/app/home/white_label_tab.js"></script>
        }
    }

    <!-- Init -->
    <script>
        $(document).ready(() => {

            FetchSpecificationLanguagesDataFromAPI(
                (specLanguagesDataResult) => {
                    SpecificationLanguagesListData = specLanguagesDataResult;

                    FetchMasterUserDataFromAPI(
                        (masterUserData) => {
                            MasterUserData = masterUserData;

                            // Add Notifications
                            masterUserData.notifications.forEach((backendNotification) => {
                                function getIconForNotificationType(typeEnum) {
                                    switch (typeEnum) {
                                        case 0: // General / Info
                                            return 'fa-regular fa-circle-info';
                                        case 1: // Success
                                            return 'fa-regular fa-circle-check text-success';
                                        case 2: // Warning
                                            return 'fa-regular fa-triangle-exclamation text-warning';
                                        case 3: // Error
                                            return 'fa-regular fa-circle-xmark text-danger';
                                        default:
                                            return 'fa-regular fa-bell';
                                    }
                                }

                                const frontendNotification = {
                                    id: backendNotification.id,
                                    icon: getIconForNotificationType(backendNotification.type.value),
                                    title: backendNotification.title,
                                    description: backendNotification.body,
                                    timestamp: new Date(backendNotification.createdAt),
                                    isRead: backendNotification.isRead,
                                    isFixed: backendNotification.isFixed,
                                    source: 'backend'
                                };

                                frontendNotification.onRead = (notificationId) => {
                                    MarkNotificationAsReadAPI(notificationId,
                                        (response) => {
                                            if (!response.success) console.error(`Failed to mark notification ${notificationId} as read on server.`);
                                        },
                                        (error) => console.error(`API error marking notification ${notificationId} as read:`, error)
                                    );
                                };

                                if (backendNotification.actions && backendNotification.actions.length > 0) {
                                    const firstAction = backendNotification.actions[0];

                                    frontendNotification.action = {
                                        text: firstAction.title,
                                        class: 'btn-outline-primary',
                                        callback: () => {
                                            MarkNotificationActionClickedAPI(backendNotification.id, firstAction.id,
                                                (response) => {
                                                    if (response.success) {
                                                        try {
                                                            new Function(firstAction.callbackJavascript)();
                                                        } catch (e) {
                                                            console.error("Error executing callback javascript:", e);
                                                        }
                                                    } else {
                                                        console.error("Server failed to acknowledge action click.");
                                                    }
                                                },
                                                (error) => console.error("API error clicking action:", error)
                                            );
                                        }
                                    };
                                }

                                // 4. Add the fully constructed notification to the manager
                                notificationManager.addNotification(frontendNotification);
                            });

                            if (!MasterUserData.businessPermission.disableBusinesses) {
                                // Fetch and Init Businesses Tab
                                FetchUserBusinessesFromAPI(
                                    (userBusinesses) => {
                                        CurrentBusinessesList = userBusinesses;

                                        // Init The business Tab
                                        InitBusinessesTab();

                                        // Init Usage table
                                        InitUsageTab();

                                        // Init API Keys Tab
                                        InitApiKeysTab();

                                        @{
                                            if (FrontendAppConfig.IsCloudVersion)
                                            {
                                                <text>
                                                    // Init White Label Tab
                                                    InitWhiteLabelTab();
                                                </text>
                                            }
                                        }
                                    },
                                    (userBusinessesError) => {
                                        AlertManager.createAlert({
                                            type: "danger",
                                            message: "Error occured while fetching user businesses.<br>Check browser console for logs.<br>Refresh page to try again.",
                                            enableDismiss: false,
                                        });

                                        console.error("Error occured while fetching user businesses: ", userBusinessesError);
                                    },
                                );

                                @{
                                    if (FrontendAppConfig.IsCloudVersion)
                                    {
                                        <text>
                                            // Fetch and init Billing Tab
                                            FetchUserBillingPlanDataFromAPI(
                                                (userPlanData) => {
                                                    UserPlanData = userPlanData;

                                                    // Init Billing Tab
                                                    InitBillingTab();
                                                },
                                                (userPlanDataError) => {
                                                    AlertManager.createAlert({
                                                        type: "danger",
                                                        message: "Error occured while fetching user plan data.<br>Check browser console for logs.<br>Refresh page to try again.",
                                                        enableDismiss: false,
                                                    });
                                                    console.error("Error occured while fetching user plan data: ", userPlanDataError);
                                                },
                                            );
                                        </text>
                                    }
                                }
                                    
                            } else {
                                CurrentBusinessesList = [];

                                let alertMessage = "Bussiness Viewing, Adding, Editing and Deleting are disabled for your account.";
                                if (MasterUserData.businessPermission.disableBusinessesReason != null) {
                                    alertMessage = `${alertMessage}<br>Reason: ${MasterUserData.businessPermission.disableBusinessesReason}`;
                                } else {
                                    alertMessage = `${alertMessage}<br>Please contact support for more information.`;
                                }

                                notificationManager.addNotification({
                                    icon: 'fa-regular fa-circle-xmark text-danger',
                                    title: "Bussinesses Disabled",
                                    description: alertMessage,
                                    timestamp: new Date(MasterUserData.businessPermission.disableBusinesses),
                                    isFixed: true,
                                    source: "backend",
                                });

                                AlertManager.createAlert({
                                    type: "danger",
                                    message: alertMessage,
                                    enableDismiss: true,
                                });
                            }

                            // Check sub business permissions
                            if (!MasterUserData.businessPermission.disableBusinesses)
                            {
                                // check business add allowed
                                if (MasterUserData.businessPermission.addBusinessDisabled) {
                                    let alertMessage = "Bussiness Adding is disabled for your account.";

                                    if (MasterUserData.businessPermission.addBusinessDisableReason != null) {
                                        alertMessage = `${alertMessage}<br>Reason: ${MasterUserData.businessPermission.addBusinessDisableReason}`;
                                    } else {
                                        alertMessage = `${alertMessage}<br>Please contact support for more information.`;
                                    }

                                    notificationManager.addNotification({
                                        icon: 'fa-regular fa-circle-xmark text-danger',
                                        title: "Bussiness Adding Disabled",
                                        description: alertMessage,
                                        timestamp: new Date(MasterUserData.businessPermission.addBusinessDisabled),
                                        isFixed: true,
                                        source: 'backend'
                                    })

                                    AlertManager.createAlert({
                                        type: "danger",
                                        message: alertMessage,
                                        enableDismiss: true,
                                    });
                                } else {
                                    AddNewBusinessButton.prop("disabled", false);
                                }

                                // check business edit allowed
                                if (MasterUserData.businessPermission.editBusinessDisabled) {
                                    let alertMessage = "Bussiness Editing is disabled for your account.";

                                    if (MasterUserData.businessPermission.editBusinessDisableReason != null) {
                                        alertMessage = `${alertMessage}<br>Reason: ${MasterUserData.businessPermission.editBusinessDisableReason}`;
                                    } else {
                                        alertMessage = `${alertMessage}<br>Please contact support for more information.`;
                                    }

                                    notificationManager.addNotification({
                                        icon: 'fa-regular fa-circle-xmark text-danger',
                                        title: "Bussiness Editing Disabled",
                                        description: alertMessage,
                                        timestamp: new Date(MasterUserData.businessPermission.editBusinessDisabled),
                                        isFixed: true,
                                        source: 'backend'
                                    })

                                    AlertManager.createAlert({
                                        type: "danger",
                                        message: alertMessage,
                                        enableDismiss: true,
                                    });
                                }

                                // check business delete allowed
                                if (MasterUserData.businessPermission.deleteBusinessDisable) {
                                    let alertMessage = "Bussiness Deleting is disabled for your account.";

                                    if (MasterUserData.businessPermission.deleteBusinessDisableReason != null) {
                                        alertMessage = `${alertMessage}<br>Reason: ${MasterUserData.businessPermission.deleteBusinessDisableReason}`;
                                    } else {
                                        alertMessage = `${alertMessage}<br>Please contact support for more information.`;
                                    }

                                    notificationManager.addNotification({
                                        icon: 'fa-regular fa-circle-xmark text-danger',
                                        title: "Bussiness Deleting Disabled",
                                        description: alertMessage,
                                        timestamp: new Date(MasterUserData.businessPermission.deleteBusinessDisable),
                                        isFixed: true,
                                        source: 'backend'
                                    })

                                    AlertManager.createAlert({
                                        type: "danger",
                                        message: alertMessage,
                                        enableDismiss: true,
                                    });
                                }
                            }

                        },
                        (masterUserDataError) => {
                            AlertManager.createAlert({
                                type: "danger",
                                message: "Error occured while fetching user data. Check browser console for logs.",
                                enableDismiss: false,
                            });

                            console.error("Error occured while fetching user data: ", masterUserDataError);
                        },
                    );
                },
                (specLanguagesListError) => {
                    AlertManager.createAlert({
                        type: "danger",
                        message: "Error occured while fetching specification languages. Check browser console for logs.",
                        enableDismiss: false,
                    });

                    console.error("Error occured while fetching specification languages: ", specLanguagesListError);
                }
            );
        });
    </script>
</body>

</html>