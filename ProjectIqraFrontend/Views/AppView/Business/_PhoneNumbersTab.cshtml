                        <input type="tel" class="form-control" id="physicalNumberModalNumberInput" placeholder="Number">
                    </div>
                    <div class="mb-3">
                        <label for="physicalNumberModalRegionSelect" class="form-label">Route Server Region <a href="#" class="d-inline-block" data-bs-toggle="tooltip" data-bs-placement="right" data-bs-html="true" data-bs-title="Iqra's server region that will be used to process the call (For low latency, match your TTS/STT/LLM/etc intergation's region closed to this region)."><i class="fa-regular fa-circle-question"></i></a></label>
