                    <div style="min-width: 300px" class="me-4">
                        <button class="w-100 mb-0 text-decoration-none fw-bold btn btn-primary" id="addNewCustomSimNumberButton">
                            <span>+ Add ModemTel Number</span>
                        </button>
                    </div>
                    <div class="input-group w-100">
                        <input type="text" class="form-control" placeholder="Phone Number" aria-label="Phone Number" aria-describedby="searchCustomSimNumberButton">
