                <div class="modal-body">
                    <div class="mb-3">
                        <label for="physicalNumberModalIntegrationSelect" class="form-label">Integration</label>
                        <select class="form-select" id="physicalNumberModalIntegrationSelect">
                            <!-- Dynamically Generated Once -->
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="physicalNumberModalCountrySelect" class="form-label">Country Code</label>
                        <select class="form-select" id="physicalNumberModalCountrySelect">
