<div class="main-container fade w-100 d-none" id="conversations-tab">
    <h3 class="fw-bold tab-title mb-3"><i class='fa-regular fa-messages'></i> <span>Conversations</span></h3>
    <div class="inner-header-container mb-3">
        <ul class="nav" id="conversations-tab" role="tablist">
            <li class="nav-item me-2" role="presentation">
                <button class="nav-link active" id="conversations-inbound-tab" data-bs-toggle="pill" data-bs-target="#conversations-inbound" type="button" role="tab" aria-controls="conversations-inbound" aria-selected="true">Inbound Call</button>
            </li>
            <li class="nav-item me-2" role="presentation">
                <button class="nav-link" id="conversations-outbound-tab" data-bs-toggle="pill" data-bs-target="#conversations-outbound" type="button" role="tab" aria-controls="conversations-outbound" aria-selected="false">Outbound Call</button>
            </li>
            <li class="nav-item me-2" role="presentation">
                <button class="nav-link" id="conversations-websocket-tab" data-bs-toggle="pill" data-bs-target="#conversations-websocket" type="button" role="tab" aria-controls="conversations-websocket" aria-selected="false">Websocket</button>
            </li>
        </ul>
    </div>
    <div class="inner-container">
        <!-- Conversations List Tab -->
        <div class="show fade w-100" id="conversationListTab">
            <div class="tab-content w-100" id="conversations-tabContent">
                <!-- Inbound Tab -->
                <div class="tab-pane fade show active w-100" id="conversations-inbound" role="tabpanel" aria-labelledby="conversations-inbound-nav-tab" tabindex="0">
                    <div class="mb-4 d-flex flex-row align-items-center justify-content-between">
                        <div style="min-width: 200px" class="me-4">
                            <button class="w-100 mb-0 text-decoration-none fw-bold btn btn-primary btn-ic-span-align" id="filterInboundCallButton">
                                <i class="fa-regular fa-bars-filter me-1"></i>
                                <span>Filter</span>
                            </button>
                        </div>
                        <div class="input-group w-100">
                            <input type="text" class="form-control" placeholder="Routing Name or Session" aria-label="Routing Name or Session" aria-describedby="searchConversationInboundButton">
                            <button class="input-group-button btn btn-primary" id="searchConversationInboundButton">
                                <i class='fa-regular fa-magnifying-glass'></i>
                            </button>
                        </div>
                    </div>
                    <div class="table-responsive">
                        <table id="conversationInboundTable" class="table w-100">
                            <thead>
                                <tr>
                                    <th scope="col">Queue ID</th>
                                    <th scope="col">Queued At</th>
                                    <th scope="col" class="text-center">Queue Status</th>
                                    <th scope="col">Routing</th>
                                    <th scope="col">From</th>
                                    <th scope="col">To</th>
                                    <th scope="col">Session ID</th>
                                    <th scope="col" class="text-center">Session Status</th>
                                    <th scope="col">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr class="loading-row">
                                    <td colspan="9" class="text-center p-4">
                                        <div class="spinner-border text-primary" role="status">
                                            <span class="visually-hidden">Loading...</span>
                                        </div>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <div class="d-flex justify-content-center align-items-center mt-3" id="inboundPaginationControls">
                        <button class="btn btn-primary me-2" id="inboundPrevButton" disabled>
                            <i class="fa-regular fa-arrow-left me-1"></i>
                        </button>
                        <span class="text-muted mx-2" id="inboundPageInfo">Page 1</span>
                        <button class="btn btn-primary ms-2" id="inboundNextButton" disabled>
                            <i class="fa-regular fa-arrow-right ms-1"></i>
                        </button>
                    </div>
                </div>

                <!-- Outbound Tab -->
                <div class="tab-pane fade w-100" id="conversations-outbound" role="tabpanel" aria-labelledby="conversations-outbound-tab" tabindex="0">
                    <div class="mb-4 d-flex flex-row align-items-center justify-content-between">
                        <div style="min-width: 200px" class="me-4">
                            <button class="w-100 mb-0 text-decoration-none fw-bold btn btn-primary btn-ic-span-align" id="filterOutboundCallButton">
                                <i class="fa-regular fa-bars-filter me-1"></i>
                                <span>Filter</span>
                            </button>
                        </div>
                        <div class="input-group w-100">
                            <input type="text" class="form-control" placeholder="Recipient Number or Session" aria-label="Recipient Number or Session" aria-describedby="searchConversationOutboundButton">
                            <button class="input-group-button btn btn-primary" id="searchConversationOutboundButton">
                                <i class='fa-regular fa-magnifying-glass'></i>
                            </button>
                        </div>
                    </div>
                    <div class="table-responsive">
                        <table id="conversationOutboundTable" class="table w-100">
                            <thead>
                                <tr>
                                    <th scope="col">Queue ID</th>
                                    <th scope="col">Queued At</th>
                                    <th scope="col" class="text-center">Queue Status</th>
                                    <th scope="col">From</th>
                                    <th scope="col">To</th>
                                    <th scope="col">Session ID</th>
                                    <th scope="col" class="text-center">Session Status</th>
                                    <th scope="col">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr class="loading-row">
                                    <td colspan="8" class="text-center p-4">
                                        <div class="spinner-border text-primary" role="status">
                                            <span class="visually-hidden">Loading...</span>
                                        </div>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <div class="d-flex justify-content-center align-items-center mt-3" id="outboundPaginationControls">
                        <button class="btn btn-primary me-2" id="outboundPrevButton" disabled>
                            <i class="fa-regular fa-arrow-left me-1"></i>
                        </button>
                        <span class="text-muted mx-2" id="outboundPageInfo">Page 1</span>
                        <button class="btn btn-primary ms-2" id="outboundNextButton" disabled>
                            <i class="fa-regular fa-arrow-right ms-1"></i>
                        </button>
                    </div>
                </div>

                <!-- Websocket Tab -->
                <div class="tab-pane fade w-100" id="conversations-websocket" role="tabpanel" aria-labelledby="conversations-websocket-tab" tabindex="0">
                    <div class="mb-4 d-flex flex-row align-items-center justify-content-between">
                        <div style="min-width: 200px" class="me-4">
                            <button class="w-100 mb-0 text-decoration-none fw-bold btn btn-primary btn-ic-span-align" id="filterWebsocketButton">
                                <i class="fa-regular fa-bars-filter me-1"></i>
                                <span>Filter</span>
                            </button>
                        </div>
                        <div class="input-group w-100">
                            <input type="text" class="form-control" placeholder="Websocket Name, Identifier or Session" aria-label="Websocket Name, Identifier or Session" aria-describedby="searchConversationWebsocketButton">
                            <button class="input-group-button btn btn-primary" id="searchConversationWebsocketButton">
                                <i class='fa-regular fa-magnifying-glass'></i>
                            </button>
                        </div>
                    </div>
                    <div>
                        <table id="conversationWebsocketTable" class="table w-100">
                            <thead>
                                <tr>
                                    <th scope="col" style="width: 50px;"></th>
                                    <th scope="col">Name</th>
                                    <th scope="col">Identifier</th>
                                    <th scope="col">Datetime</th>
                                    <th scope="col">Session</th>
                                    <th scope="col">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <th scope="row" style="text-align: center;">
                                        <span class="in-progress">
                                            <i class="fa-regular fa-loader fa-spin"></i>
                                        </span>
                                    </th>
                                    <th scope="row">
                                        Badal.om
                                    </th>
                                    <td>
                                        user-abdua5coc
                                    </td>
                                    <td>6/16/2024 11:51 PM</td>
                                    <td>12-31511212</td>
                                    <td>
                                        <button class="btn btn-info btn-sm">
                                            <i class="fa-regular fa-eye"></i>
                                        </button>
                                        <button class="btn btn-danger btn-sm">
                                            <i class="fa-regular fa-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Conversations Manage Tab -->
        <div class="fade d-none w-100" id="conversationManageTab">
            <!-- Breadcrumb -->
            <nav class="mb-3" aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a href="#" id="switchBackToConversationsListTab">Conversations</a></li>
                    <li class="breadcrumb-item">
                        <span id="currentConversationTypeName">Inbound Call</span>
                    </li>
                    <li class="breadcrumb-item active" aria-current="page"><span id="currentConversationName">Details</span></li>
                </ol>
            </nav>

            <!-- Loading Overlay -->
            <div id="manageViewLoader" class="position-absolute top-0 start-0 w-100 h-100 d-flex justify-content-center align-items-center bg-light bg-opacity-75 d-none" style="z-index: 10;">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading Details...</span>
                </div>
            </div>

            <!-- Tabs Navigation -->
            <ul class="nav mb-3" id="conversationsManage-tab" role="tablist">
                <li class="nav-item me-2" role="presentation">
                    <button class="nav-link active" id="conversationsManage-general-tab" data-bs-toggle="pill" data-bs-target="#conversationsManage-general" type="button" role="tab" aria-controls="conversationsManage-general" aria-selected="true">General</button>
                </li>
                <li class="nav-item me-2 d-none" role="presentation" id="conversationsManage-metrics-tab-item">
                    <button class="nav-link" id="conversationsManage-metrics-tab" data-bs-toggle="pill" data-bs-target="#conversationsManage-metrics" type="button" role="tab" aria-controls="conversationsManage-metrics" aria-selected="false">Metrics</button>
                </li>
                <li class="nav-item me-2" role="presentation">
                    <button class="nav-link" id="conversationsManage-conversation-tab" data-bs-toggle="pill" data-bs-target="#conversationsManage-conversation" type="button" role="tab" aria-controls="conversationsManage-conversation" aria-selected="false">Conversation</button>
                </li>
                <li class="nav-item me-2" role="presentation">
                    <button class="nav-link" id="conversationsManage-logs-tab" data-bs-toggle="pill" data-bs-target="#conversationsManage-logs" type="button" role="tab" aria-controls="conversationsManage-logs" aria-selected="false">Logs</button>
                </li>
            </ul>

            <!-- Tab Content -->
            <div class="tab-content w-100" id="conversationsManage-tabContent">
                <!-- General Tab -->
                <div class="tab-pane fade show active w-100" id="conversationsManage-general" role="tabpanel" aria-labelledby="conversationsManage-general-tab" tabindex="0">
                    <div class="mb-3">
                        <label class="form-label" for="manageViewQueueId">Queue ID</label>
                        <input type="text" class="form-control" id="manageViewQueueId" readonly>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Queue Status</label>
                        <div id="manageViewQueueStatus" class="mt-1">N/A</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="manageViewEnqueuedAt">Queued At</label>
                        <input type="text" class="form-control" id="manageViewEnqueuedAt" readonly>
                    </div>
                    <div class="mb-3" id="manageViewRoutingContainer">
                        <label class="form-label" for="manageViewRouting">Routing</label>
                        <input type="text" class="form-control" id="manageViewRouting" readonly>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="manageViewFromNumber">From Number</label>
                        <input type="text" class="form-control" id="manageViewFromNumber" readonly>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="manageViewToNumber">To Number</label>
                        <input type="text" class="form-control" id="manageViewToNumber" readonly>
                    </div>
                    <hr>
                    <div class="mb-3">
                        <label class="form-label" for="manageViewSessionId">Session ID</label>
                        <input type="text" class="form-control" id="manageViewSessionId" readonly>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Session Status</label>
                        <div id="manageViewSessionStatus" class="mt-1">N/A</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="manageViewStartTime">Session Start Time</label>
                        <input type="text" class="form-control" id="manageViewStartTime" readonly>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="manageViewEndTime">Session End Time</label>
                        <input type="text" class="form-control" id="manageViewEndTime" readonly>
                    </div>
                </div>

                <!-- Metrics Tab -->
                <div class="tab-pane fade w-100 d-none" id="conversationsManage-metrics" role="tabpanel" aria-labelledby="conversationsManage-metrics-tab" tabindex="0">
                    <div class="mb-3">
                        <label class="form-label" for="metricDurationSeconds">Duration (Seconds)</label>
                        <input type="text" class="form-control" id="metricDurationSeconds" readonly>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="metricClientMessageCount">Client Message Count</label>
                        <input type="text" class="form-control" id="metricClientMessageCount" readonly>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="metricAgentMessageCount">Agent Message Count</label>
                        <input type="text" class="form-control" id="metricAgentMessageCount" readonly>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="metricAverageAgentResponseTimeMs">Avg. Agent Response (ms)</label>
                        <input type="text" class="form-control" id="metricAverageAgentResponseTimeMs" readonly>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="metricClientWordCount">Client Word Count</label>
                        <input type="text" class="form-control" id="metricClientWordCount" readonly>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="metricAgentWordCount">Agent Word Count</label>
                        <input type="text" class="form-control" id="metricAgentWordCount" readonly>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="metricClientInterruptionCount">Client Interruptions</label>
                        <input type="text" class="form-control" id="metricClientInterruptionCount" readonly>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="metricAgentInterruptionCount">Agent Interruptions</label>
                        <input type="text" class="form-control" id="metricAgentInterruptionCount" readonly>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="metricSilenceCount">Silence Count</label>
                        <input type="text" class="form-control" id="metricSilenceCount" readonly>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="metricTotalSilenceDurationSeconds">Total Silence (Seconds)</label>
                        <input type="text" class="form-control" id="metricTotalSilenceDurationSeconds" readonly>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="metricSttAverageLatencyMs">Avg. STT Latency (ms)</label>
                        <input type="text" class="form-control" id="metricSttAverageLatencyMs" readonly>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="metricLlmAverageLatencyMs">Avg. LLM Latency (ms)</label>
                        <input type="text" class="form-control" id="metricLlmAverageLatencyMs" readonly>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="metricTtsAverageLatencyMs">Avg. TTS Latency (ms)</label>
                        <input type="text" class="form-control" id="metricTtsAverageLatencyMs" readonly>
                    </div>
                    <div id="metricAdditionalMetricsContainer"></div>
                </div>

                <!-- Conversation Tab -->
                <div class="tab-pane fade w-100" id="conversationsManage-conversation" role="tabpanel" aria-labelledby="conversationsManage-conversation-tab" tabindex="0">
                    <div class="conversation-recording mb-4">
                        <div id="agentAudioContainer" class="mb-2 d-none">
                            <h5>Agent Audio</h5>
                            <div class="recording-container agent-recording">
                                <i class="typeofconvo fa-regular fa-headset"></i>
                                <div class="recording-container-waveform" id="waveform-agent-audio">
                                    <div class="audio-loader position-absolute top-50 start-50 translate-middle d-none">
                                        <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                                    </div>
                                </div>
                                <div class="audio-controller">
                                    <button class="btn btn-sm btn-light me-2 agent-audio-play" disabled><i class="fa-regular fa-play"></i></button>
                                    <button class="btn btn-sm btn-light agent-audio-download" disabled><i class="fa-regular fa-circle-down"></i></button>
                                </div>
                            </div>
                            <div class="text-danger small mt-1 agent-audio-error d-none">Failed to load audio.</div>
                        </div>
                        <div id="clientAudioContainer" class="mb-2 d-none">
                            <h5>Client Audio</h5>
                            <div class="recording-container client-recording">
                                <i class="typeofconvo fa-regular fa-user"></i>
                                <div class="recording-container-waveform" id="waveform-client-audio">
                                    <div class="audio-loader position-absolute top-50 start-50 translate-middle d-none">
                                        <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                                    </div>
                                </div>
                                <div class="audio-controller">
                                    <button class="btn btn-sm btn-light me-2 client-audio-play" disabled><i class="fa-regular fa-play"></i></button>
                                    <button class="btn btn-sm btn-light client-audio-download" disabled><i class="fa-regular fa-circle-down"></i></button>
                                </div>
                            </div>
                            <div class="text-danger small mt-1 client-audio-error d-none">Failed to load audio.</div>
                        </div>
                    </div>
                    <div class="conversation-messages">
                        <div class="text-center p-3 text-muted messages-placeholder">No messages found or session not loaded.</div>
                    </div>
                </div>

                <!-- Logs Tab -->
                <div class="tab-pane fade w-100" id="conversationsManage-logs" role="tabpanel" aria-labelledby="conversationsManage-logs-tab" tabindex="0">
                    <div class="logs-container">
                        <h5 class="mb-2">Queue Logs</h5>
                        <div class="log-box mb-4 p-3 border rounded bg-dark" id="queueLogsContainer" style="max-height: 300px; overflow-y: auto;">
                            <div class="text-muted">No queue logs found.</div>
                        </div>
                        <h5 class="mb-2">Session Logs</h5>
                        <div class="log-box p-3 border rounded bg-dark" id="sessionLogsContainer" style="max-height: 300px; overflow-y: auto;">
                            <div class="text-muted">No session logs found or session not loaded.</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>