<div class="main-container fade w-100 d-none" id="settings-tab">
    <h3 class="fw-bold tab-title mb-3"><i class='fa-regular fa-gear nav_icon'></i> <span>Settings</span></h3>
    <div class="inner-header-container mb-3">
        <!-- Tabs Buttons -->
        <div class="d-flex flex-row align-items-center justify-content-between fade show w-100" id="settings-inner-tab-container">
            <ul class="nav" id="settings-inner-tab" role="tablist">
                <li class="nav-item me-2" role="presentation">
                    <button class="nav-link active" id="settings-inner-general-tab" data-bs-toggle="pill" data-bs-target="#settings-inner-general" type="button" role="tab" aria-controls="settings-inner-general" aria-selected="true">General</button>
                </li>
                <li class="nav-item me-2" role="presentation">
                    <button class="nav-link" id="settings-inner-languages-tab" data-bs-toggle="pill" data-bs-target="#settings-inner-languages" type="button" role="tab" aria-controls="settings-inner-languages" aria-selected="true">Languages</button>
                </li>
                <li class="nav-item me-2" role="presentation">
                    <button class="nav-link disabled" id="settings-inner-domains-tab" data-bs-toggle="pill" data-bs-target="#settings-inner-domains" type="button" role="tab" aria-controls="settings-inner-domains" aria-selected="true">Domains</button>
                </li>
                <li class="nav-item me-2" role="presentation">
                    <button class="nav-link disabled" id="settings-inner-users-tab" data-bs-toggle="pill" data-bs-target="#settings-inner-users" type="button" role="tab" aria-controls="settings-inner-users" aria-selected="true">Users</button>
                </li>
            </ul>
            <button class="btn btn-primary btn-ic-span-align" id="settingsSaveButton" disabled>
                <i class="fa-regular fa-floppy-disk"></i>
                <span> Save</span>
                <div class="spinner-border save-button-spinner d-none" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </button>
        </div>
        <!-- Manage Subuser Tab -->
        <div class="fade d-none w-100" id="settings-manage-subusers-breadcrumb">
            <div class="d-flex flex-row align-items-center justify-content-between">
                <div>
                    <nav aria-label="breadcrumb" class="mb-3">
                        <ol class="breadcrumb mb-0">
                            <li class="breadcrumb-item"><a href="#" id="switchBackToBusinessSubusersTab">Subusers</a></li>
                            <li class="breadcrumb-item active" aria-current="page"><span id="currentBusinessSubuserName">Subuser</span></li>
                        </ol>
                    </nav>
                    <ul class="nav" id="business-subuser-manager-tab" role="tablist">
                        <li class="nav-item me-2" role="presentation">
                            <button class="nav-link active" id="business-subuser-manager-general-tab" data-bs-toggle="pill" data-bs-target="#business-subuser-manager-general" type="button" role="tab" aria-controls="business-subuser-manager-general" aria-selected="true">General</button>
                        </li>
                        <li class="nav-item me-2" role="presentation">
                            <button class="nav-link" id="business-subuser-manager-permissions-tab" data-bs-toggle="pill" data-bs-target="#business-subuser-manager-permissions" type="button" role="tab" aria-controls="business-subuser-manager-permissions" aria-selected="false">Permissions</button>
                        </li>
                        <li class="nav-item me-2" role="presentation">
                            <button class="nav-link" id="business-subuser-manager-white-label-tab" data-bs-toggle="pill" data-bs-target="#business-subuser-manager-white-label" type="button" role="tab" aria-controls="business-subuser-manager-white-label" aria-selected="false">White Label</button>
                        </li>
                    </ul>
                </div>
                <button class="btn btn-primary btn-ic-span-align" id="saveBusinessSubuserButton" disabled>
                    <i class='fa-regular fa-floppy-disk'></i>
                    <span> Save</span>
                    <div class="spinner-border save-button-spinner d-none" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </button>
            </div>
        </div>
        <!-- Manage Domain Tab -->
        <div class="fade d-none w-100" id="settings-manage-domains-breadcrumb">
            <div class="d-flex flex-row align-items-center justify-content-between">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-0">
                        <li class="breadcrumb-item"><a href="#" id="switchBackToBusinessDomainsTab">Domains</a></li>
                        <li class="breadcrumb-item active" aria-current="page"><span id="currentBusinessDomainName">Domain</span></li>
                    </ol>
                </nav>
                <button class="btn btn-primary btn-ic-span-align" id="saveBusinessDomainButton" disabled>
                    <i class='fa-regular fa-floppy-disk'></i>
                    <span> Save</span>
                    <div class="spinner-border save-button-spinner d-none" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </button>
            </div>
        </div>
    </div>
    <div class="inner-container" has-header="true">
        <!-- Tabs Content -->
        <div class="tab-content w-100" id="settings-inner-tabContent">
            <!-- General -->
            <div class="tab-pane fade w-100 show active" id="settings-inner-general" role="tabpanel" aria-labelledby="settings-inner-general-tab" tabindex="0">
                <div class="mb-3">
                    <label class="form-label" for="settingsGeneralBusinessName">Business Name</label>
                    <input type="text" class="form-control" id="settingsGeneralBusinessName" placeholder="Business Name">
                </div>
                <div class="mb-3">
                    <label class="form-label d-block" for="settingsGeneralBusinessLogo">Business Logo</label>
                    <img src="~/img/logo/Badal-Logo-Light.png" class="img-fluid rounded-3" alt="Business Logo" id="settingsGeneralBusinessLogoPreview">
                    <input type="file" class="form-control d-none" id="settingsGeneralBusinessLogo" accept="image/png, image/jpeg, image/webp, image/gif">
                </div>
            </div>
            <!-- Languages -->
            <div class="tab-pane fade w-100" id="settings-inner-languages" role="tabpanel" aria-labelledby="settings-inner-languages-tab" tabindex="0">
                <div class="mb-3">
                    <label class="form-label" for="settingsLanguageAddSelect">Added Languages</label>
                    <div class="input-group">
                        <select class="form-select" id="settingsLanguageAddSelect">
                            <option value="none" selected disabled>Select Language</option>
                        </select>
                        <button class="btn btn-light" type="button" id="settingsLanguageAddButton" disabled>Add</button>
                    </div>
                </div>
                <table id="settingsAddedLanguagesList" class="table w-100">
                    <thead>
                        <tr>
                            <th scope="col">Code</th>
                            <th scope="col">Language</th>
                            <th scope="col">Is Default?</th>
                            <th scope="col">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- Dynamically Generated -->
                    </tbody>
                </table>
            </div>
            <!-- Domains -->
            <div class="tab-pane fade w-100" id="settings-inner-domains" role="tabpanel" aria-labelledby="settings-inner-domains-tab" tabindex="0">
                <!-- Domains List Tab -->
                <div class="fade w-100 show" id="businessDomainsListTab">
                    <div class="mb-4 d-flex flex-row align-items-center justify-content-between">
                        <div style="min-width: 200px" class="me-4">
                            <button class="w-100 mb-0 text-decoration-none fw-bold btn btn-primary" id="addNewBusinessDomainButton">
                                <span>+ Add New Domain</span>
                            </button>
                        </div>
                        <div class="input-group w-100">
                            <input type="text" class="form-control" placeholder="Domain" aria-label="Domain" aria-describedby="searchBusinessDomainButton">
                            <button class="input-group-button btn btn-primary" id="searchBusinessDomainButton">
                                <i class='fa-regular fa-magnifying-glass'></i>
                            </button>
                        </div>
                    </div>
                    <table id="businessDomainsTable" class="table w-100">
                        <thead>
                            <tr>
                                <th scope="col">Domain</th>
                                <th scope="col">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <!-- Business Domains will be dynamically added here -->
                        </tbody>
                    </table>
                </div>

                <!-- Domains Manager Tab -->
                <div class="fade w-100 d-none" id="businessDomainsManagerTab">
                    <div class="mb-3">
                        <label for="business-domains-domain-type" class="form-label">Domain Type</label>
                        <select class="form-select" id="business-domains-domain-type">
                            <option value="Unknown" selected disabled>Select Domain Type</option>
                            <option value="IqraSubdomain">Iqra Subdomain</option>
                            <option value="CustomDomain">Custom Domain</option>
                        </select>
                    </div>

                    <!-- Iqra Subdomain Container -->
                    <div id="business-domains-iqra-subdomain-container" class="mb-4 d-none">
                        <div class="mb-3">
                            <label for="business-domains-iqra-subdomain" class="form-label">Subdomain Name</label>
                            <div class="input-group">
                                <input type="text" class="form-control" id="business-domains-iqra-subdomain" placeholder="Enter subdomain name">
                                <span class="input-group-text">.domain</span>
                            </div>
                        </div>
                    </div>

                    <!-- Custom Domain Container -->
                    <div id="business-domains-custom-domain-container" class="mb-4 d-none">
                        <div class="mb-3">
                            <label for="business-domains-custom-domain" class="form-label">Custom Domain</label>
                            <input type="text" class="form-control" id="business-domains-custom-domain" placeholder="Enter custom domain">
                        </div>
                        <div id="business-domains-ssl-config" class="mb-3">
                            <div class="">
                                <label class="form-label" for="business-domains-ssl-enabled">SSL Type</label>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="businessDomainSSLType" id="businessDomainSSLTypeFree" ssl-type="free" checked>
                                    <label class="form-check-label" for="businessDomainSSLTypeFree">
                                        Free by IqraAI
                                    </label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="businessDomainSSLType" id="businessDomainSSLTypeCustom" ssl-type="custom">
                                    <label class="form-check-label" for="businessDomainSSLTypeCustom">
                                        Custom SSL
                                    </label>
                                </div>
                            </div>

                            <div id="business-domain-ssl-type-custom" class="d-none mt-3">
                                <div class="mb-2">
                                    <label for="business-domains-ssl-private-key" class="form-label">Private Key</label>
                                    <textarea class="form-control" id="business-domains-ssl-private-key" rows="3" placeholder="Enter SSL private key"></textarea>
                                </div>
                                <div>
                                    <label for="business-domains-ssl-certificate" class="form-label">Certificate</label>
                                    <textarea class="form-control" id="business-domains-ssl-certificate" rows="3" placeholder="Enter SSL certificate"></textarea>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Users -->
            <div class="tab-pane fade w-100" id="settings-inner-users" role="tabpanel" aria-labelledby="settings-inner-users-tab" tabindex="0">
                <!-- Business Subusers List Tab -->
                <div class="fade w-100 show" id="businessSubusersListTab">
                    <div class="mb-4 d-flex flex-row align-items-center justify-content-between">
                        <div style="min-width: 200px" class="me-4">
                            <button class="w-100 mb-0 text-decoration-none fw-bold btn btn-primary" id="addNewBusinessSubuserButton">
                                <span>+ Add New Subuser</span>
                            </button>
                        </div>
                        <div class="input-group w-100">
                            <input type="text" class="form-control" placeholder="Subuser Email" aria-label="Subuser Email" aria-describedby="searchBusinessSubuserButton">
                            <button class="input-group-button btn btn-primary" id="searchBusinessSubuserButton">
                                <i class='fa-regular fa-magnifying-glass'></i>
                            </button>
                        </div>
                    </div>
                    <table id="businessSubusersTable" class="table w-100">
                        <thead>
                            <tr>
                                <th scope="col">Email</th>
                                <th scope="col">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <!-- Business Subusers will be dynamically added here -->
                        </tbody>
                    </table>
                </div>

                <!-- Users Manager Tab -->
                <div class="fade w-100 d-none" id="subusersManagerTab">
                    <div class="tab-content w-100" id="business-subuser-manager-tabContent">
                        <!-- General Tab -->
                        <div class="tab-pane fade show active w-100" id="business-subuser-manager-general" role="tabpanel" aria-labelledby="business-subuser-manager-general-tab" tabindex="0">
                            <div class="mb-3">
                                <label for="businessSubuserEmail" class="form-label">Email</label>
                                <input type="email" class="form-control" id="businessSubuserEmail" placeholder="Subuser Email">
                            </div>
                            <div class="mb-3">
                                <label for="businessSubuserPassword" class="form-label">Password</label>
                                <input type="password" class="form-control" id="businessSubuserPassword" placeholder="Subuser Password">
                                <div class="form-text">Password must be at least 8 characters long.</div>
                            </div>
                            <div>
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="businessSubuserLoginDisabledInput" check-type="permission-with-reason">
                                    <label class="form-label d-block" for="businessSubuserLoginDisabledInput">Login Disabled</label>
                                </div>
                                <input type="text" class="form-control d-none" id="businessSubuserLoginDisabledReasonInput" placeholder="Subuser Disabled Login Reason">
                            </div>
                        </div>

                        <!-- Permissions Tab -->
                        <div class="tab-pane fade w-100" id="business-subuser-manager-permissions" role="tabpanel" aria-labelledby="business-subuser-manager-permissions-tab" tabindex="0">
                            <ul class="nav mb-3" id="business-subuser-permissions-tab" role="tablist">
                                <li class="nav-item me-2" role="presentation">
                                    <button class="nav-link active" id="business-subuser-permissions-routing-tab" data-bs-toggle="pill" data-bs-target="#business-subuser-permissions-routing" type="button" role="tab" aria-controls="business-subuser-permissions-routing" aria-selected="true">Routing</button>
                                </li>
                                <li class="nav-item me-2" role="presentation">
                                    <button class="nav-link" id="business-subuser-permissions-tools-tab" data-bs-toggle="pill" data-bs-target="#business-subuser-permissions-tools" type="button" role="tab" aria-controls="business-subuser-permissions-tools" aria-selected="false">Tools</button>
                                </li>
                                <li class="nav-item me-2" role="presentation">
                                    <button class="nav-link" id="business-subuser-permissions-agents-tab" data-bs-toggle="pill" data-bs-target="#business-subuser-permissions-agents" type="button" role="tab" aria-controls="business-subuser-permissions-agents" aria-selected="false">Agents</button>
                                </li>
                                <li class="nav-item me-2" role="presentation">
                                    <button class="nav-link" id="business-subuser-permissions-context-tab" data-bs-toggle="pill" data-bs-target="#business-subuser-permissions-context" type="button" role="tab" aria-controls="business-subuser-permissions-context" aria-selected="false">Context</button>
                                </li>
                                <li class="nav-item me-2" role="presentation">
                                    <button class="nav-link" id="business-subuser-permissions-make-calls-tab" data-bs-toggle="pill" data-bs-target="#business-subuser-permissions-make-calls" type="button" role="tab" aria-controls="business-subuser-permissions-make-calls" aria-selected="false">Make Calls</button>
                                </li>
                                <li class="nav-item me-2" role="presentation">
                                    <button class="nav-link" id="business-subuser-permissions-conversations-tab" data-bs-toggle="pill" data-bs-target="#business-subuser-permissions-conversations" type="button" role="tab" aria-controls="business-subuser-permissions-conversations" aria-selected="false">Conversations</button>
                                </li>
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link" id="business-subuser-permissions-settings-tab" data-bs-toggle="pill" data-bs-target="#business-subuser-permissions-settings" type="button" role="tab" aria-controls="business-subuser-permissions-settings" aria-selected="false">Settings</button>
                                </li>
                            </ul>

                            <div class="tab-content" id="business-subuser-permissions-tabContent">
                                <!-- Routing Permissions -->
                                <div class="tab-pane fade show active" id="business-subuser-permissions-routing" role="tabpanel" aria-labelledby="business-subuser-permissions-routing-tab" tabindex="0">
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="business-subuser-routing-tab-enabled">
                                        <label class="form-check-label" for="business-subuser-routing-tab-enabled">Routing Tab Enabled</label>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="business-subuser-routing-add-new-route" disabled>
                                        <label class="form-check-label" for="business-subuser-routing-add-new-route">Add New Route</label>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="business-subuser-routing-edit-route" disabled>
                                        <label class="form-check-label" for="business-subuser-routing-edit-route">Edit Route</label>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="business-subuser-routing-delete-route" disabled>
                                        <label class="form-check-label" for="business-subuser-routing-delete-route">Delete Route</label>
                                    </div>
                                </div>

                                <!-- Tools Permissions -->
                                <div class="tab-pane fade" id="business-subuser-permissions-tools" role="tabpanel" aria-labelledby="business-subuser-permissions-tools-tab" tabindex="0">
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="business-subuser-tools-tab-enabled">
                                        <label class="form-check-label" for="business-subuser-tools-tab-enabled">Tools Tab Enabled</label>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="business-subuser-tools-add-new-tool" disabled>
                                        <label class="form-check-label" for="business-subuser-tools-add-new-tool">Add New Tool</label>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="business-subuser-tools-edit-tool" disabled>
                                        <label class="form-check-label" for="business-subuser-tools-edit-tool">Edit Tool</label>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="business-subuser-tools-delete-tool" disabled>
                                        <label class="form-check-label" for="business-subuser-tools-delete-tool">Delete Tool</label>
                                    </div>
                                </div>

                                <!-- Agents Permissions -->
                                <div class="tab-pane fade" id="business-subuser-permissions-agents" role="tabpanel" aria-labelledby="business-subuser-permissions-agents-tab" tabindex="0">
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="business-subuser-agents-tab-enabled">
                                        <label class="form-check-label" for="business-subuser-agents-tab-enabled">Agents Tab Enabled</label>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="business-subuser-agents-add-new-agent" disabled>
                                        <label class="form-check-label" for="business-subuser-agents-add-new-agent">Add New Agent</label>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="business-subuser-agents-edit-agent" disabled>
                                        <label class="form-check-label" for="business-subuser-agents-edit-agent">Edit Agent</label>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="business-subuser-agents-delete-agent" disabled>
                                        <label class="form-check-label" for="business-subuser-agents-delete-agent">Delete Agent</label>
                                    </div>
                                </div>

                                <!-- Context Permissions -->
                                <div class="tab-pane fade" id="business-subuser-permissions-context" role="tabpanel" aria-labelledby="business-subuser-permissions-context-tab" tabindex="0">
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="business-subuser-context-tab-enabled">
                                        <label class="form-check-label" for="business-subuser-context-tab-enabled">Context Tab Enabled</label>
                                    </div>

                                    <h6 class="mt-3">Branding</h6>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="business-subuser-context-branding-tab-enabled" disabled>
                                        <label class="form-check-label" for="business-subuser-context-branding-tab-enabled">Branding Tab Enabled</label>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="business-subuser-context-edit-branding" disabled>
                                        <label class="form-check-label" for="business-subuser-context-edit-branding">Edit Branding</label>
                                    </div>

                                    <h6 class="mt-3">Branches</h6>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="business-subuser-context-branches-tab-enabled" disabled>
                                        <label class="form-check-label" for="business-subuser-context-branches-tab-enabled">Branches Tab Enabled</label>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="business-subuser-context-edit-branches" disabled>
                                        <label class="form-check-label" for="business-subuser-context-edit-branches">Edit Branches</label>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="business-subuser-context-add-branches" disabled>
                                        <label class="form-check-label" for="business-subuser-context-add-branches">Add Branches</label>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="business-subuser-context-delete-branches" disabled>
                                        <label class="form-check-label" for="business-subuser-context-delete-branches">Delete Branches</label>
                                    </div>

                                    <h6 class="mt-3">Services</h6>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="business-subuser-context-services-tab-enabled" disabled>
                                        <label class="form-check-label" for="business-subuser-context-services-tab-enabled">Services Tab Enabled</label>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="business-subuser-context-edit-services" disabled>
                                        <label class="form-check-label" for="business-subuser-context-edit-services">Edit Services</label>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="business-subuser-context-add-services" disabled>
                                        <label class="form-check-label" for="business-subuser-context-add-services">Add Services</label>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="business-subuser-context-delete-services" disabled>
                                        <label class="form-check-label" for="business-subuser-context-delete-services">Delete Services</label>
                                    </div>

                                    <h6 class="mt-3">Products</h6>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="business-subuser-context-products-tab-enabled" disabled>
                                        <label class="form-check-label" for="business-subuser-context-products-tab-enabled">Products Tab Enabled</label>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="business-subuser-context-edit-products" disabled>
                                        <label class="form-check-label" for="business-subuser-context-edit-products">Edit Products</label>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="business-subuser-context-add-products" disabled>
                                        <label class="form-check-label" for="business-subuser-context-add-products">Add Products</label>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="business-subuser-context-delete-products" disabled>
                                        <label class="form-check-label" for="business-subuser-context-delete-products">Delete Products</label>
                                    </div>
