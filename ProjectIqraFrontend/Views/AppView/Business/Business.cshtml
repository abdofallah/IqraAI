    <!-- Main Init Script -->
    <script>
        $(window).on('load', () => {

            if (!CurrentBusinessId || CurrentBusinessId == null)
            {
                AlertManager.createAlert({
                    type: 'danger',
                    message: 'Business ID not found in the URL path.',
                    enableDismiss: false
                });

                return;
            }

            function initalizeBusinessDashboard(){
                FetchSpecificationLanguagesDataFromAPI(
                    (langaugesListData) => {
                        SpecificationLanguagesListData = langaugesListData;

                        FetchSpecificationRegionsDataFromAPI(
                            (regionsListData) => {
                                SpecificationRegionsListData = regionsListData;

                                FetchSpecificationFlowAppsFromAPI(
                                    (flowAppsListData) => {
                                        SpecificationFlowAppsListData = flowAppsListData;

                                        FetchSpecificationIntegrationsDataFromAPI(
                                            (integrationsListData) => {
                                                SpecificationIntegrationsListData = integrationsListData;

                                                const temporaryLLMProvidersForIntegrations = [];
                                                const temporarySTTProvidersForIntegrations = [];
                                                const temporaryTTSProvidersForIntegrations = [];
                                                const temporaryEmbeddingProvidersForIntegrations = [];
                                                const temporaryRerankProvidersForIntegrations = [];
                                                let LLMProviderFail = false;
                                                let STTProviderFail = false;
                                                let TTSProviderFail = false;
                                                let EmbeddingProviderFail = false;
                                                let RerankProviderFail = false;

                                                SpecificationIntegrationsListData.forEach((integration) => {
                                                    if (integration.type.includes("LLM")) {
                                                        FetchSpecificationLLMProviderDataByIntegrationTypeFromAPI(
                                                            integration.id,
                                                            (LLMProviderResult) => {
                                                                temporaryLLMProvidersForIntegrations.push(LLMProviderResult);
                                                            },
                                                            (LLMProviderError) => {
                                                                AlertManager.createAlert({
                                                                    type: 'danger',
                                                                    message: 'Error occured while fetching LLM Provider data for integration with id ' + integration.id + '. Check browser console for logs.',
                                                                    enableDismiss: false
                                                                });

                                                                console.log('Error occured while fetching LLM Provider data for integration with id ' + integration.id + ': ', LLMProviderError);

                                                                LLMProviderFail = true;
                                                            }
                                                        );
                                                    }

                                                    if (integration.type.includes("STT") || integration.type.includes("SPEECH2TEXT")) {
                                                        FetchSpecificationSTTProviderDataByIntegrationTypeFromAPI(
                                                            integration.id,
                                                            (STTProviderResult) => {
                                                                temporarySTTProvidersForIntegrations.push(STTProviderResult);
                                                            },
                                                            (STTProviderError) => {
                                                                AlertManager.createAlert({
                                                                    type: 'danger',
                                                                    message: 'Error occured while fetching STT Provider data for integration with id ' + integration.id + '. Check browser console for logs.',
                                                                    enableDismiss: false
                                                                });

                                                                console.log('Error occured while fetching STT Provider data for integration with id ' + integration.id + ': ', STTProviderError);

                                                                STTProviderFail = true;
                                                            }
                                                        );
                                                    }

                                                    if (integration.type.includes("TTS") || integration.type.includes("TEXT2SPEECH")) {
                                                        FetchSpecificationTTSProviderDataByIntegrationTypeFromAPI(
                                                            integration.id,
                                                            (TTSProviderResult) => {
                                                                temporaryTTSProvidersForIntegrations.push(TTSProviderResult);
                                                            },
                                                            (TTSProviderError) => {
                                                                AlertManager.createAlert({
                                                                    type: 'danger',
                                                                    message: 'Error occured while fetching TTS Provider data for integration with id ' + integration.id + '. Check browser console for logs.',
                                                                    enableDismiss: false
                                                                });

                                                                console.log('Error occured while fetching TTS Provider data for integration with id ' + integration.id + ': ', TTSProviderError);

                                                                TTSProviderFail = true;
                                                            }
                                                        );
                                                    }

                                                    if (integration.type.includes("Embedding"))
                                                    {
                                                        FetchSpecificationEmbeddingProviderDataByIntegrationTypeFromAPI(
                                                            integration.id,
                                                            (EmbeddingProviderResult) => {
                                                                temporaryEmbeddingProvidersForIntegrations.push(EmbeddingProviderResult);
                                                            },
                                                            (EmbeddingProviderError) => {
                                                                AlertManager.createAlert({
                                                                    type: 'danger',
                                                                    message: 'Error occured while fetching Embedding Provider data for integration with id ' + integration.id + '. Check browser console for logs.',
                                                                    enableDismiss: false
                                                                });

                                                                console.log('Error occured while fetching Embedding Provider data for integration with id ' + integration.id + ': ', EmbeddingProviderError);

                                                                EmbeddingProviderFail = true;
                                                            }
                                                        );
                                                    }

                                                    if (integration.type.includes("Rerank"))
                                                    {
                                                        FetchSpecificationRerankProviderDataByIntegrationTypeFromAPI(
                                                            integration.id,
                                                            (RerankProviderResult) => {
                                                                temporaryRerankProvidersForIntegrations.push(RerankProviderResult);
                                                            },
                                                            (RerankProviderError) => {
                                                                AlertManager.createAlert({
                                                                    type: 'danger',
                                                                    message: 'Error occured while fetching Rerank Provider data for integration with id ' + integration.id + '. Check browser console for logs.',
                                                                    enableDismiss: false
                                                                });

                                                                console.log('Error occured while fetching Rerank Provider data for integration with id ' + integration.id + ': ', RerankProviderError);

                                                                RerankProviderFail = true;
                                                            }
                                                        );
                                                    }
                                                });

                                                if (!LLMProviderFail) {
                                                    BusinessLLMProvidersForIntegrations = temporaryLLMProvidersForIntegrations;
                                                }

                                                if (!STTProviderFail) {
                                                    BusinessSTTProvidersForIntegrations = temporarySTTProvidersForIntegrations;
                                                }

                                                if (!TTSProviderFail) {
                                                    BusinessTTSProvidersForIntegrations = temporaryTTSProvidersForIntegrations;
                                                }

                                                if (!EmbeddingProviderFail)
                                                {
                                                    BusinessEmbeddingProvidersForIntegrations = temporaryEmbeddingProvidersForIntegrations;
                                                }

                                                if (!RerankProviderFail)
                                                {
                                                    BusinessRerankProvidersForIntegrations = temporaryRerankProvidersForIntegrations;
                                                }

                                                if (!LLMProviderFail && !STTProviderFail && !TTSProviderFail && !EmbeddingProviderFail && !RerankProviderFail) {
                                                    FetchBusinessDataFromAPI(CurrentBusinessId,
                                                        (businessData) => {
                                                            BusinessFullData = businessData;

                                                            BusinessFullLanguagesData = [];
                                                            BusinessFullData.businessData.languages.forEach((value, index) => {
                                                                const countryCodeLanguage = SpecificationLanguagesListData.find((data, index) => {
                                                                    return data.id === value;
                                                                });

                                                                if (countryCodeLanguage) {
                                                                    BusinessFullLanguagesData.push(countryCodeLanguage);
                                                                }
                                                            });
                                                            BusinessDefaultLanguage = BusinessFullData.businessData.defaultLanguage;

                                                            initSettingsTab();
                                                            initToolsTab();
                                                            initContextTab();
                                                            initCacheTab();
                                                            initIntegrationsTab();
                                                            initAgentTab();
                                                            initScriptsTab();
                                                            initRoutingTab();
                                                            initNumbersTab();
                                                            initConversationsTab();
                                                            initTelephonyCampaignsTab();
                                                            initWebCampaignsTab();
                                                            initMakeCallsTab();
                                                            initKnowledgeBaseTab();
                                                            initPostAnalysisTab();

                                                            let businessTutorials = BusinessFullData.businessData.tutorials;
                                                            if (businessTutorials) {
                                                                if (businessTutorials.newBusinessTutorial) {
                                                                    // todo enable again
                                                                    //InitalizeNewBusinessTutorial();
                                                                }
                                                            }

                                                            EverythingInitalized = true;
                                                        },
                                                        (businessDataError) => {
                                                            AlertManager.createAlert({
                                                                type: 'danger',
                                                                message: 'Error occured while fetching business data. Check browser console for logs.',
                                                                enableDismiss: false
                                                            });

                                                            console.log('Error occured while fetching business data: ', businessDataError);
                                                        }
                                                    );
                                                }
                                            },
                                            (integrationsListError) => {
                                                AlertManager.createAlert({
                                                    type: 'danger',
                                                    message: 'Error occured while fetching specification integrations data. Check browser console for logs.',
                                                    enableDismiss: false
                                                });

                                                console.log('Error occured while fetching specification integrations data: ', integrationsListError);
                                            }
                                        );
                                    },
                                    (flowAppsListError) => {
                                        AlertManager.createAlert({
                                            type: 'danger',
                                            message: 'Error occured while fetching specification flow apps data. Check browser console for logs.',
                                            enableDismiss: false
                                        });

                                        console.log('Error occured while fetching specification flow apps data: ', flowAppsListError);
                                    }
                                );
                            },
                            (regionsListError) => {
                                AlertManager.createAlert({
                                    type: 'danger',
                                    message: 'Error occured while fetching specification regions data. Check browser console for logs.',
                                    enableDismiss: false
                                });

                                console.log('Error occured while fetching specification regions data: ', regionsListError);
                            }
                        );

                    },
                    (langaugesListDataError) => {
                        AlertManager.createAlert({
                            type: 'danger',
                            message: 'Error occured while fetching specification languages data. Check browser console for logs.',
                            enableDismiss: false
                        });

                        console.log('Error occured while fetching specification languages data: ', langaugesListDataError);
                    }
                );
            }

            if (IsWhiteLabelCustomer)
            {
                FetchWhiteLabelCustomerFromAPI(
                    (successResponse) => {
                        WhiteLabelCustomer = successResponse;

                        initWhiteLabelBusinessDashboard();
                        initalizeBusinessDashboard();
                    },
                    (errorResponse) => {
                        AlertManager.createAlert({
                            type: 'danger',
                            message: 'Error occured while fetching customer data. Check browser console for logs.',
                            enableDismiss: false
                        });

                        console.log('Error occured while fetching customer data: ', errorResponse);
                    }
                );
            }
            else {
                initalizeBusinessDashboard();
            }
        });
    </script>
</body>

