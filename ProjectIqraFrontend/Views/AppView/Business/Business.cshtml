@using IqraCore.Entities.WhiteLabel
@using IqraInfrastructure.Repositories.Business
@inject WhiteLabelContext Ctx
@inject BusinessLogoRepository LogoRepo
@{
    // Resolve branding information from the context, with fallbacks.
    var platformName = Ctx.RequestContext?.Branding?.PlatformName ?? "Iqra AI";
    var platformLogoS3StorageLink = Ctx.RequestContext?.Branding?.PlatformLogoS3StorageLink;
    var platformIconS3StorageLink = Ctx.RequestContext?.Branding?.PlatformIconS3StorageLink;
    var customCSS = Ctx.RequestContext?.Branding?.PlatformCustomCSS;

    var logoUrl = "/img/logo/logo-colored-light.png";
    if (platformLogoS3StorageLink != null)
    {
        logoUrl = LogoRepo.GeneratePresignedUrl(platformLogoS3StorageLink.ObjectName, 3600, platformLogoS3StorageLink.OriginRegion);
    }
    var iconUrl = "/img/favicon/favicon.ico";
    if (platformIconS3StorageLink != null)
    {
        iconUrl = LogoRepo.GeneratePresignedUrl(platformIconS3StorageLink.ObjectName, 3600, platformIconS3StorageLink.OriginRegion);
    }
}
