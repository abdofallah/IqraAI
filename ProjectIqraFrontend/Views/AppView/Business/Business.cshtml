                url: `/app/specification/embeddingproviders/getbyintegration/${type}`,
                type: 'GET',
                success: (response) => {
                    if (!response.success) {
                        errorCallback(response);
                        return;
                    }

                    successCallback(response.data);
                },
                error: (error) => {
                    errorCallback(error);
                }
            });
        }

        function FetchSpecificationRerankProviderDataByIntegrationTypeFromAPI(type, successCallback, errorCallback) {
            return $.ajax({
                url: `/app/specification/rerankproviders/getbyintegration/${type}`,
                type: 'GET',
                success: (response) => {
                    if (!response.success) {
                        errorCallback(response);
                        return;
                    }

                    successCallback(response.data);
                },
                error: (error) => {
                    errorCallback(error);
                }
            });
        }

        function FetchSpecificationFlowAppsFromAPI(successCallback, errorCallback) {
            return $.ajax({
                url: `/app/specification/flowapps`,
                type: 'GET',
                success: (response) => {
                    if (!response.success) {
