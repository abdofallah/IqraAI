<div class="main-container fade d-none w-100" id="scripts-tab">
    <h3 class="fw-bold tab-title mb-3"><i class='fa-regular fa-scroll'></i> <span>Scripts</span></h3>
    <div class="inner-header-container w-100 mb-3 fade d-none" id="scripts-manager-header">

        <!-- Scripts Manager Breadcrumb -->
        <div class="mb-4 d-flex flex-row align-items-center justify-content-between w-100">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item">
                        <a href="#" id="switchBackToScriptsListTab">Scripts</a>
                    </li>
                    <li class="breadcrumb-item active" aria-current="page"><span id="currentScriptName">Script</span></li>
                </ol>
            </nav>
            <div>
                <div class="btn-group" id="saveScriptDropdown">
                    <button class="btn btn-primary btn-sm btn-ic-span-align" id="saveScriptButton">
                        <i class='fa-regular fa-floppy-disk'></i>
                        <span> Save</span>
                    </button>
                </div>
            </div>
        </div>

        <!-- Scripts Manager Inner Tabs -->
        <div class="d-flex flex-row align-items-center justify-content-between w-100">
            <ul class="nav" role="tablist">
                <li class="nav-item me-2" role="presentation">
                    <button class="nav-link active" id="scripts-manager-general-tab" data-bs-toggle="pill" data-bs-target="#scripts-manager-general" type="button" role="tab" aria-controls="scripts-manager-general" aria-selected="true">General</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="scripts-manager-conversation-tab" data-bs-toggle="pill" data-bs-target="#scripts-manager-conversation" type="button" role="tab" aria-controls="scripts-manager-conversation" aria-selected="true">Conversation</button>
                </li>
            </ul>

            <div class="ms-4" id="scriptsManagerMultiLanguageParentContainer">
                <div id="scriptsManagerMultiLanguageContainer">
                </div>
            </div>
        </div>

    </div>
    <div class="inner-container">
        <!-- Scripts List Tab -->
        <div class="fade show w-100" id="scriptsListTab">
            <div class="mb-4 d-flex flex-row align-items-center justify-content-between">
                <div style="min-width: 200px" class="me-4">
                    <button class="w-100 mb-0 text-decoration-none fw-bold btn btn-primary" id="addNewScriptButton">
                        <span>+ Add New Script</span>
                    </button>
                </div>
                <div class="input-group w-100">
                    <input type="text" class="form-control" placeholder="Script Name" aria-label="Script Name" aria-describedby="searchScriptButton">
                    <button class="input-group-button btn btn-primary" id="searchScriptButton">
                        <i class='fa-regular fa-magnifying-glass'></i>
                    </button>
                </div>
            </div>
            <div class="row" id="scriptsCardListContainer">
                <!-- Scripts will be added here dynamically -->
            </div>
        </div>
        <!-- Scripts Manager Tab -->
        <div class="fade d-none w-100" id="scriptsManagerTab">
            <div class="tab-content w-100" id="scripts-manager-tabContent">
                
                <!-- General -->
                <div class="tab-pane fade show active w-100" id="scripts-manager-general" role="tabpanel" aria-labelledby="scripts-manager-general-tab" tabindex="0">
                    <div class="mb-3">
                        <label class="form-label btn-ic-span-align" for="inputScriptName"><span>Name</span> <i class="fa-regular fa-language"></i></label>
                        <input type="text" class="form-control" id="inputScriptName" placeholder="Script Name">
                    </div>
                    <div>
                        <label class="form-label btn-ic-span-align" for="inputScriptDescription"><span>Description</span> <i class="fa-regular fa-language"></i></label>
                        <textarea class="form-control" id="inputScriptDescription" rows="1" placeholder="Script Description"></textarea>
                    </div>
                </div>
                <!-- Conversation -->
                <div class="tab-pane fade w-100" id="scripts-manager-conversation" role="tabpanel" aria-labelledby="scripts-manager-conversation-tab" tabindex="0">
                    <!-- Graph Container -->
                    <div class="script-graph-container">
                        <!-- Left Sidebar -->
                        <div class="script-graph-sidebar-left bg-dark border-dark text-bg-dark">
                            <!-- Search Bar -->
                            <div class="sidebar-search-container">
                                <div class="input-group input-group-sm">
                                    <span class="input-group-text bg-transparent border-end-0 text-muted">
                                        <i class="fa-regular fa-magnifying-glass"></i>
                                    </span>
                                    <input type="text" class="form-control border-start-0 ps-0" id="sidebarNodeSearch" placeholder="Search nodes...">
                                </div>
                            </div>

                            <!-- Scrollable Content -->
                            <div class="sidebar-scrollable-content">

                                <!-- Conversation Category -->
                                <div class="sidebar-category">
                                    <div class="sidebar-category-title">Conversation</div>
                                    <div class="sidebar-nodes-grid">
                                        <div class="sidebar-node-item" data-preset-id="user-query">
                                            <i class="fa-regular fa-message"></i>
                                            <span>User Query</span>
                                        </div>
                                        <div class="sidebar-node-item" data-preset-id="ai-response">
                                            <i class="fa-regular fa-robot"></i>
                                            <span>AI Response</span>
                                        </div>
                                        <div class="sidebar-node-item disabled" data-preset-id="keep-listening">
                                            <i class="fa-regular fa-ear"></i>
                                            <span>Keep Listening</span>
                                        </div>
                                    </div>
                                </div>

                                <!-- Action Category -->
                                <div class="sidebar-category category-action-flow">
                                    <div class="sidebar-category-title">Action Flow</div>
                                    <div class="sidebar-nodes-grid">
                                        <div class="sidebar-node-item disabled" data-preset-id="action-flow-group">
                                            <i class="fa-regular fa-gears"></i>
                                            <span>Action Flow Group</span>
                                        </div>
                                        <div class="sidebar-node-item disabled" data-preset-id="action-flow-condition">
                                            <i class="fa-regular fa-filter"></i>
                                            <span>Condition</span>
                                        </div>
                                        <div class="sidebar-node-item disabled" data-preset-id="action-flow-wait">
                                            <i class="fa-regular fa-timer"></i>
                                            <span>Wait</span>
                                        </div>
                                        <div class="sidebar-node-item disabled" data-preset-id="action-flow-go-to-action">
                                            <i class="fa-regular fa-arrow-right"></i>
                                            <span>Go To Action</span>
                                        </div>
                                        <div class="sidebar-node-item disabled" data-preset-id="action-flow-return">
                                            <i class="fa-regular fa-flag-checkered"></i>
                                            <span>Return</span>
                                        </div>
                                    </div>
                                </div>

                                <!-- Logic Category -->
                                <div class="sidebar-category category-logic">
                                    <div class="sidebar-category-title">Logic</div>
                                    <div class="sidebar-nodes-grid">
                                        <div class="sidebar-node-item" data-preset-id="go-to-node">
                                            <i class="fa-regular fa-arrow-turn-down-right"></i>
                                            <span>Continue From Node</span>
                                        </div>
                                        <div class="sidebar-node-item" data-preset-id="end-call">
                                            <i class="fa-regular fa-phone-slash"></i>
                                            <span>End Conversation</span>
                                        </div>
                                        <div class="sidebar-node-item disabled" data-preset-id="transfer-agent">
                                            <i class="fa-regular fa-headset"></i>
                                            <span>Transfer To Agent</span>
                                        </div>
                                        <div class="sidebar-node-item disabled" data-preset-id="transfer-human">
                                            <i class="fa-regular fa-user-headset"></i>
                                            <span>Transfer To Human</span>
                                        </div>
                                        <div class="sidebar-node-item" data-preset-id="get-dtmf">
                                            <i class="fa-regular fa-hashtag"></i>
                                            <span>Get Numerical Input</span>
                                        </div>
                                        <div class="sidebar-node-item disabled" data-preset-id="change-language">
                                            <i class="fa-regular fa-language"></i>
                                            <span>Change Language</span>
                                        </div>
                                        <div class="sidebar-node-item disabled" data-preset-id="add-script-context">
                                            <i class="fa-regular fa-file-circle-plus"></i>
                                            <span>Add Script</span>
                                        </div>
                                        <div class="sidebar-node-item disabled" data-preset-id="schedule-call">
                                            <i class="fa-regular fa-phone-arrow-up-right"></i>
                                            <span>Schedule Call</span>
                                        </div>
                                        <div class="sidebar-node-item disabled" data-preset-id="webhook">
                                            <i class="fa-regular fa-webhook"></i>
                                            <span>Webhook</span>
                                        </div>
                                        <div class="sidebar-node-item disabled" data-preset-id="set-variable">
                                            <i class="fa-regular fa-brackets-curly"></i>
                                            <span>Set Variable</span>
                                        </div>
                                        <div class="sidebar-node-item disabled" data-preset-id="send-event">
                                            <i class="fa-regular fa-command"></i>
                                            <span>Send Event</span>
                                        </div>
                                        <div class="sidebar-node-item disabled" data-preset-id="action-flow-run-code">
                                            <i class="fa-regular fa-code"></i>
                                            <span>Run Code</span>
                                        </div>
                                    </div>
                                </div>

                                <!-- Telephony Category -->
                                <div class="sidebar-category category-telephony">
                                    <div class="sidebar-category-title">Telephony</div>
                                    <div class="sidebar-nodes-grid">
                                        <div class="sidebar-node-item" data-preset-id="press-dtmf">
                                            <i class="fa-regular fa-mobile-button"></i>
                                            <span>Press Keypad</span>
                                        </div>
                                    </div>
                                </div>

                                <!-- Integrations Category -->
                                <div class="sidebar-category category-integrations">
                                    <div class="sidebar-category-title">Integrations</div>
                                    <div class="sidebar-nodes-grid" id="sidebarIntegrationsGrid">
                                        <div class="sidebar-node-item" data-preset-id="custom-tool">
                                            <i class="fa-regular fa-wrench"></i>
                                            <span>Custom Tool</span>
                                        </div>
                                        <div class="sidebar-node-item" data-preset-id="send-sms">
                                            <i class="fa-regular fa-comment-sms"></i>
                                            <span>Send SMS</span>
                                        </div>
                                        <div class="sidebar-node-item" data-preset-id="retrieve-kb">
                                            <i class="fa-regular fa-book-open"></i>
                                            <span>Retrieve Knowledgebase</span>
                                        </div>
                                        <!-- Dynamic FlowApps will be injected here via JS -->
                                    </div>
                                </div>

                            </div>
                        </div>

                        <!-- Graph Area -->
                        <div id="script-graph"></div>

                        <!-- Right Side Controls -->
                        <div class="script-graph-side-controls">
                            <!-- Minimap -->
                            <div id="script-graph-minimap" class="script-graph-minimap"></div>

                            <!-- Language -->
                            <div id="scriptsManagerMultiLanguageParentSideControlContainer" style="margin-bottom: 10px;">
                            </div>

                            <!-- Controls -->
                            <div class="script-graph-controls">
                                <div class="btn-group d-flex mb-2">
                                    <button id="script-graph-fullscreen" class="btn btn-primary btn-sm flex-fill" title="Toggle Fullscreen">
                                        <i class="fa-regular fa-expand"></i>
                                    </button>
                                </div>
                                <div class="btn-group d-flex mb-2">
                                    <button id="script-graph-zoom-in" class="btn btn-primary btn-sm flex-fill" title="Zoom In">
                                        <i class="fa-regular fa-magnifying-glass-plus"></i>
                                    </button>
                                    <button id="script-graph-zoom-out" class="btn btn-primary btn-sm flex-fill" title="Zoom Out">
                                        <i class="fa-regular fa-magnifying-glass-minus"></i>
                                    </button>
                                </div>
                                <div class="btn-group d-flex">
                                    <button id="script-graph-undo" class="btn btn-primary btn-sm flex-fill" title="Undo" disabled>
                                        <i class="fa-regular fa-rotate-left"></i>
                                    </button>
                                    <button id="script-graph-redo" class="btn btn-primary btn-sm flex-fill" title="Redo" disabled>
                                        <i class="fa-regular fa-rotate-right"></i>
                                    </button>
                                </div>

                                <div class="btn-group d-flex mb-2">
                                    <button id="script-graph-variables" class="btn btn-primary btn-sm flex-fill" title="Manage Script Variables">
                                        <i class="fa-regular fa-brackets-curly"></i>
                                    </button>
                                </div>
                            </div>
                        </div>

                        <!-- Configuration Offcanvas -->
                        <div class="offcanvas offcanvas-end text-bg-dark" data-bs-scroll="true" data-bs-backdrop="false" data-bs-keyboard="false" id="nodeConfigOffcanvas" tabindex="-1">
                            <div class="offcanvas-header">
                                <h5 class="offcanvas-title" id="nodeConfigTitle">Node Configuration</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
                            </div>
                            <div class="offcanvas-body" id="nodeConfigContent">
                                <!-- Configuration content will be loaded here -->
                            </div>
                        </div>

                            
                        <!-- Variables Manager Offcanvas -->
                        <div class="offcanvas offcanvas-end text-bg-dark" data-bs-scroll="true" data-bs-backdrop="false" tabindex="-1" id="variablesOffcanvas" aria-labelledby="variablesOffcanvasLabel">
                            <div class="offcanvas-header border-bottom border-secondary">
                                <h5 class="offcanvas-title" id="variablesOffcanvasLabel">Script Variables</h5>
                                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Close"></button>
                            </div>
                            <div class="offcanvas-body d-flex flex-column p-0">
        
                                <!-- List Container -->
                                <div class="flex-grow-1 overflow-auto p-3" id="variablesListContainer">
                                    <!-- Dynamic Variable Items will go here -->
                                    <div class="text-center text-muted mt-5 empty-vars-notice">
                                        <i class="fa-regular fa-brackets-curly fa-2x mb-2"></i>
                                        <p>No variables defined.</p>
                                    </div>
                                </div>

                                <!-- Add New Section (Fixed Bottom) -->
                                <div class="border-top border-secondary p-3 bg-dark">
                                    <h6 class="mb-3">Add New Variable</h6>
                                    <div class="mb-2">
                                        <input type="text" class="form-control form-control-sm mb-2" id="newVarKey" placeholder="Key (e.g. discount_code)">
                                        <select class="form-select form-select-sm mb-2" id="newVarType">
                                            <option value="1">String</option>
                                            <option value="2">Number</option>
                                            <option value="3">Boolean</option>
                                        </select>
                                        <input type="text" class="form-control form-control-sm mb-2" id="newVarDefault" placeholder="Value (Required for Static Variables)">
                                    </div>
                                    <div class="mb-2">
                                        <label class="form-label small btn-ic-span-align mb-1">
                                            <span>Description</span> <i class="fa-regular fa-language"></i> <span class="text-danger">*</span>
                                        </label>
                                        <input type="text" class="form-control form-control-sm" id="newVarDescription" placeholder="Explain what this variable is for...">
                                    </div>
                                    <div class="d-flex gap-3 mb-3">
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" id="newVarVisible" checked>
                                            <label class="form-check-label small text-muted" for="newVarVisible" title="Injected into System Prompt">
                                                Visible to AI
                                            </label>
                                        </div>
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" id="newVarEditable">
                                            <label class="form-check-label small text-muted" for="newVarEditable" title="AI can modify this value">
                                                Editable by AI
                                            </label>
                                        </div>
                                    </div>
                                    <button class="btn btn-success btn-sm w-100" id="addVariableBtn">
                                        <i class="fa-solid fa-plus me-1"></i> Add Variable
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                
            </div>
        </div>
    </div>

</div>