        <!-- Global -->
        <script>
            var AlertManager = new BootstrapAlertManager();

            var CurrentUserBusinessPermission = null;

            var CurrentBusinessesList = null;

            var PhysicalSimNumbersList = null;
            var TwilioNumbersList = null;
            var VonageNumbersList = null;
            var TelnyxNumbersList = null;

            var SpecificationRegionsListData = null;

            // API Related Calls
            function FetchSpecificationRegionsDataFromAPI(successCallback, errorCallback) {
                $.ajax({
                    url: '/app/specification/regions/',
                    type: 'POST',
                    success: (response) => {
                        if (!response.success) {
                            errorCallback(response);
                            return;
                        }

                        successCallback(response.data);
                    },
                    error: (error) => {
                        errorCallback(error);
                    }
                });
            }

            function FetchUserBusinessPermissionsFromAPI(successCallback, errorCallback) {
                $.ajax({
                    url: '/app/user/permissions/business',
                    type: 'POST',
                    dataType: "json",
                    success: (response) => {
                        if (!response.success) {
                            errorCallback(response);
                            return;
                        }

                        successCallback(response.data);
                    },
                    error: (error) => {
                        errorCallback(error);
                    }
                });
            }

            function FetchUserBusinessesFromAPI(successCallback, errorCallback) {
                $.ajax({
                    url: '/app/user/businesses',
                    type: 'POST',
                    dataType: "json",
                    success: (response) => {
                        if (!response.success) {
                            errorCallback(response);
                            return;
                        }

                        successCallback(response.data);
                    },
                    error: (error) => {
                        errorCallback(error);
                    }
                });
            }

            function FetchUserNumbersFromAPI(provider, page, pageSize, successCallback, errorCallback) {
                $.ajax({
                    url: '/app/user/numbers/' + provider,
                    type: 'POST',
                    dataType: "json",
                    data: {
                        page: page,
                        pageSize: pageSize
                    },
                    success: (response) => {
                        if (!response.success) {
                            errorCallback(response);
                            return;
                        }

                        successCallback(response.data);
                    },
                    error: (error) => {
                        errorCallback(error);
                    }
                });
            }

            function AddNewUserBusinessToAPI(formData, successCallback, errorCallback) {
                $.ajax({
                    url: '/app/user/business/add',
                    type: 'POST',
                    data: formData,
                    dataType: "json",
                    processData: false,
                    contentType: false,
                    success: (response) => {
                        if (!response.success) {
                            errorCallback(response);
                            return;
                        }

                        successCallback(response.data);
                    },
                    error: (error) => {
                        errorCallback(error);
                    }
                });
            }
        </script>

        <!-- PageLoader -->
        <script>
            const pageLoader = $("#page-loader");

            var PageLoaderInterval = setInterval(
                () => {
                    if (
                        CurrentBusinessesList != null
                        &&
                        SpecificationRegionsListData != null
                        &&
                        PhysicalSimNumbersList != null
                        &&
                        TwilioNumbersList != null
                        &&
                        VonageNumbersList != null
                        &&
                        TelnyxNumbersList != null
                    ) {
                        clearInterval(PageLoaderInterval);

                        pageLoader.css("opacity", "0");
                        setTimeout(() => {
                            pageLoader.addClass("d-none");
                        }, 300);
                    }
                }
                , 100);

            function RunActionAfterBusinessesDataLoad(action) {
                var businessDataCheckInterval = setInterval(
                    () => {
                        if (CurrentBusinessesList != null) {
                            clearInterval(businessDataCheckInterval);
                            action();
                        }
                    }
                    , 100);
            }
        </script>

        <!-- Scripts -->
        <script src="~/scripts/app/index/businesses_tab.js"></script>
        <script src="~/scripts/app/index/numbers_tab.js"></script>

        <!-- Init -->
        <script>
            FetchSpecificationRegionsDataFromAPI(
                (specificationRegions) => {
                    SpecificationRegionsListData = specificationRegions;

                    InitBusinessesTab();
                    RunActionAfterBusinessesDataLoad(() => {
                        InitNumbersTab();
                    });
                },
                (specificationRegionsError) => {
                    AlertManager.createAlert({
                        type: "danger",
                        message: "Error occured while fetching specification regions. Check browser console for logs.",
                        enableDismiss: false,
                    });

                    console.log("Error occured while fetching specification regions: ", specificationRegionsError);
                },
            );
        </script>
</body>

</html>