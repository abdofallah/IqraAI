    <script>
        const NumberProviderEnum = {
            "Physical": 1,
            "Twilio": 2,
            "Vonage": 3
        }

        var PhysicalSimNumbersListPage = 0;
        var PhysicalSimNumbersListPageSize = 0;

        const physicalSimNumbersTable = $("#physicalSimNumbersTable");

        function CreateUserPhysicalNumbersTableElement(numberData) {
            let countryData = CountriesList[numberData.countryCode.toUpperCase()]
            let businessData = CurrentBusinessesList.find((businessData) => businessData.id == numberData.assignedToBusinessId);

            let element = $(`<tr>
                <td><span class="badge bg-success">Online</span></td>
                <td>${countryData["Alpha-2 code"]}</td>
                <td>${numberData.number}</td>
                <td>${numberData.hostType.name}</td>
                <td>${(businessData == null ? "-" : businessData.name)}</td>
                <td>
                    <button class="btn btn-info btn-sm" number-email="${numberData.id}" button-type="edit-physical-number">
                        <i class="fa-regular fa-eye"></i>
                    </button>
                    <button class="btn btn-danger btn-sm">
                        <i class="fa-regular fa-trash"></i>
                    </button>
                </td>
            </tr>`);

            return element;
        }

        var LoadNumberAfterBusinesses = setInterval(
            () => {

                if (CurrentBusinessesList != null && !HasNumbersLoaded) {
                    HasNumbersLoaded = true;
                    clearInterval(LoadNumberAfterBusinesses);

                    $(document).ready(() => {
                        FetchUserNumbersFromAPI(NumberProviderEnum["Physical"], PhysicalSimNumbersListPage, PhysicalSimNumbersListPageSize,
                            (userPhysicalNumbers) => {
                                PhysicalSimNumbersList = userPhysicalNumbers;

                                if (PhysicalSimNumbersList.length == 0) {
                                    physicalSimNumbersTable.append('<tr><td colspan="6">No numbers found</td></tr>');
                                }
                                else
                                {
                                    PhysicalSimNumbersList.forEach((numberData) => {
                                        physicalSimNumbersTable.find("tbody").append(CreateUserPhysicalNumbersTableElement(numberData));
                                    })
                                }
                            },
                            (userPhysicalNumbersError) => {
                                AlertManager.createAlert({
                                    type: "danger",
                                    message: "Error occured while fetching user numbers. Check browser console for logs.",
                                    timeout: 5000
                                });

                                console.log("Error occured while fetching user numbers: ", userPhysicalNumbersError);
                            }
                        );
                    })
                }

            }, 100
        );
    </script>
</body>

</html>