    <!-- Variables -->
    <script>
        var isBusinessAnimationEnabled = true;
    </script>

    <!-- Businesses Tab -->
    <script>
        function MoveToBusinessPage(BusinessId) {
            window.location.href = "/app/business/" + BusinessId;
        }

        function FetchUserBusinessPermissionsFromAPI(successCallback)
        {
            $.ajax({
                url: '/app/user/permissions/business',
                type: 'POST',
                dataType: "json",
                success: (response) => {
                    successCallback(response.data);
                },
                error: (error) => {
                    console.log(error);
                }
            });
        }

        function FetchBusinessesFromAPI()
        {
            $.ajax({
                url: '/app/user/businesses',
                type: 'POST',
                dataType: "json",
                success: (data) => {
                    console.log(data);
                },
                error: (error) => {
                    console.log(error);
                }
            });


        }

        function CreateUserBusinessCard(businessData)
        {
            let element = `
                <div class="col-lg-4 col-md-6 col-12">
                    <div class="business-card d-flex flex-column align-items-start justify-content-center" data-business-id="${businessData.id}">
                        <div class="d-flex flex-row align-items-center justify-content-start">
                            <img src="~/img/logo/Badal-Logo-Black.png">
                            <h4>${businessData.name}</h4>
                        </div>
                    </div>
                </div>
            `;

            return $(element);
        }

        $(document).ready(() => {
            const AddNewBusinessButton = $("#AddNewBusinessButton");

            const BusinessesList = $("#BusinessesList");

            $(document).on("click", ".business-card", (event) => {
                let currentCardElement = $(event.currentTarget);
                let businessDataId = currentCardElement.attr("data-business-id");

                if (!businessDataId || !businessDataId.length) {
                    return;
                }

                if (isBusinessAnimationEnabled) {
                    $("body").css("overflow", "hidden");

                    let transitionTimeMS = 1000

                    currentCardElement.css("transition", `all ${transitionTimeMS}ms ease`);
                    currentCardElement.css("transform", "scale(40)");
                    currentCardElement.css("background-color", "#1a1a1a");
                    currentCardElement.css("color", "#1a1a1a");

                    setTimeout(() => {
                        MoveToBusinessPage(businessDataId);
                    }, (transitionTimeMS / 1.1));
                }
                else {
                    MoveToBusinessPage(businessDataId);
                }
            });

            // Init

            FetchUserBusinessPermissionsFromAPI((userBusinessPermission) => {
                if (userBusinessPermission.canViewBusinesses) {
                    FetchBusinessesFromAPI((userBusinesses) => {
                        console.log(userBusinesses);

                        userBusinesses.forEach((businessData) => {
                            let businessCardElement = CreateUserBusinessCard(businessData);

                            BusinessesList.append(businessCardElement);
                        });
                    });
                }

                if (userBusinessPermission.canAddBusinesses)
                {
                    AddNewBusinessButton.prop("disabled", false);
                }
            });
        });
    </script>
