        function FetchUsersFromAPI(page, pageSize, successCallback) {
            $.ajax({
                url: '/app/admin/users',
                type: 'POST',
                dataType: "json",
                data: {
                    page: page,
                    pageSize: pageSize
                },
                success: (response) => {
                    if (!response.success) {
                        alert(response.message);
                        return;
                    }

                    successCallback(response.data);
                },
                error: (error) => {
                    console.log(error);
                }
            });
        }

        function FetchUserFromAPI(email, successCallback, errorCallback) {
            $.ajax({
                url: '/app/admin/user',
                type: 'POST',
                dataType: "json",
                data: {
                    email: email
                },
                success: (response) => {
                    if (!response.success) {
                        alert(response.message);
                        return;
                    }

                    successCallback(response.data);
                },
                error: (error) => {
                    errorCallback(error);
                }
            });
