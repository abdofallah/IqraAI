            searchAddUserBusinessModalButton.on("click", (event) => {
                event.preventDefault();

                let value = addUserBusinessModalSearchInput.val().trim();

                FetchSearchedBusinessesFromAPI(value, UsersTabAddBusinessModalListPage, UsersTabAddBusinessModalListPageSize, (businesses) => {
