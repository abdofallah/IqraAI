        // Other Functions

        function DisableFullPermissionHelper(disableFullElement, subDisableElementsArray, dialogOptions)
        {
            disableFullElement.on("change", (event) => {
                event.preventDefault();
                event.stopPropagation();

                let current = $(event.currentTarget);

                let isChecked = current.is(':checked');
                if (isChecked) {
                    var confirmDialog = new BootstrapConfirmDialog(dialogOptions);

                    confirmDialog.show().then((isConfirmed) => {
                        if (isConfirmed) {
                            subDisableElementsArray.forEach((element) => {
                                element.prop("checked", false).prop("disabled", true).change();
                            })
                        } else {
                            disableFullElement.prop("checked", false);
                            disableFullElement.parent().parent().find("input[type=text]").val("").addClass("d-none");
                        }
                    });
                }
                else
                {
                    subDisableElementsArray.forEach((element) => {
                        element.prop("checked", false).prop("disabled", false).change();
                    });
                }
            });
        }

        function SetPermissionInput(checkboxElement, reasonInputElement, disabledAt, disabledReason) {
            if (disabledAt) {
                checkboxElement.prop("checked", true).change();
                if (disabledReason) {
                    reasonInputElement.val(disabledReason);
                }
            } else {
                checkboxElement.prop("checked", false).change();
                reasonInputElement.val("");
            }
        }
    </script>

    <!-- PageLoader -->
    <script>
        const pageLoader = $("#page-loader");

        var PageLoaderInterval = setInterval(
            () => {
                if (
                    CurrentUsersList != null
                    &&
                    CurrentBusinessesList != null
                    &&
                    CurrentRegionsList != null
                    &&
                    CurrentPhysicalNumbersList != null
                    &&
                    CurrentTwilioNumbersList != null
                    &&
                    CurrentVonageNumbersList != null
                    &&
                    CurrentLLMProvidersList != null
                    &&
                    CurrentSTTProvidersList != null
                    &&
                    CurrentLanguagesList != null
                    &&
                    CurrentIntegrationsList != null
                ) {
                    clearInterval(PageLoaderInterval);      

                    pageLoader.css("opacity", "0");
                    setTimeout(() => {
                        pageLoader.addClass("d-none");
                    }, 300);
                }
            }
        , 100);

        function RunActionAfterLanguagesLoad(action)
        {
            var languagesCheckInterval = setInterval(
                () => {
                    if (CurrentLanguagesList != null) {
                        clearInterval(languagesCheckInterval);
                        action();
                    }
                }
            , 100);
        }

        function RunActionAfterIntegrationsLoad(action)
        {
            var integrationsCheckInterval = setInterval(
                () => {
                    if (CurrentIntegrationsList != null) {
                        clearInterval(integrationsCheckInterval);
                        action();
                    }
                }
            , 100);
        }
    </script>

