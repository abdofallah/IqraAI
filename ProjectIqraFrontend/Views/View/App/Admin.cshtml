    <!-- Users Tab -->
    <script>
        var CurrentManageUserBusinesses = [];
        var CurrentManageUserNumbers = [];

        var UsersTabListTabPage = 0;
        var UsersTabListTabPageSize = 30;

        var IsEditUserAllowed = false;

        const usersTab = $("#users-tab");

        const usersListTable = usersTab.find("#usersListTable");

        const usersListTableTab = usersTab.find("#usersListTableTab");
        const usersManageTab = usersTab.find("#usersManageTab");

        const usersInnerTab = usersTab.find("#users-inner-tab");
        const usersManageBreadcrumb = usersTab.find("#users-manage-breadcrumb");

        const switchBackToUsersListTabFromManageTab = usersTab.find("#switchBackToUsersListTabFromManageTab");
        const currentManageUserName = usersTab.find("#currentManageUserName");

        const addUserBusinessModal = usersTab.find("#addUserBusinessModal");
        const addUserBusinessModalListTable = usersTab.find("#addUserBusinessModalListTable");

        function CreateUsersListTableElement(userData) {
            let element = $(`<tr>
                <td>${userData.email}</td>
                <td>${userData.firstName} ${userData.lastName}</td>
                <td>${userData.businesses.length}</td>
                <td>${userData.numbers.length}</td>
                <td>
                    <button class="btn btn-info btn-sm" user-email="${userData.email}" button-type="edit-user">
                        <i class="fa-regular fa-eye"></i>
                    </button>
                    <button class="btn btn-danger btn-sm">
                        <i class="fa-regular fa-trash"></i>
                    </button>
                </td>
            </tr>`);

            return element;
        }

        function CreateUserManageBusinessesTableElement(businessData) {
            let element = $(`<tr>
                <td>${businessData.id}</td>
                <td>${businessData.name}</td>
                <td>${businessData.numbers.length}</td>
                <td>${businessData.users.length}</td>
                <td>${businessData.region}</td>
                <td>
                    <button class="btn btn-info btn-sm" business-id="${businessData.id}" button-type="edit-business">
                        <i class="fa-regular fa-eye"></i>
                    </button>
                    <button class="btn btn-danger btn-sm">
                        <i class="fa-regular fa-trash"></i>
                    </button>
                </td>
            </tr>`);
        }

        function CreateUserManageNumbersTableElement(numberData) {
            let element = $(`<tr>
                <td>${numberData.id}</td>
                <td>${numberData.country}</td>
                <td>${numberData.number}</td>
                <td>${numberData.assigned}</td>
                <td>
                    <button class="btn btn-info btn-sm" number-email="${numberData.id}" button-type="edit-number">
                        <i class="fa-regular fa-eye"></i>
                    </button>
                    <button class="btn btn-danger btn-sm">
                        <i class="fa-regular fa-trash"></i>
                    </button>
                </td>
            </tr>`);
        }

        function ResetAndEmptyManageTabData() {
            usersManageTab.find("input[type=text]").val("");
            usersManageTab.find("input[type=checkbox]").prop("checked", false).change();
            usersManageTab.find("table tbody").empty();
        }

        function FillUserManageTab(userData, userBusinessesData, userNumbersData) {
            ResetAndEmptyManageTabData();

            // General

            usersManageTab.find("#usersManageFirstNameInput").val(userData.firstName);
            usersManageTab.find("#usersManageLastNameInput").val(userData.lastName);

            usersManageTab.find("#usersManageEmailInput").val(userData.email);

            // Permissions

            if (userData.permission.loginDisabledAt != null) {
                usersManageTab.find("#usersManageDisableLoginInput").prop("checked", true).change();

                if (userData.permission.loginDisabledReason != null) {
                    usersManageTab.find("#usersManageLoginDisabledReasonInput").val(userData.permission.loginDisabledReason);
                }
            }

            if (userData.permission.business.disableBusinessesAt != null) {
                usersManageTab.find("#usersManageDisableCompleteBusinessInput").prop("checked", true).change();


                if (userData.permission.business.disableBusinessesReason != null) {
                    usersManageTab.find("#usersManageDisableCompleteBusinessReasonInput").val(userData.permission.business.disableBusinessesReason);
                }
            }

            if (userData.permission.business.editBusinessDisabledAt != null) {
                usersManageTab.find("#usersManageDisableDeleteBusinessInput").prop("checked", true).change();

                if (userData.permission.business.editBusinessDisabledReason != null) {
                    usersManageTab.find("#usersManageDisableEditBusinessReasonInput").val(userData.permission.business.editBusinessDisabledReason);
                }
            }

            if (userData.permission.business.deleteBusinessDisableAt != null) {
                usersManageTab.find("#usersManageDisableDeleteInput").prop("checked", true).change();

                if (userData.permission.business.deleteBusinessDisabledReason != null) {
                    usersManageTab.find("#usersManageDisableDeleteReasonInput").val(userData.permission.business.deleteBusinessDisabledReason);
                }
            }

            if (userData.permission.business.addBusinessDisabledAt != null) {
                usersManageTab.find("#usersManageDisableAddBusinessInput").prop("checked", true).change();

                if (userData.permission.business.addBusinessDisabledReason != null) {
                    usersManageTab.find("#usersManageDisableAddBusinessReasonInput").val(userData.permission.business.addBusinessDisabledReason);
                }
            }

            // Businesses

            if (userBusinessesData.length > 0) {
                userBusinessesData.forEach((businessData) => {
                    usersManageTab.find("#userBusinessesListTable tbody").append(CreateUserManageBusinessesTableElement(businessData));
                });
            }
            else {
                usersManageTab.find("#userBusinessesListTable tbody").append('<tr tr-type="none-notice"><td colspan="6">No businesses</td></tr>');
            }

            // Numbers

            if (userNumbersData.length > 0) {
                userNumbersData.forEach((numberData) => {
                    usersManageTab.find("#userNumbersListTable tbody").append(CreateUserManageNumbersTableElement(numberData));
                });
            }
            else {
                usersManageTab.find("#userNumbersListTable tbody").append('<tr tr-type="none-notice"><td colspan="5">No numbers</td></tr>');
            }
        }

        $(document).ready(() => {
            $(document).on("click", "#users-tab #usersListTable tr td button[button-type=edit-user]", (event) => {
                event.preventDefault();
                event.stopPropagation();

                if (!IsEditUserAllowed) {
                    console.log("Already editing a user!");
                    return;
                }

                IsEditUserAllowed = false;

                let userEmail = $(event.currentTarget).attr("user-email");
                usersManageTab.attr("user-email", userEmail);

                let currentUserData = CurrentUsersList.find((userData) => userData.email == userEmail);
                if (!currentUserData) {
                    alert("Could not find user data for: " + user);

                    IsEditUserAllowed = true;
                    return;
                }

                FetchUserBusinessesFromAPI(userEmail, (userBusinessesData) => {
                    CurrentManageUserBusinesses = userBusinessesData;
                });

                FetchUserNumbersFromAPI(userEmail, (userNumbersData) => {
                    CurrentManageUserNumbers = userNumbersData;
                });

                FillUserManageTab(currentUserData, CurrentManageUserBusinesses, CurrentManageUserNumbers);
                currentManageUserName.text(userEmail);

                $("#users-manage-general-tab").click();

                usersInnerTab.removeClass("show");
                usersListTableTab.removeClass("show");
                setTimeout(() => {
                    usersInnerTab.addClass("d-none");
                    usersListTableTab.addClass("d-none");

                    usersManageBreadcrumb.removeClass("d-none");
                    usersManageTab.removeClass("d-none");

                    setTimeout(() => {
                        usersManageBreadcrumb.addClass("show");
                        usersManageTab.addClass("show");

                        IsEditUserAllowed = true;
                        return;
                    }, 10);
                }, 300);
            });

            switchBackToUsersListTabFromManageTab.on("click", (event) => {
                event.preventDefault();

                usersManageBreadcrumb.removeClass("show");
                usersManageTab.removeClass("show");
                setTimeout(() => {
                    usersManageBreadcrumb.addClass("d-none");
                    usersManageTab.addClass("d-none");

                    usersInnerTab.removeClass("d-none");
                    usersListTableTab.removeClass("d-none");

                    setTimeout(() => {
                        usersInnerTab.addClass("show");
                        usersListTableTab.addClass("show");
                    }, 10);
                }, 300);
            });

            $("#users-tab #usersManageTab input[check-type=permission-with-reason]").on("change", (event) => {
                event.stopPropagation();

                let current = $(event.currentTarget);
                let reasonInput = current.parent().parent().find("input[type=text]");

                if (current.prop("checked")) {
                    reasonInput.removeClass("d-none");
                }
                else {
                    reasonInput.addClass("d-none");
                }
            });

            // Add User Business Modal
            addUserBusinessModal.on('show.bs.modal', (event) => {
                addUserBusinessModalListTable.find("tbody").append('<tr><td colspan="3">Search for results...</td></tr>');
            });

            addUserBusinessModal.on('hidden.bs.modal', (event) => {
                addUserBusinessModalListTable.find("tbody").empty();
            });

            // Add User Number Modal
            // Todo

            // Init

            FetchUsersFromAPI(UsersTabListTabPage, UsersTabListTabPageSize, (users) => {
                CurrentUsersList = users;

                users.forEach((userData) => {
                    usersListTable.append(CreateUsersListTableElement(userData));
                });

                IsEditUserAllowed = true;
            });
        });
    </script>

    <!-- Businesses Tab -->
    <script>
        var BusinessesTabListTabPage = 0;
        var BusinessesTabListTabPageSize = 30;

        var CurrentBusinessesList = null;

        const businessesTab = $("#business-tab");

        const manageBusinessMasterUserInput = businessesTab.find("#manageBusinessMasterUserInput");

        const manageBusinessMasterUserModal = businessesTab.find("#manageBusinessMasterUserModal");

        const searchBusinessMasterUserModalButton = manageBusinessMasterUserModal.find("#searchBusinessMasterUserModalButton");
        const searchBusinessMasterUserModalInput = manageBusinessMasterUserModal.find("#searchBusinessMasterUserModalInput");
        const businessMasterUserModalListTable = manageBusinessMasterUserModal.find("#businessMasterUserModalListTable");
        const selectManageBusinessMasterUserButton = manageBusinessMasterUserModal.find("#selectManageBusinessMasterUserButton");

        $(document).ready(() => {
            searchBusinessMasterUserModalInput.on("input", (event) => {
                let value = searchBusinessMasterUserModalInput.val().trim();

                if (!value || value == "") {
                    searchBusinessMasterUserModalInput.addClass("is-invalid");
                    searchBusinessMasterUserModalButton.prop("disabled", true);
                }
                else {
                    searchBusinessMasterUserModalInput.removeClass("is-invalid");
                    searchBusinessMasterUserModalButton.prop("disabled", false);
                }
            })

            searchBusinessMasterUserModalButton.on("click", (event) => {
                event.preventDefault();

                searchBusinessMasterUserModalInput.prop("disabled", true);
                searchBusinessMasterUserModalButton.prop("disabled", true);
                selectManageBusinessMasterUserButton.prop("disabled", true);

                businessMasterUserModalListTable.find("tbody").empty();

                FetchUserFromAPI(searchBusinessMasterUserModalInput.val().trim(),
                    // success callback
                    (userData) => {
                        let element = $(
                            `<tr class="selectable" tr-type="business-master-user">
                                <td data-type="email">${userData.email}</td>
                                <td data-type="name">${userData.firstName} ${userData.lastName}</td>
                            </tr>`
                        );

                        businessMasterUserModalListTable.find("tbody").append(element);

                        searchBusinessMasterUserModalInput.prop("disabled", false);
                        searchBusinessMasterUserModalButton.prop("disabled", false);
                    },
                    // Error callback
                    (error) => {
                        console.log(error);

                        searchBusinessMasterUserModalInput.prop("disabled", false);
                        searchBusinessMasterUserModalButton.prop("disabled", false);
                    }
                );
            });

            $(document).on("click", "#business-tab #businessMasterUserModalListTable tr.selectable[tr-type=business-master-user]", (event) => {
                event.preventDefault();

                let userEmail = $(event.currentTarget).find("td[data-type=email]").text();

                let findActiveSelectable = businessMasterUserModalListTable.find("tr.selectable[tr-type=business-master-user].active");
                findActiveSelectable.removeClass("active");

                $(event.currentTarget).addClass("active");

                selectManageBusinessMasterUserButton.prop("disabled", false);
            });

            selectManageBusinessMasterUserButton.on("click", (event) => {
                event.preventDefault();

                let findActiveSelectable = businessMasterUserModalListTable.find("tr.selectable[tr-type=business-master-user].active");

                let userEmail = findActiveSelectable.find("td[data-type=email]").text();

                manageBusinessMasterUserInput.val(userEmail);

                manageBusinessMasterUserModal.modal("hide");
            });

            manageBusinessMasterUserModal.on('show.bs.modal', (event) => {
                businessMasterUserModalListTable.find("tbody").append($('<tr><td colspan="2">Search for result...</td></tr>'));
            });

            manageBusinessMasterUserModal.on('hidden.bs.modal', (event) => {
                searchBusinessMasterUserModalButton.prop("disabled", true);
                searchBusinessMasterUserModalInput.val("").prop("disabled", false).removeClass("is-invalid");
                businessMasterUserModalListTable.find("tbody").empty();
            });

            $("#business-tab #businesses-manage-permissions input[check-type=permission-with-reason]").on("change", (event) => {
                event.stopPropagation();

                let current = $(event.currentTarget);
                let reasonInput = current.parent().parent().find("input[type=text]");

                if (current.prop("checked")) {
                    reasonInput.removeClass("d-none");
                }
                else {
                    reasonInput.addClass("d-none");
                }
            });

            // Init

            FetchBusinessesFromAPI(BusinessesTabListTabPage, BusinessesTabListTabPageSize, (businesses) => {
                CurrentBusinessesList = businesses;

                businesses.forEach((businessData) => {
                    console.log(businessData);
                });
            });
        });
    </script>

