<html data-bs-theme="dark">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard | Iqra AI</title>

    <link href="~/libs/bootstrap-5.3.3-dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/libs/boxicons-2.1.4/css/boxicons.min.css" rel="stylesheet">
    <link href="~/libs/fontawesome-pro-6.5.1-web/css/fontawesome.min.css" rel="stylesheet">
    <link href="~/libs/fontawesome-pro-6.5.1-web/css/regular.min.css" rel="stylesheet">

    <link href="~/css/structure.css" rel="stylesheet">
    <link href="~/css/style.css" rel="stylesheet">

    <link rel="icon" type="image/x-icon" href="~/img/favicon.ico">

    <style id="dynamicCSS"></style>
</head>

<body id="body-pd" class="body-pd">
    <div id="page-loader">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>

    <header class="header header-body-pd" id="header">
        <div class="header_toggle"> <i class='fa-regular fa-bars fa-bars' id="header-toggle"></i> </div>
    </header>

    <div class="l-navbar show" id="nav-bar">
        <nav class="nav">
            <div class="upper-navigation">
                <a href="/" class="nav_logo">
                    <img class="nav_logo-icon" src="~/img/logo/logo-colored-light.png">
                </a>
                <div class="nav_list">
                    <a href="#" class="nav_link" for="users-tab">
                        <i class='fa-regular fa-user nav_icon'></i>
                        <span class="nav_name">Users</span>
                    </a>
                    <a href="#" class="nav_link" for="business-tab">
                        <i class='fa-regular fa-briefcase nav_icon'></i>
                        <span class="nav_name">Businesses</span>
                    </a>
                    <a href="#" class="nav_link" for="phone-numbers-tab">
                        <i class='fa-regular fa-hashtag nav_icon'></i>
                        <span class="nav_name">Numbers</span>
                    </a>
                    <a href="#" class="nav_link" for="region-tab">
                        <i class='fa-regular fa-server nav_icon'></i>
                        <span class="nav_name">Region</span>
                    </a>
                    <a href="#" class="nav_link" for="llm-provider-tab">
                        <i class='fa-regular fa-message-text nav_icon'></i>
                        <span class="nav_name">LLM Provider</span>
                    </a>
                    <a href="#" class="nav_link" for="languages-tab">
                        <i class='fa-regular fa-language nav_icon'></i>
                        <span class="nav_name">Languages</span>
                    </a>
                    <a href="#" class="nav_link active" for="integrations-tab">
                        <i class='fa-regular fa-cube nav_icon'></i>
                        <span class="nav_name">Integrations</span>
                    </a>
                </div>
            </div>
            <div class="bottom-navigation">
                <a href="/logout" class="nav_link mt-0">
                    <i class='fa-regular fa-right-from-bracket nav_icon'></i>
                    <span class="nav_name">Log out</span>
                </a>
            </div>

        </nav>
    </div>

    <div class="w-100 main-container-wrapper" id="tabs-list">
        <!-- Users Container -->
        <div class="main-container fade w-100 d-none" id="users-tab">
            <h3 class="fw-bold tab-title"><i class='fa-regular fa-user'></i> <span>Users</span></h3>
            <div class="inner-container">
                <!-- Manager Inner Tabs -->
                <div class="mb-3">
                    <ul class="nav w-100 fade show" id="users-inner-tab" role="tablist">
                        <li class="nav-item me-2" role="presentation">
                            <button class="nav-link disabled" id="users-analytics-tab" data-bs-toggle="pill" data-bs-target="#users-analytics" type="button" role="tab" aria-controls="users-analytics" aria-selected="true">Analytics</button>
                        </li>
                        <li class="nav-item me-2" role="presentation">
                            <button class="nav-link active" id="users-list-tab" data-bs-toggle="pill" data-bs-target="#users-list" type="button" role="tab" aria-controls="users-list" aria-selected="true">List</button>
                        </li>
                    </ul>
                    <nav class="w-100 fade d-none" aria-label="breadcrumb" id="users-manage-breadcrumb">
                        <ol class="breadcrumb mb-0">
                            <li class="breadcrumb-item">
                                <a href="#" id="switchBackToUsersListTabFromManageTab">Users</a>
                            </li>
                            <li class="breadcrumb-item active" aria-current="page"><span id="currentManageUserName">User</span></li>
                        </ol>
                    </nav>
                </div>
                <!-- Tab Content -->
                <div class="tab-content w-100" id="users-inner-tabContent">
                    <!-- Analytics -->
                    <div class="tab-pane fade w-100" id="users-analytics" role="tabpanel" aria-labelledby="users-analytics-tab" tabindex="0">
                        analytics
                    </div>

                    <!-- List -->
                    <div class="tab-pane fade w-100 show active" id="users-list" role="tabpanel" aria-labelledby="users-list-tab" tabindex="0">
                        <!-- Users List Table Tab -->
                        <div class="fade w-100 show" id="usersListTableTab">
                            <div class="mb-4 d-flex flex-row align-items-center justify-content-between">
                                <div style="min-width: 200px" class="me-4">
                                    <button class="w-100 mb-0 text-decoration-none fw-bold btn btn-primary" id="addNewUserButton">
                                        <span>+ Add New User</span>
                                    </button>
                                </div>
                                <div class="input-group w-100">
                                    <input type="text" class="form-control" placeholder="User Name or Email" aria-label="User Name or Email" aria-describedby="searchUserButton">
                                    <button class="input-group-button btn btn-primary" id="searchAgentScriptButton">
                                        <i class='fa-regular fa-magnifying-glass'></i>
                                    </button>
                                </div>
                            </div>
                            <table id="usersListTable" class="table w-100">
                                <thead>
                                    <tr>
                                        <th scope="col">Email</th>
                                        <th scope="col">Name</th>
                                        <th scope="col">Businesses</th>
                                        <th scope="col">Numbers</th>
                                        <th scope="col">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <!-- Dynamically Generated -->
                                </tbody>
                            </table>
                        </div>
                        <!-- Users Manage Tab -->
                        <div class="fade w-100 d-none" id="usersManageTab">
                            <!-- Header Tab -->
                            <div class="mb-3 d-flex flex-row align-items-center justify-content-between">
                                <ul class="nav" id="users-manage-tab" role="tablist">
                                    <li class="nav-item me-2" role="presentation">
                                        <button class="nav-link active" id="users-manage-general-tab" data-bs-toggle="pill" data-bs-target="#users-manage-general" type="button" role="tab" aria-controls="users-manage-general" aria-selected="true">General</button>
                                    </li>
                                    <li class="nav-item me-2" role="presentation">
                                        <button class="nav-link" id="users-manage-actions-tab" data-bs-toggle="pill" data-bs-target="#users-manage-actions" type="button" role="tab" aria-controls="users-manage-actions" aria-selected="true">Actions</button>
                                    </li>
                                    <li class="nav-item me-2" role="presentation">
                                        <button class="nav-link" id="users-manage-permissions-tab" data-bs-toggle="pill" data-bs-target="#users-manage-permissions" type="button" role="tab" aria-controls="users-manage-permissions" aria-selected="true">Permissions</button>
                                    </li>
                                    <li class="nav-item me-2" role="presentation">
                                        <button class="nav-link" id="users-manage-businesses-tab" data-bs-toggle="pill" data-bs-target="#users-manage-businesses" type="button" role="tab" aria-controls="users-manage-businesses" aria-selected="true">Businesses</button>
                                    </li>
                                    <li class="nav-item me-2" role="presentation">
                                        <button class="nav-link" id="users-manage-numbers-tab" data-bs-toggle="pill" data-bs-target="#users-manage-numbers" type="button" role="tab" aria-controls="users-manage-numbers" aria-selected="true">Numbers</button>
                                    </li>
                                    <li class="nav-item me-2" role="presentation">
                                        <button class="nav-link disabled" id="users-manage-analytics-tab" data-bs-toggle="pill" data-bs-target="#users-manage-analytics" type="button" role="tab" aria-controls="users-manage-analytics" aria-selected="true">Analytics</button>
                                    </li>
                                </ul>

                                <button class="btn btn-primary btn-sm btn-ic-span-align" id="usersManageSaveButton">
                                    <i class='fa-regular fa-floppy-disk'></i>
                                    <span> Save</span>
                                </button>
                            </div>
                            <!-- Tab Content -->
                            <div class="tab-content w-100" id="users-manage-tabContent">
                                <!-- General -->
                                <div class="tab-pane fade w-100 show active" id="users-manage-general" role="tabpanel" aria-labelledby="users-manage-general-tab" tabindex="0">
                                    <div class="mb-3">
                                        <label for="usersManageFirstNameInput" class="form-label">First Name</label>
                                        <input type="text" class="form-control" id="usersManageFirstNameInput" placeholder="First Name">
                                    </div>
                                    <div class="mb-3">
                                        <label for="usersManageLastNameInput" class="form-label">Last Name</label>
                                        <input type="text" class="form-control" id="usersManageLastNameInput" placeholder="Last Name">
                                    </div>
                                    <div class="mb-3">
                                        <label for="usersManageEmailInput" class="form-label">Email</label>
                                        <input type="email" class="form-control" id="usersManageEmailInput" placeholder="Email">
                                    </div>
                                    <div class="mb-3">
                                        <label for="usersManagePasswordInput" class="form-label">Password</label>
                                        <input type="text" class="form-control" id="usersManagePasswordInput" placeholder="Password">
                                    </div>
                                </div>
                                <!-- Actions -->
                                <div class="tab-pane fade w-100" id="users-manage-actions" role="tabpanel" aria-labelledby="users-manage-actions-tab" tabindex="0">
                                    <div class="mb-3">
                                        <label for="usersManageSendResetPasswordInput" class="form-label d-block">Send Reset Password</label>
                                        <button class="input-group-button btn btn-primary" id="usersManageSendResetPasswordButton">
                                            <i class='fa-regular fa-key'></i>
                                            <span> Send</span>
                                        </button>
                                    </div>
                                </div>
                                <!-- Permissions -->
                                <div class="tab-pane fade w-100" id="users-manage-permissions" role="tabpanel" aria-labelledby="users-manage-permissions-tab" tabindex="0">
                                    <div class="mb-3">
                                        <label class="form-label d-block">Authentication</label>

                                        <div class="">
                                            <div class="form-check form-switch">
                                                <input class="form-check-input" type="checkbox" role="switch" id="usersManageDisableLoginInput" check-type="permission-with-reason">
                                                <label for="usersManageDisableLoginInput" class="form-label d-block">Login Disabled</label>
                                            </div>
                                            <input type="text" class="form-control d-none" id="usersManageLoginDisabledReasonInput" placeholder="Login Disabled Reason">
                                        </div>

                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label d-block">Business</label>

                                        <div class="mb-2">
                                            <div class="form-check form-switch">
                                                <input class="form-check-input" type="checkbox" role="switch" id="usersManageDisableCompleteBusinessInput" check-type="permission-with-reason">
                                                <label for="usersManageDisableCompleteBusinessInput" class="form-label d-block">Disable Complete (Viewing Also)</label>
                                            </div>
                                            <input type="text" class="form-control d-none" id="usersManageDisableCompleteBusinessReasonInput" placeholder="Disable Complete Reason">
                                        </div>

                                        <div class="mb-2">
                                            <div class="form-check form-switch">
                                                <input class="form-check-input" type="checkbox" role="switch" id="usersManageDisableEditBusinessInput" check-type="permission-with-reason">
                                                <label for="usersManageDisableEditBusinessInput" class="form-label d-block">Disable Edit</label>
                                            </div>
                                            <input type="text" class="form-control d-none" id="usersManageDisableEditBusinessReasonInput" placeholder="Disable Edit Reason">
                                        </div>

                                        <div class="mb-2">
                                            <div class="form-check form-switch">
                                                <input class="form-check-input" type="checkbox" role="switch" id="usersManageDisableDeleteBusinessInput" check-type="permission-with-reason">
                                                <label for="usersManageDisableDeleteBusinessInput" class="form-label d-block">Disable Delete</label>
                                            </div>
                                            <input type="text" class="form-control d-none" id="usersManageDisableDeleteBusinessReasonInput" placeholder="Disable Delete Reason">
                                        </div>

                                        <div class="mb-2">
                                            <div class="form-check form-switch">
                                                <input class="form-check-input" type="checkbox" role="switch" id="usersManageDisableAddBusinessInput" check-type="permission-with-reason">
                                                <label for="usersManageDisableAddBusinessInput" class="form-label d-block">Disable Add</label>
                                            </div>
                                            <input type="text" class="form-control d-none" id="usersManageDisableAddBusinessReasonInput" placeholder="Disable Add Reason">
                                        </div>

                                    </div>
                                </div>
                                <!-- Businesses -->
                                <div class="tab-pane fade w-100" id="users-manage-businesses" role="tabpanel" aria-labelledby="users-manage-businesses-tab" tabindex="0">
                                    <div class="mb-4 d-flex flex-row align-items-center justify-content-between">
                                        <div style="min-width: 200px" class="me-4">
                                            <button class="w-100 mb-0 text-decoration-none fw-bold btn btn-primary" id="addUserBusinessModalButton" data-bs-toggle="modal" data-bs-target="#addUserBusinessModal">
                                                <span>+ Add Business</span>
                                            </button>
                                        </div>
                                        <div class="input-group w-100">
                                            <input type="text" class="form-control" placeholder="Business name or id" aria-label="Business name or id" aria-describedby="searchUserBusinessButton">
                                            <button class="input-group-button btn btn-primary" id="searchUserBusinessButton">
                                                <i class='fa-regular fa-magnifying-glass'></i>
                                            </button>
                                        </div>
                                    </div>
                                    <table id="userBusinessesListTable" class="table w-100">
                                        <thead>
                                            <tr>
                                                <th scope="col">#</th>
                                                <th scope="col">Name</th>
                                                <th scope="col">Numbers</th>
                                                <th scope="col">Users</th>
                                                <th scope="col">Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <!-- Dynamically Generated -->
                                        </tbody>
                                    </table>
                                    <!-- Add Business Modal -->
                                    <div class="modal modal-lg fade" id="addUserBusinessModal" tabindex="-1" aria-labelledby="addUserBusinessModalLabel" aria-hidden="true">
                                        <div class="modal-dialog modal-dialog-centered">
                                            <div class="modal-content">
                                                <div class="modal-header">
                                                    <h1 class="modal-title fs-5" id="addUserBusinessModalLabel">Add User Business</h1>
                                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                                </div>
                                                <div class="modal-body">
                                                    <div class="input-group w-100 mb-3">
                                                        <input type="text" class="form-control" placeholder="Business name or id" aria-label="Business name or id" aria-describedby="searchAddUserBusinessModalButton" id="addUserBusinessModalSearchInput">
                                                        <button class="input-group-button btn btn-primary" id="searchAddUserBusinessModalButton" disabled>
                                                            <i class='fa-regular fa-magnifying-glass'></i>
                                                        </button>
                                                    </div>
                                                    <table id="addUserBusinessModalListTable" class="table w-100 table-selectable">
                                                        <thead>
                                                            <tr>
                                                                <th scope="col">#</th>
                                                                <th scope="col">Name</th>
                                                                <th scope="col">Master Email</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            <!-- Dynamically Generated -->
                                                            <tr>
                                                                <td colspan="3" class="text-center">Search for results...</td>
                                                            </tr>
                                                        </tbody>
                                                    </table>
                                                </div>
                                                <div class="modal-footer">
                                                    <button type="button" class="btn btn-primary btn-ic-span-align" id="addUserBusinessModalSaveButton" disabled>
                                                        <i class="fa-regular fa-plus"></i>
                                                        <span> Add</span>
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <!-- Numbers -->
                                <div class="tab-pane fade w-100" id="users-manage-numbers" role="tabpanel" aria-labelledby="users-manage-numbers-tab" tabindex="0">
                                    <div class="input-group w-100 mb-4">
                                        <input type="text" class="form-control" placeholder="Number" aria-label="Number" aria-describedby="searchUserNumberButton">
                                        <button class="input-group-button btn btn-primary" id="searchUserNumberButton">
                                            <i class='fa-regular fa-magnifying-glass'></i>
                                        </button>
                                    </div>
                                    <table id="userNumbersListTable" class="table w-100">
                                        <thead>
                                            <tr>
                                                <th scope="col">#</th>
                                                <th scope="col">Country</th>
                                                <th scope="col">Number</th>
                                                <th scope="col">Provider</th>
                                                <th scope="col">Assigned</th>
                                                <th scope="col">Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <!-- Dynamically Generated -->
                                        </tbody>
                                    </table>
                                </div>
                                <!-- Analytics -->
                                <div class="tab-pane fade w-100" id="users-manage-analytics" role="tabpanel" aria-labelledby="users-manage-analytics-tab" tabindex="0">
                                    analytics
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Bussiness Container -->
        <div class="main-container fade w-100 d-none" id="business-tab">
            <h3 class="fw-bold tab-title"><i class='fa-regular fa-briefcase'></i> <span>Businesses</span></h3>
            <div class="inner-container">
                <!-- Manager Inner Tabs -->
                <div class="mb-3">
                    <ul class="nav w-100 fade show" id="business-inner-tab" role="tablist">
                        <li class="nav-item me-2" role="presentation">
                            <button class="nav-link disabled" id="businesses-analytics-tab" data-bs-toggle="pill" data-bs-target="#businesses-analytics" type="button" role="tab" aria-controls="businesses-analytics" aria-selected="true">Analytics</button>
                        </li>
                        <li class="nav-item me-2" role="presentation">
                            <button class="nav-link active" id="businesses-list-tab" data-bs-toggle="pill" data-bs-target="#businesses-list" type="button" role="tab" aria-controls="businesses-list" aria-selected="true">List</button>
                        </li>
                    </ul>
                    <nav class="w-100 fade d-none" aria-label="breadcrumb" id="businesses-manage-breadcrumb">
                        <ol class="breadcrumb mb-0">
                            <li class="breadcrumb-item">
                                <a href="#" id="switchBackToBusinessesListTabFromManageTab">Business</a>
                            </li>
                            <li class="breadcrumb-item active" aria-current="page"><span id="currentManageBusinessName">Business</span></li>
                        </ol>
                    </nav>
                </div>
                <!-- Tab Content -->
                <div class="tab-content w-100" id="businesses-inner-tabContent">
                    <!-- Analytics -->
                    <div class="tab-pane fade w-100" id="businesses-analytics" role="tabpanel" aria-labelledby="businesses-analytics-tab" tabindex="0">
                        analytics
                    </div>

                    <!-- List -->
                    <div class="tab-pane fade w-100 show active" id="businesses-list" role="tabpanel" aria-labelledby="businesses-list-tab" tabindex="0">
                        <!-- Businesses List Table Tab -->
                        <div class="fade w-100 show" id="businessesListTableTab">
                            <div class="mb-4 d-flex flex-row align-items-center justify-content-between">
                                <div style="min-width: 200px" class="me-4">
                                    <button class="w-100 mb-0 text-decoration-none fw-bold btn btn-primary" id="addNewBusinessButton">
                                        <span>+ Add New Business</span>
                                    </button>
                                </div>
                                <div class="input-group w-100">
                                    <input type="text" class="form-control" placeholder="Business Name or Id" aria-label="Business Name or Id" aria-describedby="searchBusinessButton">
                                    <button class="input-group-button btn btn-primary" id="searchBusinessButton">
                                        <i class='fa-regular fa-magnifying-glass'></i>
                                    </button>
                                </div>
                            </div>
                            <table id="businessesListTable" class="table w-100">
                                <thead>
                                    <tr>
                                        <th scope="col">#</th>
                                        <th scope="col">Name</th>
                                        <th scope="col">Numbers</th>
                                        <th scope="col">Master Email</th>
                                        <th scope="col">Users</th>
                                        <th scope="col">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <!-- Dynamically Generated -->
                                </tbody>
                            </table>
                        </div>
                        <!-- Businesses Manage Tab -->
                        <div class="fade w-100 d-none" id="businessesManageTab">
                            <!-- Businesses Manage General Tab -->
                            <div class="mb-3 d-flex flex-row align-items-center justify-content-between">
                                <ul class="nav" id="businesses-manage-tab" role="tablist">
                                    <li class="nav-item me-2" role="presentation">
                                        <button class="nav-link active" id="businesses-manage-general-tab" data-bs-toggle="pill" data-bs-target="#businesses-manage-general" type="button" role="tab" aria-controls="businesses-manage-general" aria-selected="true">General</button>
                                    </li>
                                    <li class="nav-item me-2" role="presentation">
                                        <button class="nav-link" id="businesses-manage-permissions-tab" data-bs-toggle="pill" data-bs-target="#businesses-manage-permissions" type="button" role="tab" aria-controls="businesses-manage-permissions" aria-selected="true">Permissions</button>
                                    </li>
                                    <li class="nav-item me-2" role="presentation">
                                        <button class="nav-link" id="businesses-manage-numbers-tab" data-bs-toggle="pill" data-bs-target="#businesses-manage-numbers" type="button" role="tab" aria-controls="businesses-manage-numbers" aria-selected="true">Numbers</button>
                                    </li>
                                    <li class="nav-item me-2" role="presentation">
                                        <button class="nav-link disabled" id="businesses-manage-routing-tab" data-bs-toggle="pill" data-bs-target="#businesses-manage-routing" type="button" role="tab" aria-controls="businesses-manage-routing" aria-selected="true">Routing</button>
                                    </li>
                                    <li class="nav-item me-2" role="presentation">
                                        <button class="nav-link disabled" id="businesses-manage-agents-tab" data-bs-toggle="pill" data-bs-target="#businesses-manage-agents" type="button" role="tab" aria-controls="businesses-manage-agents" aria-selected="true">Agents</button>
                                    </li>
                                    <li class="nav-item me-2" role="presentation">
                                        <button class="nav-link disabled" id="businesses-manage-analytics-tab" data-bs-toggle="pill" data-bs-target="#businesses-manage-analytics" type="button" role="tab" aria-controls="businesses-manage-analytics" aria-selected="true">Analytics</button>
                                    </li>
                                </ul>

                                <button class="btn btn-primary btn-sm btn-ic-span-align" id="businessesManageSaveButton">
                                    <i class='fa-regular fa-floppy-disk'></i>
                                    <span> Save</span>
                                </button>
                            </div>

                            <!-- Tab Content -->
                            <div class="tab-content w-100" id="businesses-manage-tabContent">
                                <!-- General -->
                                <div class="tab-pane fade w-100 show active" id="businesses-manage-general" role="tabpanel" aria-labelledby="businesses-manage-general-tab" tabindex="0">
                                    <div class="mb-3">
                                        <label for="manageBusinessNameInput" class="form-label">Name</label>
                                        <input type="text" class="form-control" id="manageBusinessNameInput" placeholder="Name">
                                    </div>
                                    <div class="mb-3">
                                        <label for="manageBusinessLogoInput" class="form-label d-block">Logo</label>
                                        <img src="~/img/logo/logo-colored-light.png" class="img-fluid rounded-3 mb-3" alt="Business Logo" id="manageBusinessLogoPreview">
                                        <input type="file" class="form-control" id="manageBusinessLogoInput" placeholder="Logo">
                                    </div>
                                    <div class="mb-3">
                                        <label for="manageBusinessMasterUserInput" class="form-label">Master User</label>
                                        <input type="text" class="form-control" id="manageBusinessMasterUserInput" placeholder="Master User" disabled>
                                    </div>
                                </div>

                                <!-- Permissions -->
