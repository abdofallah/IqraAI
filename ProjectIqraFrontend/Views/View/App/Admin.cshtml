                                    </div>
                                </div>
                                <!-- Permissions -->
                                <div class="tab-pane fade w-100" id="users-manage-permissions" role="tabpanel" aria-labelledby="users-manage-permissions-tab" tabindex="0">
                                    <div class="mb-3">
                                        <label class="form-label d-block">Authentication</label>
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" role="switch" id="usersManageCanLoginInput">
                                            <label for="usersManageCanLoginInput" class="form-label d-block">Can Login</label>
                                        </div>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label d-block">Business</label>
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" role="switch" id="usersManageCanViewBusinessInput">
                                            <label for="usersManageCanViewBusinessInput" class="form-label d-block">Can View</label>
                                        </div>
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" role="switch" id="usersManageCanEditBusinessInput">
                                            <label for="usersManageCanEditBusinessInput" class="form-label d-block">Can Edit</label>
                                        </div>
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" role="switch" id="usersManageCanDeleteBusinessInput">
                                            <label for="usersManageCanDeleteBusinessInput" class="form-label d-block">Can Delete</label>
                                        </div>
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" role="switch" id="usersManageCanAddBusinessInput">
                                            <label for="usersManageCanAddBusinessInput" class="form-label d-block">Can Add</label>
                                        </div>
                                    </div>
                                </div>
                                <!-- Analytics -->
                                <div class="tab-pane fade w-100" id="users-manage-analytics" role="tabpanel" aria-labelledby="users-manage-analytics-tab" tabindex="0">
                                    analytics
                                </div>
                                <!-- Businesses -->
                                <div class="tab-pane fade w-100" id="users-manage-businesses" role="tabpanel" aria-labelledby="users-manage-businesses-tab" tabindex="0">
                                    businesses
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

