                dataType: "json",
                data: {
                    page: BussinessPage,
                    max: MaxBussinessPerPage
                },
                success: (response) => {
                    if (!response.success)
                    {
                        alert(response.message);
                        return;
                    }

                    successCallback(response.data);
                },
                error: (error) => {
                    console.log(error);
                }
            });
        }

        $(document).ready(() => {
