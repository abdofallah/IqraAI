            // Conversations Permissions
            SetPermissionInput(businessPermissionsConversationInboundDisableFullInput, businessPermissionsConversationInboundDisableFullReasonInput, permissions.conversations.inbound.disabledFullAt, permissions.conversations.inbound.disabledFullReason);
            SetPermissionInput(businessPermissionsConversationInboundDisableExporting, businessPermissionsConversationInboundDisableExportingReasonInput, permissions.conversations.inbound.disabledExportingAt, permissions.conversations.inbound.disabledExportingReason);
            SetPermissionInput(businessPermissionsConversationInboundDisableDeleting, businessPermissionsConversationInboundDisableDeletingReasonInput, permissions.conversations.inbound.disabledDeletingAt, permissions.conversations.inbound.disabledDeletingReason);

