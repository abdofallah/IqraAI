            SetPermissionInput(businessPermissionsConversationWebsocketDisableFullInput, businessPermissionsConversationWebsocketDisableFullReasonInput, permissions.conversations.websocket.disabledFullAt, permissions.conversations.websocket.disabledFullReason);
            SetPermissionInput(businessPermissionsConversationWebsocketDisableExporting, businessPermissionsConversationWebsocketDisableExportingReasonInput, permissions.conversations.websocket.disabledExportingAt, permissions.conversations.websocket.disabledExportingReason);
