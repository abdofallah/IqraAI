        <!-- Phone Numbers Container -->
        <div class="main-container fade w-100 d-none" id="phone-numbers-tab">
            <h3 class="fw-bold tab-title"><i class='fa-regular fa-gear nav_icon'></i> <span>Settings</span></h3>
            <div class="inner-container">
                <h6>Ah! This page is currently under development.</h6>
            </div>
        </div>

        <!-- Billing Container -->
        <div class="main-container fade w-100 d-none" id="billing-tab">
            <h3 class="fw-bold tab-title"><i class='fa-regular fa-credit-card nav_icon'></i> <span>Billing</span></h3>
            <div class="inner-container">
                <h6>Ah! This page is currently under development.</h6>
            </div>
        </div>

        <!-- Settings Container -->
        <div class="main-container fade w-100 d-none" id="settings-tab">
            <h3 class="fw-bold tab-title"><i class='fa-regular fa-gear nav_icon'></i> <span>Settings</span></h3>
            <div class="inner-container">
                <h6>Ah! This page is currently under development.</h6>
            </div>
        </div>
    </div>

    <!-- libs -->
    <script src="~/js/jquery-3.7.1.min.js"></script>
    <script src="~/libs/bootstrap-5.3.3-dist/js/bootstrap.bundle.min.js"></script>

    <!-- Custom Scripts -->
    <script src="~/js/script.js"></script>

    <!-- Users Tab -->
    <script>
        var UsersPage = 0;
        var MaxUsersPerPage = 30;

        const usersListTable = $("#usersListTable");
        const usersListTableTab = $("#usersListTableTab");
        const usersManageTab = $("#usersManageTab");

        function FetchUsersFromAPI(successCallback) {
            $.ajax({
                url: '/app/admin/users',
                type: 'POST',
                dataType: "json",
                data: {
                    page: UsersPage,
                    max: MaxUsersPerPage
                },
                success: (response) => {
                    if (!response.success)
                    {
                        alert(response.message);
                        return;
                    }

                    successCallback(response.data);
                },
                error: (error) => {
                    console.log(error);
                }
            });
        }

        function CreateUsersListTableElement(userData) {
            let element = $(`<tr>
                <td>${userData.email}</td>
                <td>${userData.firstName} ${userData.lastName}</td>
                <td>${userData.businesses.length}</td>
                <td>
                    <button class="btn btn-info btn-sm">
                        <i class="fa-regular fa-pen-to-square"></i>
                    </button>
                    <button class="btn btn-danger btn-sm">
                        <i class="fa-regular fa-trash"></i>
                    </button>
                </td>
            </tr>`);

            return element;
        }

        $(document).ready(() => {
            // Init

            FetchUsersFromAPI((users) => {
                users.forEach((userData) => {
                    usersListTable.append(CreateUsersListTableElement(userData));
                });
            });

        });
    </script>

    <!-- Businesses Tab -->
    <script>
        var BussinessPage = 0;
        var MaxBussinessPerPage = 30;

        function FetchBusinessesFromAPI(successCallback) {
            $.ajax({
                url: '/app/admin/businesses',
                type: 'POST',
                dataType: "json",
                data: {
                    page: BussinessPage,
                    max: MaxBussinessPerPage
                },
                success: (response) => {
                    if (!response.success)
                    {
                        alert(response.message);
                        return;
                    }

                    successCallback(response.data);
                },
                error: (error) => {
                    console.log(error);
                }
            });
        }

        $(document).ready(() => {
            // Init

            FetchBusinessesFromAPI((businesses) => {
                console.log(businesses);

                businesses.forEach((businessData) => {
                    console.log(businessData);
                });
            });
        });
    </script>
