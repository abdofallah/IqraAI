        var AlertManager = new BootstrapAlertManager();

        const CurrentBusinessId = GetIdFromURLPath();

        var BusinessFullData = null;

        // API Related Functions

        function FetchBusinessDataFromAPI(businessId, successCallback, errorCallback)
        {
            $.ajax({
                url: '/app/user/business/' + businessId,
                type: 'POST',
                success: (response) => {
                    if (!response.success) {
                        errorCallback(response);
                        return;
                    }

                    successCallback(response.data);
                },
                error: (error) => {
                    errorCallback(error);
                }
            });
        }
    </script>

    <!-- New Business Tutorial -->
    <script>
        async function InitalizeNewBusinessTutorial() {
            let hasUserAsked = false;
            let currentMessage = null;
            let chatPopup;

            async function onUserMessageBusinessTutorial(message) {
                hasUserAsked = true;
                currentMessage = message;
                
                // Handle user question
                await handleUserQuestion(message);
            }

            async function handleUserQuestion(question) {
                // Here you would implement logic to answer the user's question
                // For now, we'll just echo the question back
                await chatPopup.SendResponseMessage(`You asked: "${question}". [Your answer here]`, 1000);
                
                // After answering, remind the user to continue with the tutorial
                if (chatPopup.continueButtonVisible) {
                    await chatPopup.SendResponseMessage("Don't forget to select a language and click 'Continue' when you're ready to move on.", 1000);
                }
            }

            async function sendTutorialMessage(message, delay, startDelay, disableInput = true) {
                await chatPopup.SendResponseMessage(message, delay, startDelay);
                chatPopup.disableInputState(disableInput);
            }

            async function sendTutorialMessageWithContinue(message, delay, startDelay, continueButtonText = 'Continue', validationFunc = null) {
                await chatPopup.SendResponseMessageWithContinue(message, delay, startDelay, continueButtonText, validationFunc);
            }

            function startSettingsTutorial() {
                $(".nav_list .nav_link").addClass("disabled");
                $(".nav_list .nav_link[for='settings-tab']").removeClass("disabled").click();
                $("#settings-tab #settings-inner-tab #settings-inner-languages-tab").click();
            }

            var tutorialConfirmDialog = new BootstrapConfirmDialog(
                {
                    title: 'Getting Started Tutorial',
                    message: 'Would you like Iqra AI to help you get started and get familar with the Iqra platform?<br><br>Iqra will guide you using through a chat-interface to set-up the necessary before you can create the agents for calls.',
                    confirmText: 'Yes please!',
                    cancelText: 'No, I got this!', 
                    confirmButtonClass: 'btn-success',
                    modalClass: '',
                }
            );
            
            var tutorialConfirmDialogResult = await tutorialConfirmDialog.show();
            if (!tutorialConfirmDialogResult) {
                return;
            }

            chatPopup = new ModernChatPopup('tutorialChatPopupContainer', {
                headerText: 'Getting Started',
                sendButtonText: 'Ask',
                placeholderText: 'Ask IqraAI for more explanation.',
                onUserMessage: onUserMessageBusinessTutorial
            }); 
            
            startSettingsTutorial();

            await sendTutorialMessage('Hey 👋!', 1000, 100);
            await sendTutorialMessage('My name is Iqra.', 1300);
            await sendTutorialMessage('I am here to help you get familiar with the Iqra platform.', 1300);
            await sendTutorialMessage('If you have any questions, I will be here to answer them throughout the journey 😊.', 1300);

            await sendTutorialMessage('The first thing you need to do is set up your language preferences.', 2300);
            await sendTutorialMessage('Since Iqra is the only platform with full multi-language support, we found that it is best to add all your preferred languages at the very beginning so before adding any business information, you may enable the languages you require.', 4000);
            await sendTutorialMessage('Remember, this language tab is only to enable languages for the business. You may specify the languages that are allowed for inbound calls in routings and outbound calls when making a call 😉.', 4000, 8000);

            async function validateLanguageSelection() {
                if ($("#settingsLanguageAddSelect").val() === "none") {
                    await sendTutorialMessage('Please make sure to select a language before continuing.', 2000);
                    return false;
                }
                return true;
            }

            await sendTutorialMessageWithContinue(
                'Add your very first language which would be your default, and add multiple languages if you have more than one. If you have any questions, feel free to ask!', 
                2000, 
                7000, 
                'Continue', 
                validateLanguageSelection
            );

            await sendTutorialMessage('Great! Now let\'s move on to the next step.', 1300);
        }
    </script>

