    <script>
        function GetIdFromURLPath() {
            let urlPath = window.location.pathname;

            if (urlPath.endsWith("/")) {
                urlPath = urlPath.substring(0, urlPath.length - 1);
            }

            return urlPath.split("/").pop();
        }

        function SetPermissionInput(checkboxElement, reasonInputElement, disabledAt, disabledReason) {
            if (disabledAt) {
                checkboxElement.prop("checked", true).change();
                if (disabledReason) {
                    reasonInputElement.val(disabledReason);
                }
            } else {
                checkboxElement.prop("checked", false).change();
                reasonInputElement.val("");
            }
        }

        function EnableFullPermissionHelper(enableFullElement, subEnableElementsArray) {
            enableFullElement.on("change", (event) => {
                event.preventDefault();
                event.stopPropagation();

                let current = $(event.currentTarget);

                let isChecked = current.is(':checked');
                if (isChecked) {
                    subEnableElementsArray.forEach((element) => {
                        element.prop("disabled", false).change();
                    })
                    enableFullElement.parent().parent().find("input[type=text]").removeClass("d-none");
                }
                else {
                    subEnableElementsArray.forEach((element) => {
                        element.prop("checked", false).prop("disabled", true).change();
                    });
                    enableFullElement.parent().parent().find("input[type=text]").val("").addClass("d-none");
                }
            });
        }
    </script>

