<html data-bs-theme="dark">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Dashboard | Iqra AI</title>

    <link href="~/libs/bootstrap-5.3.3-dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/libs/fontawesome-pro-6.5.1-web-dist/css/fontawesome.min.css" rel="stylesheet">
    <link href="~/libs/fontawesome-pro-6.5.1-web-dist/css/regular.min.css" rel="stylesheet">

    <link href="~/css/structure.css" rel="stylesheet">
    <link href="~/css/style.css" rel="stylesheet">

    <link rel="icon" type="image/png" href="/img/favicon/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/img/favicon/favicon.svg" />
    <link rel="shortcut icon" href="/img/favicon/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/img/favicon/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="Iqra" />
    <link rel="manifest" href="/img/favicon/site.webmanifest" />

    <style id="dynamicCSS"></style>
    <style id="dynamicBusinessCardH4CSS"></style>
</head>

<body id="body-pd" class="body-pd">
    <div id="page-loader">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>

    <header class="header header-body-pd" id="header">
        <div class="header_toggle"> <i class='fa-regular fa-bars fa-bars' id="header-toggle"></i> </div>
    </header>

    <!-- Sidebar -->
    <div class="l-navbar show" id="nav-bar">
        <nav class="nav">
            <div class="upper-navigation">
                <a href="/" class="nav_logo">
                    <img class="nav_logo-icon" src="~/img/logo/logo-colored-light.png">
                </a>
                <div class="nav_list">
                    <a class="nav_link active" for="business-tab">
                        <i class='fa-regular fa-briefcase nav_icon'></i>
                        <span class="nav_name">Businesses</span>
                    </a>
                    <a class="nav_link" for="billing-tab">
                        <i class='fa-regular fa-credit-card nav_icon'></i>
                        <span class="nav_name">Billing & Usage</span>
                    </a>
                    <a class="nav_link disabled mb-0" for="settings-tab">
                        <i class='fa-regular fa-gear nav_icon'></i>
                        <span class="nav_name">Settings</span>
                    </a>
                </div>
            </div>
            <div class="bottom-navigation">
                <a href="/logout" class="nav_link mt-0">
                    <i class='fa-regular fa-right-from-bracket nav_icon'></i>
                    <span class="nav_name">Log out</span>
                </a>
            </div>
        </nav>
    </div>

    <!-- Main Container -->
    <div class="w-100 main-container-wrapper" id="tabs-list">
        <!-- Bussiness Container -->
        <div class="main-container fade show w-100" id="business-tab">
            <h3 class="fw-bold tab-title mb-3"><i class='fa-regular fa-briefcase'></i> <span>Businesses</span></h3>
            <div class="inner-container">
                <div class="mb-4 d-flex flex-row align-items-center justify-content-between" id="businessesListActions">
                    <button id="AddNewBusinessButton" style="min-width: 200px" class="mb-0 text-decoration-none fw-bold btn btn-primary me-4" data-bs-toggle="modal" data-bs-target="#addNewBusinessModal" disabled>
                        <span>+ Add New Business</span>
                    </button>
                    <div class="input-group w-100">
                        <input type="text" class="form-control" placeholder="Business Name" aria-label="Business Name" aria-describedby="searchBusinessButton" id="searchBusinessInput" disabled>
                        <button class="input-group-button btn btn-primary" id="searchBusinessButton" disabled>
                            <i class='fa-regular fa-magnifying-glass'></i>
                        </button>
                    </div>
                </div>
                <div class="row" id="BusinessesList">
                    <!-- Dynamically Generated -->
                </div>
            </div>
        </div>

        <!-- Billing & Usage Container -->
        <div class="main-container fade w-100 d-none" id="billing-tab">
            <h3 class="fw-bold tab-title mb-3"><i class='fa-regular fa-credit-card nav_icon'></i> <span>Billing & Usage</span></h3>
            <div class="inner-container">
                <!-- Main Navigation for Billing & Usage -->
                <nav class="mb-4">
                    <ul class="nav" id="billing-inner-tabs" role="tablist">
                        <li class="nav-item me-2" role="presentation">
                            <button class="nav-link active" id="nav-overview-tab" data-bs-toggle="tab" data-bs-target="#nav-overview" type="button" role="tab" aria-selected="true">Overview</button>
                        </li>
                        <li class="nav-item me-2" role="presentation">
                            <button class="nav-link" id="nav-usage-tab" data-bs-toggle="tab" data-bs-target="#nav-usage" type="button" role="tab" aria-selected="false">Usage Details</button>
                        </li>
                        <li class="nav-item me-2" role="presentation">
                            <button class="nav-link" id="nav-method-tab" data-bs-toggle="tab" data-bs-target="#nav-method" type="button" role="tab" aria-selected="false">Payment Methods</button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="nav-history-tab" data-bs-toggle="tab" data-bs-target="#nav-history" type="button" role="tab" aria-selected="false">Billing History</button>
                        </li>
                    </ul>
                </nav>

                <div class="tab-content w-100" id="billing-inner-tabContent">
                    <!-- 1. Overview Tab -->
                    <div class="tab-pane fade show active" id="nav-overview" role="tabpanel" aria-labelledby="nav-overview-tab">
                        <div class="row">
                            <!-- Column 1: Balance and Plan -->
                            <div class="col-lg-7 col-md-12">
                                <!-- Current Balance Card -->
                                <div class="card mb-4">
                                    <div class="card-body">
                                        <h5 class="card-title">Current Balance</h5>
                                        <!-- Main credit balance -->
                                        <h2 class="fw-bold display-5 text-success mb-1">${{userBilling.creditBalance}}</h2>
                                        <!-- Unpaid Overage Balance (conditional) -->
                                        <!-- if (userBilling.unpaidOverageBalance > 0) { -->
                                        <div class="alert alert-warning d-flex justify-content-between align-items-center">
                                            <span>Outstanding Overage: ${{userBilling.unpaidOverageBalance}}</span>
                                            <button class="btn btn-warning btn-sm">Pay Now</button>
                                        </div>
                                        <!-- } -->
                                        <button class="btn btn-primary w-100 mt-2">
                                            <i class="fa-solid fa-plus me-1"></i> Add Funds
                                        </button>
                                    </div>
                                </div>

                                <!-- Current Plan Card -->
                                <div class="card mb-4">
                                    <div class="card-body">
                                        <div class="d-flex justify-content-between align-items-center mb-3">
                                            <h5 class="card-title mb-0">Current Plan</h5>
                                            <button class="btn btn-outline-secondary btn-sm">Change Plan</button>
                                        </div>
                                        <!-- Plan Name -->
                                        <h4 class="fw-bold">{{plan.name}}</h4>
                                        <p class="text-muted">Next bill on {{subscription.currentPeriodEnd | date}} for ${{plan.monthlyPrice}}</p>

                                        <!-- Plan-specific details section -->
                                        <!-- if (plan.type === 'FixedPackage') { -->
                                        <div class="mt-3">
                                            <label class="form-label">Monthly Included Minutes</label>
                                            <div class="progress" style="height: 20px;">
                                                <div class="progress-bar" role="progressbar" style="width: {{usage.minutesUsed / plan.includedMinutes * 100}}%;" aria-valuenow="{{usage.minutesUsed}}" aria-valuemin="0" aria-valuemax="{{plan.includedMinutes}}">
                                                    {{usage.minutesUsed}} / {{plan.includedMinutes}}
                                                </div>
                                            </div>
                                            <small class="form-text text-muted mt-1">Overage: ${{plan.overageMinutePrice}} per minute.</small>
                                        </div>
                                        <!-- } else if (plan.type === 'Standard' || plan.type === 'VolumeTiered') { -->
                                        <div class="mt-3">
                                            <p>
                                                Your current price is <strong>${{plan.effectiveMinutePrice}} per minute</strong>.
                                                <!-- Optional: message for volume plans -->
                                                <small class="d-block text-muted">Your rate gets lower with higher usage.</small>
                                            </p>
                                        </div>
                                        <!-- } -->
                                    </div>
                                </div>
                            </div>

                            <!-- Column 2: Concurrency and Auto-Refill -->
                            <div class="col-lg-5 col-md-12">
                                <!-- Concurrency Card -->
                                <div class="card mb-4">
                                    <div class="card-body">
                                        <h5 class="card-title">Concurrency</h5>
                                        <h3 class="fw-bold">{{plan.baseConcurrency + userBilling.additionalConcurrencySlots.length}} Total Slots</h3>
                                        <p class="text-muted mb-3">{{plan.baseConcurrency}} from plan + {{userBilling.additionalConcurrencySlots.length}} purchased</p>

                                        <h6 class="fw-bold">Purchased Slots</h6>
                                        <!-- Loop through additional slots -->
                                        <ul class="list-group list-group-flush">
                                            <!-- if (userBilling.additionalConcurrencySlots.length === 0) { -->
                                            <li class="list-group-item">No additional slots purchased.</li>
                                            <!-- } else { loop over slots -->
                                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                                <div>Renews on {{slot.nextBillingDate | date}}</div>
                                                <span class="badge bg-primary rounded-pill">${{slot.priceWhenPurchased}}/mo</span>
                                                <button class="btn btn-outline-danger btn-sm p-1">
                                                    <i class="fa-solid fa-xmark"></i>
                                                </button>
                                            </li>
                                            <!-- } -->
                                        </ul>
                                        <button class="btn btn-outline-primary btn-sm w-100 mt-3">Buy More Slots</button>
                                    </div>
                                </div>

                                <!-- Auto Refill Card -->
                                <div class="card mb-4">
                                    <div class="card-body">
                                        <div class="d-flex justify-content-between align-items-center mb-2">
                                            <h5 class="card-title mb-0">Auto-Refill</h5>
                                            <div class="form-check form-switch">
                                                <input class="form-check-input" type="checkbox" role="switch" id="autoRefillSwitch" {{userBilling.autoRefill.status= = ='Enabled' ? 'checked' : '' }}>
                                            </div>
                                        </div>
                                        <!-- Conditional display based on switch -->
                                        <div id="autoRefillSettings" class="{{userBilling.autoRefill.status === 'Enabled' ? '' : 'd-none'}}">
                                            <p class="mb-1">When balance is below <strong>${{userBilling.autoRefill.refillWhenBalanceBelow}}</strong>, refill with <strong>${{userBilling.autoRefill.refillAmount}}</strong>.</p>
                                            <small class="text-muted">Using Visa •••• 1539</small>
                                        </div>
                                        <button class="btn btn-outline-secondary btn-sm w-100 mt-3">Edit Settings</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- 2. Usage Details Tab -->
                    <div class="tab-pane fade" id="nav-usage" role="tabpanel" aria-labelledby="nav-usage-tab">
                        <div class="card">
                            <div class="card-body">
                                <h5 class="card-title">Usage this Period ({{subscription.currentPeriodStart | date}} - {{subscription.currentPeriodEnd | date}})</h5>
                                <!-- A canvas for a chart library like Chart.js -->
                                <canvas id="usageChart"></canvas>
                                <p class="text-center text-muted mt-2">Chart showing daily minute usage.</p>
                            </div>
                        </div>
                    </div>

                    <!-- 3. Payment Methods Tab -->
                    <div class="tab-pane fade" id="nav-method" role="tabpanel" aria-labelledby="nav-method-tab">
                        <!-- This will be your existing payment method UI, with an "Add New Method" button -->
                        <div class="d-flex justify-content-end mb-3">
                            <button class="btn btn-primary"><i class="fa-solid fa-plus me-1"></i> Add New Method</button>
                        </div>
                        
                        <div class="row">
                            <div class="col-md-6 col-12">
                                <div class="billing-method-card d-flex flex-column align-items-center justify-content-center mb-2">
                                    <div class="d-flex flex-row align-items-center justify-content-between w-100 mb-3">
                                        <div class="method-type-icon icon-visa">
                                            <img src="~/img/visa-svgrepo-com.svg">
                                        </div>

                                        <button class="btn btn-outline-light" type="button" disabled>Primary</button>
                                    </div>
                                    <div class="d-flex flex-row align-items-center justify-content-between w-100 mb-3">
                                        <div>
                                            <h6 class="label">Card Number</h6>
                                            <h6>•••• •••• •••• 1539</h6>
                                        </div>

                                        <div>
                                            <h6 class="label">Expires</h6>
                                            <h6>04/24</h6>
                                        </div>

                                        <div>
                                            <h6 class="label">CVV</h6>
                                            <h6>•••</h6>
                                        </div>
                                    </div>
                                    <div class="d-flex flex-row align-items-center justify-content-between w-100">
                                        <div>
                                            <h6 class="label">Card Name</h6>
                                            <h6>John Doe</h6>
                                        </div>
                                    </div>
                                </div>
                                <div class="d-flex flex-row align-items-center justify-content-between w-100 payment-method-cards-buttons">
                                    <button class="btn btn-light w-100 me-3">
                                        <i class="fa-regular fa-trash"></i>
                                        <span>Delete</span>
                                    </button>

                                    <button class="btn btn-light w-100">
                                        <i class="fa-regular fa-pen-to-square"></i>
                                        <span>Edit</span>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- 4. Billing History Tab -->
                    <div class="tab-pane fade" id="nav-history" role="tabpanel" aria-labelledby="nav-history-tab">
                        <table class="table table-hover w-100" id="billing-history-table">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Description</th>
                                    <th>Amount</th>
                                    <th>Status</th>
                                    <th>Invoice</th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- Example Row: Subscription -->
                                <tr>
                                    <td>5/1/2024</td>
                                    <td>Monthly Subscription (Fixed Package)</td>
                                    <td>$50.00</td>
                                    <td><span class="badge bg-success">Paid</span></td>
                                    <td><a href="#" class="btn btn-sm btn-outline-secondary"><i class="fa-solid fa-download"></i> Download</a></td>
                                </tr>
                                <!-- Example Row: Top-up -->
                                <tr>
                                    <td>4/28/2024</td>
                                    <td>Credit Top-up</td>
                                    <td>$25.00</td>
                                    <td><span class="badge bg-success">Paid</span></td>
                                    <td><a href="#" class="btn btn-sm btn-outline-secondary"><i class="fa-solid fa-download"></i> Download</a></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Settings Container -->
        <div class="main-container fade w-100 d-none" id="settings-tab">
            <h3 class="fw-bold tab-title mb-3"><i class='fa-regular fa-gear nav_icon'></i> <span>Settings</span></h3>
            <div class="inner-container">
                <h6>Ah! This page is currently under development.</h6>
            </div>
        </div>

        <!-------------------
        
                MODALS
        
        --------------------->

        <!-- Add New Business Modal -->
        <div class="modal modal-lg fade" id="addNewBusinessModal" tabindex="-1" aria-labelledby="addNewBusinessModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="addNewBusinessModalLabel">Add New Business</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label for="addNewBusinessNameInput" class="form-label">Name</label>
                            <input type="text" class="form-control" id="addNewBusinessNameInput" placeholder="Business Name">
                        </div>
                        <div class="mb-3">
                            <label for="addNewBusinessLogoInput" class="form-label d-block">Logo</label>
                            <img src="~/img/picture_placeholder_light.png" class="rounded-3 image-fluid" id="addNewBusinessLogoPreview">
                            <input type="file" class="form-control d-none" id="addNewBusinessLogoInput" accept="image/png, image/gif, image/jpeg, image/webp">
                        </div>
                        <div>
                            <label for="addNewBusinessDefaultLanguageSelect" class="form-label">Default Language</label>
                            <select class="form-select" id="addNewBusinessDefaultLanguageSelect">
                                <option value="none" selected disabled>Select Language</option>
                                <!-- Dynamically Generated -->
                            </select>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-primary btn-ic-span-align" id="addNewBusinessButton" disabled>
                            <i class="fa-regular fa-plus"></i>
                            <span>Add</span>
                            <div class="spinner-border save-button-spinner d-none" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- ASP -->
        <script>
            const BusinessLogoURL = "@(TempData["BusinessLogoURL"])";
        </script>

        <!-- libs -->
        <script src="~/js/jquery-3.7.1.min.js"></script>
        <script src="~/libs/bootstrap-5.3.3-dist/js/bootstrap.bundle.js"></script>

        <!-- Custom Scripts -->
        <script src="~/js/countries_list.js"></script>
        <script src="~/js/alert_manager.js"></script>
        <script src="~/js/confirm_dialog.js"></script>
        <script src="~/js/script.js"></script>

        <!-- Variables -->
        <script>
            var isBusinessAnimationEnabled = true;
        </script>

        <!-- Global -->
        <script>
            var AlertManager = new BootstrapAlertManager();

            var SpecificationLanguagesListData = null;

            var CurrentUserBusinessPermission = null;

            var CurrentBusinessesList = null;

            // API Related Calls
            function FetchSpecificationLanguagesDataFromAPI(successCallback, errorCallback) {
                $.ajax({
                    url: '/app/specification/languages/',
                    type: 'POST',
                    success: (response) => {
                        if (!response.success) {
                            errorCallback(response);
                            return;
                        }

                        successCallback(response.data);
                    },
                    error: (error) => {
                        errorCallback(error);
                    }
                });
            }

            function FetchUserBusinessPermissionsFromAPI(successCallback, errorCallback) {
                $.ajax({
                    url: '/app/user/permissions/business',
                    type: 'POST',
                    dataType: "json",
                    success: (response) => {
                        if (!response.success) {
                            errorCallback(response);
                            return;
                        }

                        successCallback(response.data);
                    },
                    error: (error) => {
                        errorCallback(error);
                    }
                });
            }

            function FetchUserBusinessesFromAPI(successCallback, errorCallback) {
                $.ajax({
                    url: '/app/user/businesses',
                    type: 'POST',
                    dataType: "json",
                    success: (response) => {
                        if (!response.success) {
                            errorCallback(response);
                            return;
                        }

                        successCallback(response.data);
                    },
                    error: (error) => {
                        errorCallback(error);
                    }
                });
            }

            function AddNewUserBusinessToAPI(formData, successCallback, errorCallback) {
                $.ajax({
                    url: '/app/user/business/add',
                    type: 'POST',
                    data: formData,
                    dataType: "json",
                    processData: false,
                    contentType: false,
                    success: (response) => {
                        if (!response.success) {
                            errorCallback(response);
                            return;
                        }

                        successCallback(response.data);
                    },
                    error: (error) => {
                        errorCallback(error);
                    }
                });
            }
        </script>

        <!-- PageLoader -->
        <script>
            const pageLoader = $("#page-loader");

            var PageLoaderInterval = setInterval(
                () => {
                    if (
                        CurrentBusinessesList != null
                        &&
                        SpecificationLanguagesListData != null
                    ) {
                        clearInterval(PageLoaderInterval);

                        pageLoader.css("opacity", "0");
                        setTimeout(() => {
                            pageLoader.addClass("d-none");
                        }, 300);
                    }
                }
                , 100);

            function RunActionAfterBusinessesDataLoad(action) {
                var businessDataCheckInterval = setInterval(
                    () => {
                        if (CurrentBusinessesList != null) {
                            clearInterval(businessDataCheckInterval);
                            action();
                        }
                    }
                    , 100);
            }
        </script>

        <!-- Scripts -->
        <script src="~/scripts/app/index/businesses_tab.js"></script>

        <!-- Init -->
        <script>
            $(document).ready(() => {

                FetchSpecificationLanguagesDataFromAPI(
                    (specLanguagesDataResult) => {
                        SpecificationLanguagesListData = specLanguagesDataResult;

                        FetchUserBusinessPermissionsFromAPI(
                            (userBusinessPermission) => {

                                CurrentUserBusinessPermission = userBusinessPermission;

                                if (userBusinessPermission.disableBusinessesAt == null) {
                                    searchBusinessInput.prop("disabled", false);
                                    searchBusinessButton.prop("disabled", false);

                                    FetchUserBusinessesFromAPI(
                                        (userBusinesses) => {
                                            CurrentBusinessesList = userBusinesses;

                                            // Init The business Tab
                                            InitBusinessesTab();
                                        },
                                        (userBusinessesError) => {
                                            AlertManager.createAlert({
                                                type: "danger",
                                                message: "Error occured while fetching user businesses. Check browser console for logs.",
                                                enableDismiss: false,
                                            });

                                            console.error("Error occured while fetching user businesses: ", userBusinessesError);
                                        },
                                    );
                                } else {
                                    CurrentBusinessesList = [];

                                    let alertMessage = "Bussiness Viewing, Adding, Editing and Deleting are disabled for your account.";
                                    if (userBusinessPermission.disableBusinessesReason != null) {
                                        alertMessage = `${alertMessage}<br>Reason: ${userBusinessPermission.disableBusinessesReason}`;
                                    } else {
                                        alertMessage = `${alertMessage}<br>Please contact support for more information.`;
                                    }

                                    AlertManager.createAlert({
                                        type: "danger",
                                        message: alertMessage,
                                        enableDismiss: false,
                                    });
                                }

                                if (userBusinessPermission.addBusinessDisabledAt != null || userBusinessPermission.disableBusinessesAt != null) {
                                    if (userBusinessPermission.disableBusinessesAt == null) {
                                        let alertMessage = "Bussiness Adding is disabled for your account.";

                                        if (userBusinessPermission.addBusinessDisableReason != null) {
                                            alertMessage = `${alertMessage}<br>Reason: ${userBusinessPermission.addBusinessDisableReason}`;
                                        } else {
                                            alertMessage = `${alertMessage}<br>Please contact support for more information.`;
                                        }

                                        AlertManager.createAlert({
                                            type: "danger",
                                            message: alertMessage,
                                            enableDismiss: false,
                                        });
                                    }
                                } else {
                                    AddNewBusinessButton.prop("disabled", false);
                                }

                                if (userBusinessPermission.editBusinessDisabledAt != null || userBusinessPermission.disableBusinessesAt != null) {
                                    if (userBusinessPermission.disableBusinessesAt == null) {
                                        let alertMessage = "Bussiness Editing is disabled for your account.";

                                        if (userBusinessPermission.editBusinessDisableReason != null) {
                                            alertMessage = `${alertMessage}<br>Reason: ${userBusinessPermission.editBusinessDisableReason}`;
                                        } else {
                                            alertMessage = `${alertMessage}<br>Please contact support for more information.`;
                                        }

                                        AlertManager.createAlert({
                                            type: "danger",
                                            message: alertMessage,
                                            enableDismiss: false,
                                        });
                                    }
                                }

                                if (userBusinessPermission.deleteBusinessDisableAt != null || userBusinessPermission.disableBusinessesAt != null) {
                                    if (userBusinessPermission.disableBusinessesAt == null) {
                                        let alertMessage = "Bussiness Deleting is disabled for your account.";

                                        if (userBusinessPermission.deleteBusinessDisableReason != null) {
                                            alertMessage = `${alertMessage}<br>Reason: ${userBusinessPermission.deleteBusinessDisableReason}`;
                                        } else {
                                            alertMessage = `${alertMessage}<br>Please contact support for more information.`;
                                        }

                                        AlertManager.createAlert({
                                            type: "danger",
                                            message: alertMessage,
                                            enableDismiss: false,
                                        });
                                    }
                                }
                            },
                            (userBusinessPermissionError) => {
                                AlertManager.createAlert({
                                    type: "danger",
                                    message: "Error occured while fetching user businesses. Check browser console for logs.",
                                    enableDismiss: false,
                                });

                                console.error("Error occured while fetching user businesses: ", userBusinessPermissionError);
                            },
                        );
                    },
                    (specLanguagesListError) => {
                        AlertManager.createAlert({
                            type: "danger",
                            message: "Error occured while fetching specification languages. Check browser console for logs.",
                            enableDismiss: false,
                        });

                        console.error("Error occured while fetching specification languages: ", specLanguagesListError);
                    }
                ); 
            });
