<div class="main-container fade w-100 d-none" id="billing-tab">
    <h3 class="fw-bold tab-title mb-3"><i class='fa-regular fa-credit-card nav_icon'></i> <span>Billing</span></h3>

    <!-- Main Navigation Header -->
    <div class="inner-header-container w-100 mb-3" id="billing-header">
        <!-- Main Navigation for Billing -->
        <ul class="nav" id="billing-inner-tabs" role="tablist">
            <li class="nav-item me-2" role="presentation">
                <button class="nav-link active" id="billing-overview-tab" data-bs-toggle="tab" data-bs-target="#billing-overview" type="button" role="tab" aria-selected="true">Overview</button>
            </li>
            <li class="nav-item me-2" role="presentation">
                <button class="nav-link" id="payment-methods-tab-button" data-bs-toggle="pill" data-bs-target="#payment-methods-content" type="button" role="tab" aria-controls="payment-methods-content" aria-selected="false">Payment Methods</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="billing-history-tab" data-bs-toggle="tab" data-bs-target="#billing-history" type="button" role="tab" aria-selected="false">Billing History</button>
            </li>
        </ul>
    </div>

    <div class="inner-container">
        <div class="tab-content w-100" id="billing-inner-tabContent">
            <!-- Overview Tab -->
            <div class="tab-pane fade show active" id="billing-overview" role="tabpanel" aria-labelledby="billing-overview-tab">

                <!-- Card 1: Balance & Plan Summary -->
                <div class="card mb-4">
                    <div class="card-body d-flex flex-column flex-md-row p-0">
                        <!-- Left Side: Balance -->
                        <div class="p-4 w-100 w-md-50 d-flex flex-column justify-content-between">
                            <div>
                                <h5 class="card-title m-0">Current Balance</h5>
                                <!-- The color of this text will be changed by JS based on value -->
                                <h2 class="fw-bold display-5 my-3" id="balanceValue">$0.00</h2>
                            </div>
                            <button class="btn btn-primary w-100 m-0" id="addFundsBtn" data-bs-toggle="modal" data-bs-target="#addFundsModal">
                                <i class="fa-solid fa-plus me-1"></i> Add Funds
                            </button>
                        </div>
                        <!-- Right Side: Plan Summary (Simplified) -->
                        <div class="p-4 w-100 w-md-50 d-flex flex-column justify-content-between border-top border-md-top-0 border-md-start">
                            <div>
                                <h5 class="card-title m-0">Current Plan</h5>
                                <h4 class="fw-bold mt-3 mb-1" id="planName">Loading...</h4>
                                <p class="text-muted small mb-0" id="planDescription">...</p>
                            </div>
                            <div class="mt-3">
                                <p class="mb-1" id="planNextBill">...</p>
                                <a href="#" id="changePlanLink" class="btn btn-outline-secondary btn-sm disabled">Change Plan</a> <!-- Disabled for now -->
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Plan Usage -->
                <div class="mb-4">
                    <!-- Table 1: Usage-Based Features -->
                    <div class="table-responsive mb-3">
                        <table class="table mb-0" id="planUsageTable">
                            <thead>
                                <tr>
                                    <th scope="col" class="ps-3">Usage-Based Features</th>
                                    <th scope="col">Included</th>
                                    <th scope="col">Cost</th>
                                    <th scope="col" style="min-width: 250px;">Usage This Cycle</th>
                                </tr>
                            </thead>
                            <tbody id="planUsageTableBody">
                                <!-- Dynamically populated usage rows -->
                            </tbody>
                        </table>
                    </div>

                    <!-- Table 2: Recurring Features -->
                    <div class="table-responsive">
                        <table class="table mb-0" id="planRecurringFeaturesTable">
                            <thead>
                                <tr>
                                    <th scope="col" class="ps-3">Recurring Features</th>
                                    <th scope="col">Included in Plan</th>
                                    <th scope="col">Purchased Add-ons</th>
                                    <th scope="col" style="min-width: 250px;">Usage</th>
                                    <th scope="col" class="pe-3">Actions</th>
                                </tr>
                            </thead>
                            <tbody id="planRecurringFeaturesTableBody">
                                <!-- Dynamically populated recurring feature rows -->
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Card 3: Auto-Refill -->
                <div class="card mb-4">
                    <div class="card-body d-flex justify-content-between align-items-center">
                        <div>
                            <h5 class="card-title mb-0">Auto-Refill</h5>
                            <div id="autoRefillSettings" class="d-none">
                                <p class="mb-1 mt-2" id="autoRefillDetailsText">...</p>
                                <small class="text-muted" id="autoRefillPaymentMethod">...</small>
                            </div>
                        </div>
                        <div class="d-flex align-items-center">
                            <div class="form-check form-switch me-3">
                                <input class="form-check-input" type="checkbox" role="switch" id="autoRefillSwitch" style="transform: scale(1.4);">
                            </div>
                            <button class="btn btn-outline-secondary btn-sm" id="editAutoRefillBtn" data-bs-toggle="modal" data-bs-target="#editAutoRefillModal">Edit Settings</button>
                        </div>
                    </div>
                </div>

            </div>

            <!-- Payment Methods Tab -->
            <div class="tab-pane fade" id="payment-methods-content" role="tabpanel" aria-labelledby="payment-methods-tab-button">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h4 class="mb-0">Saved Payment Methods</h4>
                    <button class="btn btn-primary" id="addNewPaymentMethodBtn">
                        <i class="fa-solid fa-plus me-1"></i> Add New Method
                    </button>
                </div>

                <div id="paymentMethodsContainer" class="row gx-4 gy-4">
                    <!-- Loading State -->
                    <div class="col-12 text-center p-5" id="paymentMethodsLoading">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                        <p class="mt-2 text-muted">Loading payment methods...</p>
                    </div>

                    <!-- Empty State (template) -->
                    <div class="col-12 text-center p-5 d-none" id="paymentMethodsEmpty">
                        <h5 class="text-muted">No Payment Methods Saved</h5>
                        <p>Add a new method to get started with subscriptions and auto-refill.</p>
                    </div>

                    <!-- Dynamic payment method cards will be inserted here -->
                </div>
            </div>

            <!-- Billing History Tab -->
            <div class="tab-pane fade" id="billing-history" role="tabpanel" aria-labelledby="billing-history-tab">
                <table class="table table-hover w-100" id="billing-history-table">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Description</th>
                            <th>Amount</th>
                            <th>Status</th>
                            <th>Invoice</th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- Example Row: Subscription -->
                        <tr>
                            <td>5/1/2024</td>
                            <td>Monthly Subscription (Fixed Package)</td>
                            <td>$50.00</td>
                            <td><span class="badge bg-success">Paid</span></td>
                            <td><a href="#" class="btn btn-sm btn-outline-secondary"><i class="fa-solid fa-download"></i> Download</a></td>
                        </tr>
                        <!-- Example Row: Top-up -->
                        <tr>
                            <td>4/28/2024</td>
                            <td>Credit Top-up</td>
                            <td>$25.00</td>
                            <td><span class="badge bg-success">Paid</span></td>
                            <td><a href="#" class="btn btn-sm btn-outline-secondary"><i class="fa-solid fa-download"></i> Download</a></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- ========================================================================= -->
    <!-- BILLING MODALS -->
    <!-- ========================================================================= -->

    <!-- Modal Add Funds -->
    <div class="modal fade" id="addFundsModal" tabindex="-1" aria-labelledby="addFundsModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="addFundsModalLabel">Add Funds to Balance</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="addFundsAmountInput" class="form-label">Amount (USD)</label>
                        <input type="number" class="form-control" id="addFundsAmountInput" placeholder="e.g., 25.00" min="5.00" step="0.01">
                        <div id="addFundsMinAmountText" class="form-text">Minimum amount: $5.00</div>
                    </div>
                    <div>
                        <label for="addFundsPaymentMethodSelect" class="form-label">Payment Method</label>
                        <select class="form-select" id="addFundsPaymentMethodSelect">
                            <!-- Options populated by JS -->
                        </select>
                    </div>
                </div>
                <div class="modal-footer d-flex justify-content-between">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" id="addFundsConfirmBtn" disabled>Proceed to Pay</button>
                </div>
            </div>
        </div>
    </div>


    <!-- Modal Purchase Add-on (Generic & Reusable) -->
    <div class="modal fade" id="purchaseAddonModal" tabindex="-1" aria-labelledby="purchaseAddonModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="purchaseAddonModalLabel">Purchase Add-on</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <!-- This hidden input will store the feature key we are buying -->
                    <input type="hidden" id="purchaseAddonFeatureKey" value="">

                    <p id="purchaseAddonDescription" class="text-muted">Purchase additional units for this feature.</p>

                    <div class="mb-3">
                        <label for="purchaseAddonQuantityInput" class="form-label">Quantity</label>
                        <div class="input-group">
                            <input type="number" class="form-control" id="purchaseAddonQuantityInput" value="1" min="1" step="1">
                            <span class="input-group-text" id="purchaseAddonUnitText">units</span>
                        </div>
                    </div>

                    <div class="card bg-dark">
                        <div class="card-body">
                            <div id="purchaseAddonPricingLoading" class="text-center">
                                <div class="spinner-border spinner-border-sm" role="status">
                                    <span class="visually-hidden">Loading pricing...</span>
                                </div>
                                <span class="ms-2">Fetching pricing...</span>
                            </div>

                            <div id="purchaseAddonPricingDetails" class="d-none">
                                <div class="d-flex justify-content-between">
                                    <span>Price per unit (monthly):</span>
                                    <strong id="purchaseAddonPricePerUnitText"></strong>
                                </div>
                                <div class="d-flex justify-content-between">
                                    <span>Prorated cost per unit (for this month):</span>
                                    <strong id="purchaseAddonProratedCostText"></strong>
                                </div>
                                <hr class="my-2">
                                <div class="d-flex justify-content-between h5">
                                    <strong>Total for this month:</strong>
                                    <strong id="purchaseAddonTotalCostText"></strong>
                                </div>
                                <small class="text-muted" id="purchaseAddonMonthlyCostText"></small>
                            </div>
                        </div>
                    </div>

                    <div class="mt-3">
                        <label for="purchaseAddonPaymentMethodSelect" class="form-label">Payment Method</label>
                        <select class="form-select" id="purchaseAddonPaymentMethodSelect">
                            <!-- Options populated by JS -->
                        </select>
                    </div>
                </div>
                <div class="modal-footer d-flex justify-content-between">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" id="purchaseAddonConfirmBtn">
                        Confirm Purchase
                    </button>
                </div>
            </div>
        </div>
    </div>


    <!-- Modal Edit Auto-Refill -->
    <div class="modal fade" id="editAutoRefillModal" tabindex="-1" aria-labelledby="editAutoRefillModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="editAutoRefillModalLabel">Edit Auto-Refill Settings</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted">Automatically add funds to your balance when it drops below a certain amount.</p>
                    <div class="mb-3">
                        <label for="autoRefillThresholdInput" class="form-label">When balance drops below (USD)</label>
                        <input type="number" class="form-control" id="autoRefillThresholdInput" placeholder="e.g., 10.00" min="0" step="0.01">
                    </div>
                    <div class="mb-3">
                        <label for="autoRefillAmountInput" class="form-label">Refill with amount (USD)</label>
                        <input type="number" class="form-control" id="autoRefillAmountInput" placeholder="e.g., 50.00" min="1.00" step="0.01">
                    </div>
                    <div class="mb-3">
                        <label for="autoRefillPaymentMethodSelect" class="form-label">Using payment method</label>
                        <select class="form-select" id="autoRefillPaymentMethodSelect">
                            <!-- Options populated by JS -->
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" id="autoRefillSaveChangesBtn">Save Changes</button>
                </div>
            </div>
        </div>
    </div>
</div>