                <!-- Configuration Tab -->
                <div class="tab-pane fade w-100" id="telephony-campaign-manager-configuration" role="tabpanel" aria-labelledby="telephony-campaign-manager-configuration-tab" tabindex="0">
                    <div class="mb-3 p-3 border rounded bg-dark">
                        <div class="form-check form-switch">
                            <input type="checkbox" role="switch" class="form-check-input" id="telephony-campaign-retry-on-decline-check">
                            <label class="form-check-label" for="telephony-campaign-retry-on-decline-check">Enable Retry on Decline/Busy</label>
                        </div>
                        <div class="d-none fade mt-3" id="telephony-campaign-retry-on-decline-options">
                            <div class="row g-2 align-items-center">
                                <div class="col-auto">
                                    <label for="telephony-campaign-retry-decline-count-input" class="col-form-label">Retries:</label>
                                </div>
                                <div class="col-auto">
                                    <input type="number" class="form-control form-control-sm" id="telephony-campaign-retry-decline-count-input" value="3" min="1">
                                </div>
                                <div class="col-auto">
                                    <label for="telephony-campaign-retry-decline-delay-input" class="col-form-label">Delay:</label>
                                </div>
                                <div class="col-auto">
                                    <input type="number" class="form-control form-control-sm" id="telephony-campaign-retry-decline-delay-input" value="10" min="1">
                                </div>
                                <div class="col-auto">
                                    <select class="form-select form-select-sm" id="telephony-campaign-retry-decline-unit-select">
                                        <option value="0">Seconds</option>
                                        <option value="1" selected>Minutes</option>
                                        <option value="2">Hours</option>
                                        <option value="3">Days</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="mb-4 p-3 border rounded bg-dark">
                        <div class="form-check form-switch">
                            <input type="checkbox" role="switch" class="form-check-input" id="telephony-campaign-retry-on-miss-check">
                            <label class="form-check-label" for="telephony-campaign-retry-on-miss-check">Enable Retry on No Answer</label>
                        </div>
                        <div class="d-none fade mt-3" id="telephony-campaign-retry-on-miss-options">
                            <div class="row g-2 align-items-center">
                                <div class="col-auto">
                                    <label for="telephony-campaign-retry-miss-count-input" class="col-form-label">Retries:</label>
                                </div>
                                <div class="col-auto">
                                    <input type="number" class="form-control form-control-sm" id="telephony-campaign-retry-miss-count-input" value="3" min="1">
                                </div>
                                <div class="col-auto">
                                    <label for="telephony-campaign-retry-miss-delay-input" class="col-form-label">Delay:</label>
                                </div>
                                <div class="col-auto">
                                    <input type="number" class="form-control form-control-sm" id="telephony-campaign-retry-miss-delay-input" value="10" min="1">
                                </div>
                                <div class="col-auto">
                                    <select class="form-select form-select-sm" id="telephony-campaign-retry-miss-unit-select">
                                        <option value="0">Seconds</option>
                                        <option value="1" selected>Minutes</option>
                                        <option value="2">Hours</option>
                                        <option value="3">Days</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="telephony-campaign-pickup-delay-input">Pick up delay (ms)</label>
                        <input type="number" class="form-control" id="telephony-campaign-pickup-delay-input" value="0">
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="telephony-campaign-silence-notify-input">Notify on silence (ms)</label>
                        <input type="number" class="form-control" id="telephony-campaign-silence-notify-input" value="10000">
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="telephony-campaign-silence-end-input">End call on silence (ms)</label>
                        <input type="number" class="form-control" id="telephony-campaign-silence-end-input" value="30000">
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="telephony-campaign-max-call-time-input">Max call time (s)</label>
                        <input type="number" class="form-control" id="telephony-campaign-max-call-time-input" value="600">
                    </div>
                </div>

                <!-- Voicemail Detection Tab -->
                <div class="tab-pane fade w-100" id="telephony-campaign-manager-voicemail" role="tabpanel" aria-labelledby="telephony-campaign-manager-voicemail-tab" tabindex="0">
                    <div class="card card-body mb-4">
                        <div class="d-flex align-items-center justify-content-between">
                            <h6 class="mb-0">Voicemail Detection</h6>
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" role="switch" id="telephony-campaign-voicemail-is-enabled-check">
                                <label class="form-check-label" for="telephony-campaign-voicemail-is-enabled-check">Enable</label>
                            </div>
                        </div>
                    </div>
                    <div id="telephony-campaign-voicemail-settings-container" class="disabled-container">
                        <div class="card card-body mb-3">
                            <p class="fw-bold mb-2">Detection Timing & Method</p>
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label for="telephony-campaign-voicemail-initial-check-delay-ms-input" class="form-label">Initial Check Delay (ms)</label>
                                    <input type="number" class="form-control" id="telephony-campaign-voicemail-initial-check-delay-ms-input" value="1000" min="0">
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="telephony-campaign-voicemail-ml-check-duration-ms-range" class="form-label">ML Check Duration (ms)</label>
                                    <input type="range" class="form-range" id="telephony-campaign-voicemail-ml-check-duration-ms-range" min="1000" max="4000" step="100" value="1000">
                                    <div class="text-center small"><span id="telephony-campaign-voicemail-ml-check-duration-ms-value">1000</span> ms</div>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="telephony-campaign-voicemail-max-ml-check-tries-input" class="form-label">Max ML Check Tries</label>
                                    <input type="number" class="form-control" id="telephony-campaign-voicemail-max-ml-check-tries-input" value="2" min="1">
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="telephony-campaign-voicemail-vad-silence-threshold-ms-input" class="form-label">VAD Silence Threshold (ms)</label>
                                    <input type="number" class="form-control" id="telephony-campaign-voicemail-vad-silence-threshold-ms-input" value="1000" min="0">
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="telephony-campaign-voicemail-vad-max-speech-duration-ms-input" class="form-label">VAD Max Speech Duration (ms)</label>
                                    <input type="number" class="form-control" id="telephony-campaign-voicemail-vad-max-speech-duration-ms-input" value="4000" min="0">
                                </div>
                            </div>
                        </div>
                        <div class="card card-body mb-3">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" role="switch" id="telephony-campaign-voicemail-advanced-verification-check">
                                <label class="form-check-label" for="telephony-campaign-voicemail-advanced-verification-check">Enable Advanced Verification</label>
                            </div>
                            <div id="telephony-campaign-voicemail-advanced-verification-container" class="d-none mt-3">
                                <div class="row">
                                    <div class="col-12 col-md-6 mb-3 mb-md-0">
                                        <label class="form-label">STT for Transcription</label>
                                        <div id="telephony-campaign-voicemail-stt-integration-container"></div>
                                    </div>
                                    <div class="col-12 col-md-6 mb-0">
                                        <label class="form-label">LLM for Verification</label>
                                        <div id="telephony-campaign-voicemail-llm-integration-container"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="card card-body mb-3">
                            <p class="fw-bold mb-2">Action Triggers</p>
                            <div class="row">
                                <div class="col-12 col-md-6 mb-3 mb-md-0">
                                    <p class="fw-bold mb-2 small">Stop Agent Speaking Triggers</p>
                                    <div class="card">
                                        <div class="card-body">
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" id="telephony-campaign-stop-agent-on-ml-check">
                                                <label class="form-check-label" for="telephony-campaign-stop-agent-on-ml-check">After ML Check Success</label>
                                            </div>
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" id="telephony-campaign-stop-agent-on-vad-check">
                                                <label class="form-check-label" for="telephony-campaign-stop-agent-on-vad-check">After VAD Silence</label>
                                            </div>
                                            <div class="form-check mb-3">
                                                <input class="form-check-input" type="checkbox" id="telephony-campaign-stop-agent-on-llm-check">
                                                <label class="form-check-label" for="telephony-campaign-stop-agent-on-llm-check">After LLM Confirmation</label>
                                            </div>
                                            <label for="telephony-campaign-voicemail-stop-speaking-delay-input" class="form-label">Delay Action (ms)</label>
                                            <input type="number" class="form-control" id="telephony-campaign-voicemail-stop-speaking-delay-input" value="1000" min="0">
                                        </div>
                                    </div>
                                </div>
                                <div class="col-12 col-md-6 mb-0">
                                    <p class="fw-bold mb-2 small">End Call / Leave Message Triggers</p>
                                    <div class="card">
                                        <div class="card-body">
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" id="telephony-campaign-end-leave-on-ml-check">
                                                <label class="form-check-label" for="telephony-campaign-end-leave-on-ml-check">After ML Check Success</label>
                                            </div>
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" id="telephony-campaign-end-leave-on-vad-check">
                                                <label class="form-check-label" for="telephony-campaign-end-leave-on-vad-check">After VAD Silence</label>
                                            </div>
                                            <div class="form-check mb-3">
                                                <input class="form-check-input" type="checkbox" id="telephony-campaign-end-leave-on-llm-check">
                                                <label class="form-check-label" for="telephony-campaign-end-leave-on-llm-check">After LLM Confirmation</label>
                                            </div>
                                            <label for="telephony-campaign-voicemail-end-leave-delay-input" class="form-label">Delay Action (ms)</label>
                                            <input type="number" class="form-control" id="telephony-campaign-voicemail-end-leave-delay-input" value="1000" min="0">
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="card card-body">
                            <p class="fw-bold mb-2">Final Action on Detect</p>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="telephony-campaign-final-action-radio" id="telephony-campaign-voicemail-end-call-radio" value="end" checked>
                                <label class="form-check-label" for="telephony-campaign-voicemail-end-call-radio">End Call</label>
