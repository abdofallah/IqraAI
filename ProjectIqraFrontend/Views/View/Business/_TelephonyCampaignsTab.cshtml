                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input type="checkbox" role="switch" class="form-check-input" id="telephony-campaign-agent-to-number-in-context-check" checked>
                            <label class="form-label mb-0" for="telephony-campaign-agent-to-number-in-context-check">Include 'To' Number in Context</label>
                        </div>
                    </div>
                </div>

                <!-- Number Route Tab -->
                <div class="tab-pane fade w-100" id="telephony-campaign-manager-numbers" role="tabpanel" aria-labelledby="telephony-campaign-manager-numbers-tab" tabindex="0">
                    <div class="mb-4 d-flex flex-row align-items-center justify-content-between">
                        <button class="btn btn-primary" id="telephony-campaign-add-region-route-button" data-bs-toggle="modal" data-bs-target="#telephony-campaign-add-region-modal"><span>+ Add Region Route</span></button>
