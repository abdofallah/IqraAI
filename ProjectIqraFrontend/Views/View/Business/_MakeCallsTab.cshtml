<div class="main-container fade d-none w-100" id="make-calls-tab">
    <h3 class="fw-bold tab-title mb-3"><i class='fa-regular fa-phone-arrow-up-right'></i> <span>Make Calls</span></h3> <!-- Changed Icon -->
    <div class="inner-header-container mb-3">
        <div class="d-flex flex-row align-items-center justify-content-between">
            <ul class="nav" id="make-call-simple-tab" role="tablist">
                <li class="nav-item me-2" role="presentation">
                    <button class="nav-link active" id="make-call-general-tab-btn" data-bs-toggle="pill" data-bs-target="#make-call-general" type="button" role="tab" aria-controls="make-call-general" aria-selected="true">General</button>
                </li>
                <li class="nav-item me-2" role="presentation">
                    <button class="nav-link" id="make-call-number-tab-btn" data-bs-toggle="pill" data-bs-target="#make-call-number" type="button" role="tab" aria-controls="make-call-number" aria-selected="true">Number</button>
                </li>
                <li class="nav-item me-2" role="presentation">
                    <button class="nav-link" id="make-call-configuration-tab-btn" data-bs-toggle="pill" data-bs-target="#make-call-configuration" type="button" role="tab" aria-controls="make-call-configuration" aria-selected="true">Configuration</button>
                </li>
                <li class="nav-item me-2" role="presentation">
                    <button class="nav-link" id="make-call-agent-tab-btn" data-bs-toggle="pill" data-bs-target="#make-call-agent" type="button" role="tab" aria-controls="make-call-agent" aria-selected="true">Agent</button>
                </li>
                <li class="nav-item me-2" role="presentation">
                    <button class="nav-link" id="make-call-actions-tab-btn" data-bs-toggle="pill" data-bs-target="#make-call-actions" type="button" role="tab" aria-controls="make-call-actions" aria-selected="true">Actions</button>
                </li>
            </ul>
            <!-- Added Reset Button (Optional) -->
            <div class="d-flex">
                <button class="btn btn-outline-secondary btn-ic-span-align me-2" id="makeCallResetButton">
                    <i class='fa-regular fa-arrows-rotate'></i>
                    <span> Reset</span>
                </button>
                <button class="btn btn-primary btn-ic-span-align" id="makeCallInitiateButton">
                    <!-- Added Spinner -->
                    <span class="spinner-border spinner-border-sm d-none me-1" role="status" aria-hidden="true"></span>
                    <i class='fa-regular fa-phone'></i>
                    <span> Initiate Call</span>
                </button>
            </div>
        </div>
    </div>
    <div class="inner-container">
        <div class="tab-content w-100" id="make-call-tabContent">
            <!-- General -->
            <div class="tab-pane fade w-100 show active" id="make-call-general" role="tabpanel" aria-labelledby="make-call-general-tab-btn" tabindex="0">
                <div class="mb-3">
                    <label class="form-label" for="makeCallIdentifierInput">Identifier</label>
                    <input type="text" class="form-control" id="makeCallIdentifierInput" placeholder="Call/Campaign Identifier">
                </div>
                <div class="mb-3">
                    <label class="form-label" for="makeCallDescriptionInput">Description</label>
                    <input type="text" class="form-control" id="makeCallDescriptionInput" placeholder="Call/Campaign Description">
                </div>
            </div>

            <!-- Number -->
            <div class="tab-pane fade w-100" id="make-call-number" role="tabpanel" aria-labelledby="make-call-number-tab-btn" tabindex="0">
                <div class="">
                    <label class="form-label btn-ic-span-align" for="editMakeCallTypeInput">
                        <span>Call Type </span>
                        <a href="#" class="d-inline-block" data-bs-toggle="tooltip" data-bs-placement="right" data-bs-html="true" data-bs-title="Choose 'Single' to call one number directly, or 'Bulk' to upload a CSV file for multiple calls.">
                            <i class="fa-regular fa-circle-question"></i>
                        </a>
                    </label>
                    <div class="row">
                        <div class="col-md-6 col-12 mb-3">
                            <div class="make-call-type-box-choose active" box-type="single">
                                <div class="info-icon">
                                    <i class="fa-regular fa-user"></i>
                                </div>
                                <div class="info-data">
                                    <h4>Single</h4>
                                    <p>Call only a single number</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 col-12 mb-3">
                            <div class="make-call-type-box-choose" box-type="bulk">
                                <div class="info-icon">
                                    <i class="fa-regular fa-user-group"></i>
                                </div>
                                <div class="info-data">
                                    <h4>Bulk</h4>
                                    <p>Call in bulk with a CSV file</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Single Number Container -->
                <div class="show fade" id="make-call-number-single-container">
                    <div class="mb-3">
                        <label class="form-label" for="makeCallSelectedFromNumber">
                            Call From Number
                        </label>
                        <div class="input-group">
                            <input type="text" class="form-control" id="makeCallSelectedFromNumber" placeholder="Select a number..." disabled>
                            <button class="btn btn-primary" id="makeCallChangeFromNumberButton" data-bs-toggle="modal" data-bs-target="#makeCallChangeFromNumberModal">
                                Select
                            </button>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="makeCallToNumberInput">Call To Number</label>
                        <input type="tel" class="form-control" id="makeCallToNumberInput" placeholder="Enter number with country code (e.g., +1xxxxxxxxx)"> <!-- Changed type to tel -->
                    </div>
                </div>
                <!-- Bulk Number Container -->
                <div class="d-none fade" id="make-call-number-bulk-container">
                    <div class="mb-3">
                        <label class="form-label" for="makeCallSelectedFromNumberBulk">
                            Call From Number (Used if not specified in CSV)
                        </label>
                        <div class="input-group">
                            <input type="text" class="form-control" id="makeCallSelectedFromNumberBulk" placeholder="Select a default 'from' number..." disabled>
                            <button class="btn btn-primary" id="makeCallChangeFromNumberButtonBulk" data-bs-toggle="modal" data-bs-target="#makeCallChangeFromNumberModal">
                                <!-- Reuses same modal -->
                                Select
                            </button>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label btn-ic-span-align" for="makeCallToNumberBulkInput">
                            <span>Numbers CSV File </span>
                            <a class="d-inline-block" data-bs-toggle="tooltip" data-bs-placement="right" data-bs-html="true" data-bs-title="Upload a CSV File. Must contain a 'to_number' column. Optionally include columns for 'from_number', 'identifier', 'description', 'agent_id', 'script_id', 'timezone' to override defaults.">
                                <i class='fa-regular fa-circle-question'></i>
                            </a>
                            <a href="/path/to/sample/bulk_call_template.csv" download="bulk_call_template.csv" class="d-inline-block ms-2 small">(Download Template)</a> <!-- Add Template Link -->
                        </label>
                        <input type="file" class="form-control" id="makeCallToNumberBulkInput" accept=".csv">
                    </div>
                </div>

                <!-- makeCallChangeFromNumberModal -->
                <div class="modal fade" id="makeCallChangeFromNumberModal" tabindex="-1" aria-labelledby="makeCallChangeFromNumberModalLabel" aria-hidden="true">
                    <div class="modal-dialog modal-dialog-centered modal-lg">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h1 class="modal-title fs-5" id="makeCallChangeFromNumberModalLabel">
                                    Select 'Call From' Number
                                </h1>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>
                            <div class="modal-body">
                                <!-- Tabs for providers will be similar to routing -->
                                <div class="d-flex flex-row align-items-center justify-content-between mb-2">
                                    <ul class="nav" id="make-call-assign-number-modal-tab" role="tablist">
                                        <!-- Provider Tabs Dynamically Generated or Hardcoded if fixed -->
                                        <li class="nav-item me-2" role="presentation">
                                            <button class="nav-link active" id="make-call-assign-number-modal-modemtel-tab" number-provider="1" data-bs-toggle="pill" data-bs-target="#make-call-assign-number-modal-modemtel" type="button" role="tab" aria-selected="true">
                                                ModemTel
                                            </button>
                                        </li>
                                        <li class="nav-item me-2" role="presentation">
                                            <button class="nav-link" id="make-call-assign-number-modal-twilio-tab" number-provider="2" data-bs-toggle="pill" data-bs-target="#make-call-assign-number-modal-twilio" type="button" role="tab" aria-selected="true">Twilio</button>
                                        </li>
                                        <li class="nav-item me-2" role="presentation">
                                            <button class="nav-link" id="make-call-assign-number-modal-vonage-tab" number-provider="3" data-bs-toggle="pill" data-bs-target="#make-call-assign-number-modal-vonage" type="button" role="tab" aria-selected="true">Vonage</button>
                                        </li>
                                        <li class="nav-item" role="presentation">
                                            <button class="nav-link" id="make-call-assign-number-modal-telnyx-tab" number-provider="4" data-bs-toggle="pill" data-bs-target="#make-call-assign-number-modal-telnyx" type="button" role="tab" aria-selected="true">Telnyx</button>
                                        </li>
                                    </ul>
                                </div>
                                <div class="tab-content w-100 mb-3" id="make-call-assign-number-modal-tabContent">
                                    <div class="input-group mb-3">
                                        <input type="text" class="form-control" id="inputMakeCallModalSearchNumberInput" placeholder="Search Number (e.g., +1)">
                                        <button class="btn btn-primary" id="searchMakeCallAssignNumberModalList">
                                            <i class="fa-regular fa-magnifying-glass"></i>
                                        </button>
                                    </div>

                                    <!-- Content for each provider tab -->
                                    <div class="tab-pane fade show active" id="make-call-assign-number-modal-modemtel" role="tabpanel">
                                        <div class="list-group make-call-assign-number-modal-list" number-provider="1">
                                            <!-- Dynamically Generated -->
                                            <span class="list-group-item">No ModemTel numbers configured for outbound calls.</span>
                                        </div>
                                    </div>
                                    <div class="tab-pane fade" id="make-call-assign-number-modal-twilio" role="tabpanel">
                                        <div class="list-group make-call-assign-number-modal-list" number-provider="2">
                                            <!-- Dynamically Generated -->
                                            <span class="list-group-item">No Twilio numbers configured for outbound calls.</span>
                                        </div>
                                    </div>
                                    <div class="tab-pane fade" id="make-call-assign-number-modal-vonage" role="tabpanel">
                                        <div class="list-group make-call-assign-number-modal-list" number-provider="3">
                                            <!-- Dynamically Generated -->
                                            <span class="list-group-item">No Vonage numbers configured for outbound calls.</span>
                                        </div>
                                    </div>
                                    <div class="tab-pane fade" id="make-call-assign-number-modal-telnyx" role="tabpanel">
                                        <div class="list-group make-call-assign-number-modal-list" number-provider="4">
                                            <!-- Dynamically Generated -->
                                            <span class="list-group-item">No Telnyx numbers configured for outbound calls.</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                                <button type="button" class="btn btn-primary" id="saveMakeCallFromNumberButton" disabled>
                                    Select Number
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Configuration -->
            <div class="tab-pane fade w-100" id="make-call-configuration" role="tabpanel" aria-labelledby="make-call-configuration-tab-btn" tabindex="0">
                <!-- Schedule / Call Now -->
                <div class="mb-4">
                    <label class="form-label btn-ic-span-align">
                        <span>When to Call</span>
                        <a href="#" class="d-inline-block" data-bs-toggle="tooltip" data-bs-placement="right" data-bs-title="Choose to initiate the call(s) immediately or schedule them for a future date and time.">
                            <i class="fa-regular fa-circle-question"></i>
                        </a>
                    </label>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="makeCallScheduleType" id="makeCallScheduleTypeNow" value="now" checked>
                        <label class="form-check-label" for="makeCallScheduleTypeNow">
                            Call Now
                        </label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="makeCallScheduleType" id="makeCallScheduleTypeLater" value="later">
                        <label class="form-check-label" for="makeCallScheduleTypeLater">
                            Schedule For Later
                        </label>
                    </div>
                    <div class="mt-2 d-none fade" id="makeCallScheduleDateTimeContainer">
                        <label class="form-label" for="makeCallScheduleDateTimeInput">Schedule Date & Time</label>
                        <input type="datetime-local" class="form-control" id="makeCallScheduleDateTimeInput">
                    </div>
                </div>

                <!-- Retry on Decline -->
                <div class="mb-4 p-3 border rounded">
                    <div class="form-check form-switch mb-2">
                        <input type="checkbox" role="switch" class="form-check-input" id="makeCallRetryOnDeclineCheck">
                        <label class="form-check-label" for="makeCallRetryOnDeclineCheck">
                            Enable Retry on Decline/Busy
                        </label>
                        <a href="#" class="d-inline-block ms-1" data-bs-toggle="tooltip" data-bs-placement="right" data-bs-title="Automatically retry the call if the recipient declines or the line is busy.">
                            <i class="fa-regular fa-circle-question"></i>
                        </a>
                    </div>
                    <div class="makeCallRetryOptionsContainer d-none fade ms-4 my-2" id="makeCallRetryOnDeclineOptionsContainer">
                        <!-- Simplified container -->
                        <div class="row g-2 align-items-center">
                            <div class="col-auto">
                                <label for="makeCallRetryDeclineCountInput" class="col-form-label">Retries:</label>
                            </div>
                            <div class="col-auto">
                                <input type="number" class="form-control form-control-sm" id="makeCallRetryDeclineCountInput" value="3" min="1">
                            </div>
                            <div class="col-auto">
                                <label for="makeCallRetryDeclineDelayInput" class="col-form-label">Delay:</label>
                            </div>
                            <div class="col-auto">
                                <input type="number" class="form-control form-control-sm" id="makeCallRetryDeclineDelayInput" value="10" min="1">
                            </div>
                            <div class="col-auto">
                                <select class="form-select form-select-sm" id="makeCallRetryDeclineUnitSelect">
                                    <option value="seconds">Seconds</option>
                                    <option value="minutes" selected>Minutes</option>
                                    <option value="hours">Hours</option>
                                    <option value="days">Days</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Retry on Misscall/No Answer -->
                <div class="mb-4 p-3 border rounded">
                    <div class="form-check form-switch mb-2">
                        <input type="checkbox" role="switch" class="form-check-input" id="makeCallRetryOnMissCheck">
                        <label class="form-check-label" for="makeCallRetryOnMissCheck">
                            Enable Retry on No Answer
                        </label>
                        <a href="#" class="d-inline-block ms-1" data-bs-toggle="tooltip" data-bs-placement="right" data-bs-title="Automatically retry the call if there is no answer after ringing.">
                            <i class="fa-regular fa-circle-question"></i>
                        </a>
                    </div>
                    <div class="makeCallRetryOptionsContainer d-none fade ms-4 my-2" id="makeCallRetryOnMissOptionsContainer">
                        <!-- Simplified container -->
                        <div class="row g-2 align-items-center">
                            <div class="col-auto">
                                <label for="makeCallRetryMissCountInput" class="col-form-label">Retries:</label>
                            </div>
                            <div class="col-auto">
                                <input type="number" class="form-control form-control-sm" id="makeCallRetryMissCountInput" value="3" min="1">
                            </div>
                            <div class="col-auto">
                                <label for="makeCallRetryMissDelayInput" class="col-form-label">Delay:</label>
                            </div>
                            <div class="col-auto">
                                <input type="number" class="form-control form-control-sm" id="makeCallRetryMissDelayInput" value="10" min="1">
                            </div>
                            <div class="col-auto">
                                <select class="form-select form-select-sm" id="makeCallRetryMissUnitSelect">
                                    <option value="seconds">Seconds</option>
                                    <option value="minutes" selected>Minutes</option>
                                    <option value="hours">Hours</option>
                                    <option value="days">Days</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Standard Timeouts -->
                <div class="mb-3">
                    <label class="form-label btn-ic-span-align" for="makeCallNumberSilenceNotify">
                        <span>Notify on silence (ms) </span>
                        <a href="#" class="d-inline-block" data-bs-toggle="tooltip" data-bs-placement="right" data-bs-title="Milliseconds of silence to wait before notifying the user that the call will end if they do not give an input.">
                            <i class="fa-regular fa-circle-question"></i>
                        </a>
                    </label>
                    <input type="number" class="form-control" id="makeCallNumberSilenceNotify" value="10000" min="0">
                </div>
                <div class="mb-3">
                    <label class="form-label btn-ic-span-align" for="makeCallNumberSilenceEnd">
                        <span>End call on silence (ms) </span>
                        <a href="#" class="d-inline-block" data-bs-toggle="tooltip" data-bs-placement="right" data-bs-title="Milliseconds of silence to wait after the notification before ending the call if there's still no input.">
                            <i class="fa-regular fa-circle-question"></i>
                        </a>
                    </label>
                    <input type="number" class="form-control" id="makeCallNumberSilenceEnd" value="30000" min="0">
                </div>
                <div class="mb-3">
                    <label class="form-label btn-ic-span-align" for="makeCallNumberTotalCallTime">
                        <span>Max call time (s) </span>
                        <a href="#" class="d-inline-block" data-bs-toggle="tooltip" data-bs-placement="right" data-bs-title="Maximum total duration of the call in seconds before it's automatically ended.">
                            <i class="fa-regular fa-circle-question"></i>
                        </a>
                    </label>
                    <input type="number" class="form-control" id="makeCallNumberTotalCallTime" value="600" min="1">
                </div>
            </div>

            <!-- Agent -->
            <div class="tab-pane fade w-100" id="make-call-agent" role="tabpanel" aria-labelledby="make-call-agent-tab-btn" tabindex="0">
                <div class="mb-3">
                    <label class="form-label" for="makeCallSelectedAgentName">Selected Agent</label>
                    <div class="input-group">
                        <span class="input-group-text" id="makeCallSelectedAgentIcon">-</span>
                        <input type="text" class="form-control" id="makeCallSelectedAgentName" placeholder="Select Agent..." disabled>
                        <button class="btn btn-primary" id="makeCallChangeAgentButton" data-bs-toggle="modal" data-bs-target="#makeCallChangeAgentModal">
                            Select
                        </button>
                    </div>
                    <!-- makeCallChangeAgentModal -->
                    <div class="modal fade" id="makeCallChangeAgentModal" tabindex="-1" aria-labelledby="makeCallChangeAgentModalLabel" aria-hidden="true">
                        <div class="modal-dialog modal-dialog-centered modal-lg">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h1 class="modal-title fs-5" id="makeCallChangeAgentModalLabel">Select Agent</h1>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                </div>
                                <div class="modal-body">
                                    <div class="input-group mb-3">
                                        <input type="text" class="form-control" id="inputMakeCallSelectAgentSearch" placeholder="Search Agent Name...">
                                        <button class="btn btn-primary" id="searchMakeCallSelectAgentList">
                                            <i class="fa-regular fa-magnifying-glass"></i>
                                        </button>
                                    </div>
                                    <div class="list-group" id="make-call-select-agent-modal-list">
                                        <!-- Dynamically Generated -->
                                        <span class="list-group-item">No agents created yet.</span>
                                    </div>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                                    <button type="button" class="btn btn-primary" id="saveMakeCallAgentButton" disabled>
                                        Select Agent
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label btn-ic-span-align" for="makeCallAgentDefaultScriptSelect">
                        <span>Opening Script </span>
                        <a href="#" class="d-inline-block" data-bs-toggle="tooltip" data-bs-placement="right" data-bs-html="true" data-bs-title="Select the conversation script the agent should start with.">
                            <i class="fa-regular fa-circle-question"></i>
                        </a>
                    </label>
                    <select class="form-select" id="makeCallAgentDefaultScriptSelect" disabled>
                        <option value="" disabled selected>Select Agent First</option>
                        <!-- Dynamically Generated -->
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label btn-ic-span-align" for="makeCallAgentLanguageSelect">
                        <span>Language </span>
                        <a href="#" class="d-inline-block" data-bs-toggle="tooltip" data-bs-placement="right" data-bs-html="true" data-bs-title="Select the language the agent will use for this call. This affects voice synthesis and recognition.">
                            <i class="fa-regular fa-circle-question"></i>
                        </a>
                    </label>
                    <select class="form-select" id="makeCallAgentLanguageSelect">
                        <option value="" disabled selected>Select Language</option>
                        <!-- Dynamically Generated -->
                    </select>
                </div>
                <!-- UPDATED INTERRUPTION SECTION -->
                <div class="mb-3">
                    <label class="form-label btn-ic-span-align" for="makeCallAgentInterruptionTypeSelect">
                        <span>Interruption Type </span>
                        <a href="#" class="d-inline-block" data-bs-toggle="tooltip" data-bs-placement="right" data-bs-html="true" data-bs-title="How the conversation flow is managed.<br><strong>Turn by Turn:</strong> User and agent speak sequentially.<br><strong>Interruptible:</strong> User can interrupt the agent based on selected method.">
                            <i class="fa-regular fa-circle-question"></i>
                        </a>
                    </label>
                    <select class="form-select" id="makeCallAgentInterruptionTypeSelect">
                        <option value="0" selected>Turn by Turn</option>
                        <option value="1">Interruptible via VAD (Voice Activity Detection)</option>
                        <option value="2">Interruptible via AI (LLM decides)</option>
                        <option value="3">Interruptible via Response (STT transcription)</option>
                    </select>
                    <!-- Turn by Turn Options -->
                    <div class="w-100 make-call-conversation-type-box d-none" box-type="turnbyturn">
                        <div class="form-check form-switch">
                            <input type="checkbox" role="switch" class="form-check-input" id="makeCallAgentTurnByTurnUseInterruptedResponseInNextTurn">
                            <label class="form-check-label mb-0" for="makeCallAgentTurnByTurnUseInterruptedResponseInNextTurn">
                                Use Interrupted Response in Next Turn?
                            </label>
                            <a href="#" class="d-inline-block ms-1" data-bs-toggle="tooltip" data-bs-placement="right" data-bs-title="Any user speech detected during the agent's turn will be processed in the user's next turn.">
                                <i class="fa-regular fa-circle-question"></i>
                            </a>
                        </div>
                    </div>
                    <!-- VAD Options -->
                    <div class="w-100 make-call-conversation-type-box d-none" box-type="interruptibleviavad">
                        <label class="form-label btn-ic-span-align" for="makeCallAgentConversationTypeInterruptibleAudioActivityDuration">
                            <span>Voice Activity Duration (ms) </span>
                            <a href="#" class="d-inline-block" data-bs-toggle="tooltip" data-bs-placement="right" data-bs-html="true" data-bs-title="Duration of continuous voice activity needed to trigger an interruption.">
                                <i class="fa-regular fa-circle-question"></i>
                            </a>
                        </label>
                        <input type="number" class="form-control" id="makeCallAgentConversationTypeInterruptibleAudioActivityDuration" value="300" min="50">
                    </div>
                    <!-- AI LLM Options -->
                    <div class="w-100 make-call-conversation-type-box d-none" box-type="interruptibleviaai">
                        <div class="form-check form-switch">
                            <input type="checkbox" role="switch" class="form-check-input" id="makeCallAgentInterruptViaAIUseAgentLLM">
                            <label class="form-check-label mb-0" for="makeCallAgentInterruptViaAIUseAgentLLM">
                                Use Agent's LLM for Interruption Check?
                            </label>
                            <a href="#" class="d-inline-block ms-1" data-bs-toggle="tooltip" data-bs-placement="right" data-bs-title="Use the agent's primary LLM integration to decide if an interruption is appropriate based on the user's speech. If unchecked, select a separate LLM below.">
                                <i class="fa-regular fa-circle-question"></i>
                            </a>
