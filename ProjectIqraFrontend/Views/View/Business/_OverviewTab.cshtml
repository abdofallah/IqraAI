<div class="main-container fade w-100 show" id="overview-tab">
    <h3 class="fw-bold tab-title mb-3"><i class='fa-regular fa-chalkboard'></i> <span>Overview</span></h3>
    <div class="inner-container">
        <div class="row mb-4">
            <!-- Total Calls-->
            <div class="col-12 col-md-3">
                <div class="analytics-card">
                    <h6>Total Calls</h6>
                    <div class="d-flex flex-row justify-content-between align-items-end">
                        <h4 class="m-0">103</h4>
                        <span class="m-0 percentage percentage-positive">
                            <span>+5%</span>
                            <i class="fa-regular fa-arrow-up"></i>
                        </span>
                    </div>
                </div>
            </div>
            <!-- Average Call Time -->
            <div class="col-12 col-md-4">
                <div class="analytics-card">
                    <h6>Average Call Time</h6>
                    <div class="d-flex flex-row justify-content-between align-items-end">
                        <h4 class="m-0">3min 30sec</h4>
                        <span class="m-0 percentage percentage-negative">
                            <span>-10%</span>
                            <i class="fa-regular fa-arrow-down"></i>
                        </span>
                    </div>
                </div>
            </div>
            <!-- Appointments/Orders -->
            <div class="col-12 col-md-5">
                <div class="analytics-card half-card">
                    <h6 class="w-100 mb-0">Appointments Booked</h6>
                    <div class="d-flex flex-row justify-content-between align-items-end">
                        <h4 class="m-0">10</h4>
                        <span class="m-0 percentage percentage-positive">
                            <span>+53%</span>
                            <i class="fa-regular fa-arrow-up"></i>
                        </span>
                    </div>
                </div>

                <div class="analytics-card half-card">
                    <h6 class="w-100 mb-0">Orders Placed</h6>
                    <div class="d-flex flex-row justify-content-between align-items-end">
                        <h4 class="m-0">41</h4>
                        <span class="m-0 percentage percentage-positive">
                            <span>+13%</span>
                            <i class="fa-regular fa-arrow-up"></i>
                        </span>
                    </div>
                </div>
            </div>

        </div>
        <div class="row mb-2 analytics-second-section">
            <div class="col-12 col-md-8">
                <canvas id="analyticsChart"></canvas>
            </div>
            <div class="col-12 col-md-4">
                <div class="analytics-acitivity h-100">
                    <h4 class="mb-4">Upcoming</h4>
                    <div>
                        <div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>