                                        <input type="checkbox" role="switch" class="form-check-input" id="agentCacheSettingsAutoCacheAudio">
                                        <label class="form-label mb-0" for="agentCacheSettingsAutoCacheAudio">
                                            <span>Auto Cache Audio Queries?</span>
                                        </label>
                                    </div>

                                    <a style="display: inline-block; vertical-align: middle;" href="#" class="d-inline-block" data-bs-toggle="tooltip" data-bs-placement="right" data-bs-title="If enabled, will auto cache all tts generated results into the specified audio cache group.">
                                        <i class="fa-regular fa-circle-question"></i>
                                    </a>
                                </div>

                                <div class="mt-3 d-none" id="agentCacheSettingsAutoCacheAudioBox">
                                    <div class="mb-2">
                                        <label class="form-label" for="agentAutoCacheAudioGroupSelect">Auto Audio Cache Group</label>
                                        <select class="form-select" id="agentAutoCacheAudioGroupSelect">
                                            <!-- Dynamically Generated -->
                                        </select>
                                    </div>
                                    <div>
                                        <label class="form-label btn-ic-span-align" for="agentAutoCacheExpiryInput">
                                            <span>Auto Audio Cache Expiry (Hours)</span>
                                            <a href="#" class="d-inline-block" data-bs-toggle="tooltip" data-bs-placement="right" data-bs-title="How long before auto-cached queries expire. Set to 0 for no expiry.">
                                                <i class="fa-regular fa-circle-question"></i>
                                            </a>
                                        </label>
                                        <input type="number" class="form-control" id="agentAutoCacheExpiryInput" min="0" value="24" step="1">
                                    </div>
                                </div>

                            </div>
                        </div>
                    </div>
                </div>
                <!-- Settings -->
                <div class="tab-pane fade w-100" id="agents-manager-settings" role="tabpanel" aria-labelledby="agents-manager-settings-tab" tabindex="0">
                    <div class="mb-3">
                        <label class="form-label btn-ic-span-align" for="editAgentBackgroundAudioSelect">
                            <span>Background Audio </span>

                            <a href="#" class="d-inline-block" data-bs-toggle="tooltip" data-bs-placement="right" data-bs-html="true" data-bs-title="Audio to be played in the background of the call on repeat.">
                                <i class="fa-regular fa-circle-question"></i>
                            </a>
                        </label>
                        <select class="form-select" id="editAgentBackgroundAudioSelect">
                            <option value="none">None</option>
                            <option value="custom">Custom (Upload)</option>
                        </select>

                        <div class="toolAudioExtraOptionsBox d-none" id="agentBackgroundAudioBox">
                            <div id="agentBackgroundAudioInputBox">
                                <label class="form-label d-block">Audio</label>
                                <div class="mb-3 recording-container">
                                    <div class="d-flex flex-row align-items-center justify-content-between w-100">
                                        <div class="recording-container-waveform d-none" id="agent-background-audio-waveform">
                                        </div>
                                        <div class="no-audio-notice">
                                            <span>No audio uploaded yet...</span>
                                        </div>
                                        <button class="btn btn-sm btn-light mb-auto" id="agent-background-audio-upload-btn">Upload</button>
                                        <input type="file" class="form-control d-none" id="agentBackgroundAudioUploadInput" accept="audio/mp3,audio/wav">
                                    </div>
                                    <div class="audio-controller d-none">
                                        <div class="speed-controller me-5">
                                            <label for="slider-agent-background-audio-waveform">
                                                <i class="fa-regular fa-gauge"></i>
                                            </label>
                                            <input class="mx-1" type="slider" id="range-agent-background-audio-waveform" min="0.1" max="4" value="1" step="0.1">
                                        </div>
                                        <div class="volume-controller me-5">
                                            <label for="slider-agent-background-audio-waveform">
                                                <i class="fa-regular fa-volume"></i>
                                            </label>
                                            <input type="range" id="slider-agent-background-audio-waveform" min="0" max="1" value="1" step="0.1" style="width: 70px">
                                        </div>
                                        <button class="me-5" button-type="start-stop-audio" mode="play" disabled>
                                            <i class="fa-regular fa-play"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                            <div>
                                <label class="form-label" for="agentBackgroundAudioVolumeInput">Volume</label>
                                <input type="number" class="form-control" min="0" max="100" value="100" step="1" id="agentBackgroundAudioVolumeInput">
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>