<div class="main-container fade d-none w-100" id="agents-tab">
    <h3 class="fw-bold tab-title mb-3"><i class='fa-regular fa-headset'></i> <span>Agents</span></h3>
    <div class="inner-header-container w-100 mb-3 fade d-none" id="agents-manager-header">

        <!-- Agent Manager Breadcrumb and Save -->
        <div class="mb-4 d-flex flex-row align-items-center justify-content-between fade d-none w-100" id="agents-manager-breadcrumb">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item">
                        <a href="#" id="switchBackToAgentsTab">Agents</a>
                    </li>
                    <li class="breadcrumb-item active" aria-current="page"><span id="currentAgentName">Agent</span></li>
                </ol>
            </nav>
            <div>
                <button class="btn btn-light btn-sm btn-ic-span-align" data-bs-custom-class="agentDebugToolTip" data-bs-toggle="tooltip" data-bs-html="true" data-bs-placement="bottom" data-bs-title="<b>Debug coming soon!</b>">
                    <i class="fa-regular fa-wrench text-dark"></i>
                    <span> Debug</span>
                </button>
                <button class="btn btn-primary btn-sm btn-ic-span-align" id="confirmPublishAgentButton" disabled>
                    <i class="fa-regular fa-floppy-disk"></i>
                    <span>Save</span>
                    <div class="spinner-border save-button-spinner d-none" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </button>
            </div>
        </div>

        <!-- Agent Script Manager Breadcrumb -->
        <div class="mb-4 d-flex flex-row align-items-center justify-content-between fade d-none w-100" id="agents-script-manager-breadcrumb">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item">
                        <span>Agents</span>
                    </li>
                    <li class="breadcrumb-item">
                        <span id="agentNameScriptBreadcrumb">Agent</span>
                    </li>
                    <li class="breadcrumb-item">
                        <a href="#" id="switchBackToAgentsScriptManagerTab">Scripts</a>
                    </li>
                    <li class="breadcrumb-item active" aria-current="page"><span id="currentAgentScriptName">Script</span></li>
                </ol>
            </nav>
            <div>
                <div class="btn-group" id="saveAgentScriptDropdown">
                    <button class="btn btn-primary btn-sm btn-ic-span-align" id="saveAgentScriptButton">
                        <i class='fa-regular fa-floppy-disk'></i>
                        <span> Save</span>
                    </button>
                </div>
            </div>
        </div>

        <!-- Agent Manager Inner Tabs -->
        <div class="d-flex flex-row align-items-center justify-content-between w-100 fade d-none" id="agents-manager-tab">
            <ul class="nav" role="tablist">
                <li class="nav-item me-2" role="presentation">
                    <button class="nav-link active" id="agents-manager-general-tab" data-bs-toggle="pill" data-bs-target="#agents-manager-general" type="button" role="tab" aria-controls="agents-manager-general" aria-selected="true">General</button>
                </li>
                <li class="nav-item me-2" role="presentation">
                    <button class="nav-link" id="agents-manager-context-tab" data-bs-toggle="pill" data-bs-target="#agents-manager-context" type="button" role="tab" aria-controls="agents-manager-context" aria-selected="true">Context</button>
                </li>
                <li class="nav-item me-2" role="presentation">
                    <button class="nav-link" id="agents-manager-personality-tab" data-bs-toggle="pill" data-bs-target="#agents-manager-personality" type="button" role="tab" aria-controls="agents-manager-personality" aria-selected="true">Personality</button>
                </li>
                <li class="nav-item me-2" role="presentation">
                    <button class="nav-link" id="agents-manager-utterances-tab" data-bs-toggle="pill" data-bs-target="#agents-manager-utterances" type="button" role="tab" aria-controls="agents-manager-utterances" aria-selected="true">Utterances</button>
                </li>
                <li class="nav-item me-2" role="presentation">
                    <button class="nav-link" id="agents-manager-interruptions-tab" data-bs-toggle="pill" data-bs-target="#agents-manager-interruptions" type="button" role="tab" aria-controls="agents-manager-interruptions" aria-selected="true">Interruptions</button>
                </li>
                <li class="nav-item me-2" role="presentation">
                    <button class="nav-link" id="agents-manager-scripts-tab" data-bs-toggle="pill" data-bs-target="#agents-manager-scripts" type="button" role="tab" aria-controls="agents-manager-scripts" aria-selected="true">Scripts</button>
                </li>
                <li class="nav-item me-2" role="presentation">
                    <button class="nav-link" id="agents-manager-integrations-tab" data-bs-toggle="pill" data-bs-target="#agents-manager-integrations" type="button" role="tab" aria-controls="agents-manager-integrations" aria-selected="true">Integrations</button>
                </li>
                <li class="nav-item me-2" role="presentation">
                    <button class="nav-link" id="agents-manager-knowledgebases-tab" data-bs-toggle="pill" data-bs-target="#agents-manager-knowledgebases" type="button" role="tab" aria-controls="agents-manager-knowledgebases" aria-selected="true">Knowledge Base</button>
                </li>
                <li class="nav-item me-2" role="presentation">
                    <button class="nav-link" id="agents-manager-cache-tab" data-bs-toggle="pill" data-bs-target="#agents-manager-cache" type="button" role="tab" aria-controls="agents-manager-cache" aria-selected="true">Cache</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="agents-manager-settings-tab" data-bs-toggle="pill" data-bs-target="#agents-manager-settings" type="button" role="tab" aria-controls="agents-manager-settings" aria-selected="true">Settings</button>
                </li>
            </ul>

            <div class="ms-4" id="agentsManagerMultiLanguageContainer">
            </div>
        </div>

        <!-- Agent Script Manager Inner Tabs -->
        <div class="d-flex flex-row align-items-center justify-content-between fade d-none w-100" id="agents-manager-script-tab">
            <ul class="nav" role="tablist">
                <li class="nav-item me-2" role="presentation">
                    <button class="nav-link active" id="agents-manager-script-general-tab" data-bs-toggle="pill" data-bs-target="#agents-manager-script-general" type="button" role="tab" aria-controls="agents-manager-script-general" aria-selected="true">General</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="agents-manager-script-conversation-tab" data-bs-toggle="pill" data-bs-target="#agents-manager-script-conversation" type="button" role="tab" aria-controls="agents-manager-script-conversation" aria-selected="true">Conversation</button>
                </li>
            </ul>

            <div class="ms-4" id="agentsScriptManagerMultiLanguageParentContainer">
                <div id="agentsScriptManagerMultiLanguageContainer">
                </div>
            </div>
        </div>

    </div>
    <div class="inner-container">
        <!-- Agents List Tab -->
        <div class="fade show w-100" id="agentsListTab">
            <div class="mb-4 d-flex flex-row align-items-center justify-content-between">
                <div style="min-width: 200px" class="me-4">
                    <button class="w-100 mb-0 text-decoration-none fw-bold btn btn-primary" id="addNewAgentButton">
                        <span>+ Add New Agent</span>
                    </button>
                </div>
                <div class="input-group w-100">
                    <input type="text" class="form-control" placeholder="Agent Name" aria-label="Agent Name" aria-describedby="searchAgentButton">
                    <button class="input-group-button btn btn-primary" id="searchAgentButton">
                        <i class='fa-regular fa-magnifying-glass'></i>
                    </button>
                </div>
            </div>
            <div class="row" id="agentsListTable">
                <!-- Agents will be added here dynamically -->
            </div>
        </div>
        <!-- Agents Manager Tab -->
        <div class="fade d-none w-100" id="agentsManagerTab">
            <div class="tab-content w-100" id="agents-manager-tabContent">
                <!-- General -->
                <div class="tab-pane fade w-100 show active" id="agents-manager-general" role="tabpanel" aria-labelledby="agents-manager-general-tab" tabindex="0">
                    <div class="mb-3">
                        <label class="form-label" for="editAgentIdentifierInput"><span>Identifier</span> <i class="fa-regular fa-language"></i></label>
                        <div class="input-group">
                            <button class="btn btn-light" id="editAgentIconButton">🤖</button>
                            <input type="text" class="form-control" id="editAgentIdentifierInput" placeholder="Agent Identifier Name">
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="editAgentDescriptionInput"><span>Description</span> <i class="fa-regular fa-language"></i></label>
                        <input type="text" class="form-control" id="editAgentDescriptionInput" placeholder="Agent Description">
                    </div>
                </div>
                <!-- Context -->
                <div class="tab-pane fade w-100" id="agents-manager-context" role="tabpanel" aria-labelledby="agents-manager-context-tab" tabindex="0">
                    <div class="form-check form-switch mb-3">
                        <input class="form-check-input" type="checkbox" role="switch" id="agentEditContextEnableBranding" checked>
                        <label class="form-check-label" for="agentEditContextEnableBranding">Use Branding</label>
                        <a href="#" class="d-inline-block" data-bs-toggle="tooltip" data-bs-placement="right" data-bs-title="Use the global context branding information for this agent.">
                            <i class="fa-regular fa-circle-question"></i>
                        </a>
                    </div>
                    <div class="form-check form-switch mb-3">
                        <input class="form-check-input" type="checkbox" role="switch" id="agentEditContextEnableBranches" checked>
                        <label class="form-check-label" for="agentEditContextEnableBranches">Use Branches</label>
                        <a href="#" class="d-inline-block" data-bs-toggle="tooltip" data-bs-placement="right" data-bs-title="Use the global context branches information for this agent.">
                            <i class="fa-regular fa-circle-question"></i>
                        </a>
                    </div>
                    <div class="form-check form-switch mb-3">
                        <input class="form-check-input" type="checkbox" role="switch" id="agentEditContextEnableServices" checked>
                        <label class="form-check-label" for="agentEditContextEnableServices">Use Services</label>
                        <a href="#" class="d-inline-block" data-bs-toggle="tooltip" data-bs-placement="right" data-bs-title="Use the global context services information for this agent.">
                            <i class="fa-regular fa-circle-question"></i>
                        </a>
                    </div>
                    <div class="form-check form-switch mb-3">
                        <input class="form-check-input" type="checkbox" role="switch" id="agentEditContextEnableProducts" checked>
                        <label class="form-check-label" for="agentEditContextEnableProducts">Use Products</label>
                        <a href="#" class="d-inline-block" data-bs-toggle="tooltip" data-bs-placement="right" data-bs-title="Use the global context products information for this agent.">
                            <i class="fa-regular fa-circle-question"></i>
                        </a>
                    </div>
                </div>
                <!-- Personality -->
                <div class="tab-pane fade w-100" id="agents-manager-personality" role="tabpanel" aria-labelledby="agents-manager-personality-tab" tabindex="0">
                    <div class="mb-3">
                        <label class="form-label" for="editAgentPersonalityNameInput"><span>Name</span> <i class="fa-regular fa-language"></i></label>
                        <input type="text" class="form-control" id="editAgentPersonalityNameInput" placeholder="Agent Name">
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="editAgentPersonalityRoleInput"><span>Role</span> <i class="fa-regular fa-language"></i></label>
                        <textarea class="form-control" id="editAgentPersonalityRoleInput" placeholder="Agent Role"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label btn-ic-span-align d-block">
                            <span>Capabilities</span> <i class="fa-regular fa-language"></i>

                            <a href="#" class="d-inline-block" data-bs-toggle="tooltip" data-bs-placement="bottom" data-bs-title="Tasks, abilities, or skills the AI can perform.">
                                <i class="fa-regular fa-circle-question"></i>
                            </a>
                        </label>
                        <button class="btn btn-light btn-sm mb-2" id="addAgentPersonalityCapabilitiesValue">
                            Add Value
                        </button>
                        <div id="editAgentPersonalityCapabilitiesValueInputs">
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label btn-ic-span-align d-block">
                            <span>Ethics</span> <i class="fa-regular fa-language"></i>

                            <a href="#" class="d-inline-block" data-bs-toggle="tooltip" data-bs-placement="bottom" data-bs-title="Specify the moral principles, ethical guidelines, and values that shape the AI's decision-making and actions.">
                                <i class="fa-regular fa-circle-question"></i>
                            </a>
                        </label>
                        <button class="btn btn-light btn-sm mb-2" id="addAgentPersonalityEthicsValue">
                            Add Value
                        </button>
                        <div id="editAgentPersonalityEthicsValueInputs">
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label btn-ic-span-align d-block">
                            <span>Tone</span> <i class="fa-regular fa-language"></i>

                            <a href="#" class="d-inline-block" data-bs-toggle="tooltip" data-bs-placement="bottom" data-bs-title="The AI's personality traits, emotional patterns, communication style, and overall demeanor.">
                                <i class="fa-regular fa-circle-question"></i>
                            </a>
                        </label>
                        <button class="btn btn-light btn-sm mb-2" id="addAgentPersonalityToneValue">
                            Add Value
                        </button>
                        <div id="editAgentPersonalityToneValueInputs">
                        </div>
                    </div>
                </div>
                <!-- Utterances -->
                <div class="tab-pane fade w-100" id="agents-manager-utterances" role="tabpanel" aria-labelledby="agents-manager-utterances-tab" tabindex="0">
                    <div class="mb-3">
                        <label class="form-label" for="editAgentGreetingStartTypeInput">
                            Opening
                            Type
                        </label>
                        <select class="form-select" id="editAgentGreetingStartTypeInput">
                            <option value="0" selected>Agent Greets Right Away</option>
                            <option value="1">Wait for User To Speak Before Greeting</option>
                        </select>
                    </div>
                    <div class="">
                        <label class="form-label" for="editAgentPersonalityGreetingInput">
                            <span>Greeting Message</span> <i class="fa-regular fa-language"></i>
                        </label>
                        <textarea class="form-control" id="editAgentPersonalityGreetingInput" placeholder="The opening message agent speaks"></textarea>
                    </div>
                </div>
                <!-- Interruptions -->
                <div class="tab-pane fade w-100" id="agents-manager-interruptions" role="tabpanel" aria-labelledby="agents-manager-interruptions-tab" tabindex="0">
                    <div class="mb-3">
                        <label class="form-label btn-ic-span-align" for="editAgentTurnEndTypeSelect">
                            <span>Turn-end Detection </span>

                            <a href="#" class="d-inline-block" data-bs-toggle="tooltip" data-bs-placement="right" data-bs-html="true" data-bs-title="Defines how the system detects that the <strong>user</strong> has finished speaking.">
                                <i class="fa-regular fa-circle-question"></i>
                            </a>
                        </label>
                        <select class="form-select" id="editAgentTurnEndTypeSelect">
                            <option disabled selected>Select End-Turn Detection Type</option>
                            <option value="0">Turn End via VAD (Voice Activity Detection)</option>
                            <option value="1">Turn End via Response (STT transcription)</option>
                            <option value="2">Turn End via AI (LLM decides)</option>
                            <option value="3">Turn End via ML (Smart-turn end Classification)</option>
                        </select>
                        <div class="w-100 agent-turn-end-type-box" box-type="turnendviavad">
                            <div class="">
                                <label class="form-label btn-ic-span-align" for="editAgentTurnEndViaVADAudioActivityDuration">
                                    <span>Silence Duration (Milliseconds) </span>
                                    <a href="#" class="d-inline-block" data-bs-toggle="tooltip" data-bs-placement="right" data-bs-html="true" data-bs-title="Duration of silence after user speech to trigger turn-end.">
                                        <i class="fa-regular fa-circle-question"></i>
                                    </a>
                                </label>
                                <input type="number" class="form-control" id="editAgentTurnEndViaVADAudioActivityDuration" value="300">
                            </div>
                        </div>
                        <div class="w-100 agent-turn-end-type-box" box-type="turnendviaai">
                            <div class="form-check form-switch">
                                <div style="display: inline-block; vertical-align: middle;">
                                    <input type="checkbox" role="switch" class="form-check-input" id="editAgentTurnEndViaAIUseAgentLLM">
                                    <label class="form-label mb-0" for="editAgentTurnEndViaAIUseAgentLLM">
                                        <span>Use Agent's LLM for turn-end detection?</span>
                                    </label>
                                </div>

                                <a style="display: inline-block; vertical-align: middle;" href="#" class="d-inline-block" data-bs-toggle="tooltip" data-bs-placement="right" data-bs-title="Utilize the main LLM of the agent to check for user speech turn end. If unchecked, you can specify a separate, potentially faster LLM.">
                                    <i class="fa-regular fa-circle-question"></i>
                                </a>
                            </div>

                            <div class="mt-3" id="agentTurnEndViaLLMIntegrationSelectBox">
                                <label class="form-label">Turn-End LLM Integration</label>
                                <div id="agentTurnEndViaLLMIntegrationContainer">
                                    <!-- The IntegrationConfigurationManager class will automatically build the UI here. -->
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Turn by Turn/Disable Interruption -->
                    <div class="mb-3 agent-interruption-llm-verify-box">
                        <div class="form-check form-switch mb-2">
                            <div style="display: inline-block; vertical-align: middle;">
                                <input type="checkbox" role="switch" class="form-check-input" id="editAgentTurnByTurnMode">
                                <label class="form-label mb-0" for="editAgentTurnByTurnMode">
                                    <span>Disable Interruptions (Use Turn by Turn)?</span>
                                </label>
                            </div>

                            <a style="display: inline-block; vertical-align: middle;" href="#" class="d-inline-block" data-bs-toggle="tooltip" data-bs-placement="right" data-bs-title="Use Turn by Turn mode by letting only agent or user speak during their turn without interrupting each other.">
                                <i class="fa-regular fa-circle-question"></i>
                            </a>
                        </div>

                        <div class="form-check form-switch">
                            <div style="display: inline-block; vertical-align: middle;">
                                <input type="checkbox" role="switch" class="form-check-input" id="editAgentTurnByTurnIncludeInterruptedSpeech" disabled>
                                <label class="form-label mb-0" for="editAgentTurnByTurnIncludeInterruptedSpeech">
                                    <span>Include Interrupted Speech in Next Turn?</span>
                                </label>
                            </div>

                            <a style="display: inline-block; vertical-align: middle;" href="#" class="d-inline-block" data-bs-toggle="tooltip" data-bs-placement="right" data-bs-title="Include the user speech spoken during the agent's turn in the next user turn instead of discarding it.">
                                <i class="fa-regular fa-circle-question"></i>
                            </a>
                        </div>
                    </div>

                    <!--  Agent Pause Trigger -->
                    <div class="mb-3">
                        <label class="form-label btn-ic-span-align" for="agentInterruptionPauseTypeSelect">
                            <span>Agent Speech Interrupted Pause Trigger </span>
                            <a href="#" class="d-inline-block" data-bs-toggle="tooltip" data-bs-placement="right" data-bs-html="true" data-bs-title="What initially triggers the agent's speech to pause when a user beigns to interrupt the agent's speech.">
                                <i class="fa-regular fa-circle-question"></i>
                            </a>
                        </label>
                        <select class="form-select" id="agentInterruptionPauseTypeSelect">
                            <option disabled selected>Select Agent Pause Trigger</option>
                            <option value="0">Pause via VAD (Voice Activity Duration)</option>
                            <option value="1">Pause via Transcription (Word Count)</option>
                        </select>

                        <!-- Conditional box for VAD -->
                        <div class="w-100 agent-interruption-pause-type-box" box-type="pauseviavad" style="display: none;">
                            <div class="">
                                <label class="form-label btn-ic-span-align" for="agentInterruptionPauseVADDuration">
                                    <span>User Voice Duration (Milliseconds)</span>
                                    <a href="#" class="d-inline-block" data-bs-toggle="tooltip" data-bs-placement="right" data-bs-html="true" data-bs-title="The agent will pause its speech after the user has spoken for this duration.">
                                        <i class="fa-regular fa-circle-question"></i>
                                    </a>
                                </label>
                                <input type="number" class="form-control" id="agentInterruptionPauseVADDuration" value="100">
                            </div>
                        </div>

                        <!-- Conditional box for Word Count -->
                        <div class="w-100 agent-interruption-pause-type-box" box-type="pauseviawords" style="display: none;">
                            <div class="">
                                <label class="form-label btn-ic-span-align" for="agentInterruptionPauseWordCount">
                                    <span>Transcribed Word Count</span>
                                    <a href="#" class="d-inline-block" data-bs-toggle="tooltip" data-bs-placement="right" data-bs-html="true" data-bs-title="The agent will pause its speech after this many words have been transcribed from the user's speech.">
                                        <i class="fa-regular fa-circle-question"></i>
                                    </a>
                                </label>
                                <input type="number" class="form-control" id="agentInterruptionPauseWordCount" value="2">
                            </div>
                        </div>
                    </div>

                    <!-- Interruption Verification -->
                    <div class="agent-interruption-llm-verify-box">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" role="switch" id="enableAgentInterruptionVerification">
                            <label class="form-check-label btn-ic-span-align" for="enableAgentInterruptionVerification">
                                <span>Enable AI Interruption Verification</span>
                                <a href="#" class="d-inline-block" data-bs-toggle="tooltip" data-bs-placement="right" data-bs-html="true" data-bs-title="If enabled, after the user finishes speaking, an LLM will verify if the interruption was valid (e.g., a question) or just noise (e.g., a cough). If invalid, the agent may resume its original speech.">
                                    <i class="fa-regular fa-circle-question"></i>
                                </a>
                            </label>
                        </div>

                        <!-- Conditional container for AI Verification settings -->
                        <div class="w-100" id="agentInterruptionVerificationContainer" style="display: none;">
                            <div class="form-check form-switch mt-3">
                                <div style="display: inline-block; vertical-align: middle;">
                                    <input type="checkbox" role="switch" class="form-check-input" id="agentInterruptionVerifyAIUseAgentLLM">
                                    <label class="form-label mb-0" for="agentInterruptionVerifyAIUseAgentLLM">
                                        <span>Use Agent's main LLM for verification?</span>
                                    </label>
                                </div>
                                <a style="display: inline-block; vertical-align: middle;" href="#" class="d-inline-block" data-bs-toggle="tooltip" data-bs-placement="right" data-bs-title="Utilize the main LLM of the agent to decide if the user's speech is a valid interruption. If unchecked, you can specify a separate, potentially faster LLM.">
                                    <i class="fa-regular fa-circle-question"></i>
                                </a>
                            </div>

                            <div class="mt-3" id="agentInterruptionVerifyLLMIntegrationSelectBox">
                                <label class="form-label">Interruption Verification LLM</label>
                                <div id="agentInterruptionVerifyLLMIntegrationContainer">
                                    <!-- The IntegrationConfigurationManager class will automatically build the UI here. -->
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Scripts -->
                <div class="tab-pane fade w-100" id="agents-manager-scripts" role="tabpanel" aria-labelledby="agents-manager-scripts-tab" tabindex="0">
                    <!-- Scripts List Tab -->
                    <div class="fade show w-100" id="agentScriptsListTab">
                        <div class="mb-4 d-flex flex-row align-items-center justify-content-between">
                            <div style="min-width: 200px" class="me-4">
                                <button class="w-100 mb-0 text-decoration-none fw-bold btn btn-primary" id="addNewAgentScriptButton">
                                    <span>+ Add New Script</span>
                                </button>
                            </div>
                            <div class="input-group w-100">
                                <input type="text" class="form-control" placeholder="Script Name" aria-label="Script Name" aria-describedby="searchAgentScriptButton">
                                <button class="input-group-button btn btn-primary" id="searchAgentScriptButton">
                                    <i class='fa-regular fa-magnifying-glass'></i>
                                </button>
                            </div>
                        </div>
                        <table id="agentScriptsTable" class="table w-100">
                            <thead>
                                <tr>
                                    <th scope="col">Name</th>
                                    <th scope="col">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- Dynamically Generated -->
                            </tbody>
                        </table>
                    </div>
                    <!-- Agent Scripts Manager Tab -->
                    <div class="fade d-none w-100" id="agentScriptsManagerTab">
                        <div class="tab-content w-100" id="agents-manager-tabContent">
                            <!-- General -->
                            <div class="tab-pane fade show active w-100" id="agents-manager-script-general" role="tabpanel" aria-labelledby="agents-manager-script-general-tab" tabindex="0">
                                <div class="mb-3">
