<div class="main-container d-none show w-100" id="campaigns-tab">
    <h3 class="fw-bold tab-title mb-3"><i class='fa-regular fa-bullhorn'></i> <span>Campaigns</span></h3>

    <!-- Header Container -->
    <div class="inner-header-container w-100 mb-3 fade show" id="campaigns-header">
        <!-- List View Header (Telephony/Web Filters) -->
        <div class="fade show" id="campaigns-list-header-inner">
            <ul class="nav" id="campaigns-list-tab" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active me-2" id="campaigns-list-telephony-campaigns-tab" data-bs-toggle="tab" data-bs-target="#campaigns-list-telephony-campaigns" type="button" role="tab" aria-controls="campaigns-list-telephony-campaigns" aria-selected="true">Telephony</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="campaigns-list-web-campaigns-tab" data-bs-toggle="tab" data-bs-target="#campaigns-list-web-campaigns" type="button" role="tab" aria-controls="campaigns-list-web-campaigns" aria-selected="false">Web</button>
                </li>
            </ul>
        </div>

        
        <!-- Manager View Header (Initially hidden) -->
        <div class="d-flex flex-column align-items-start justify-content-between fade d-none" id="campaigns-manager-header-inner">
            <div class="mb-4 d-flex flex-row align-items-center justify-content-between w-100">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-0">
                        <li class="breadcrumb-item">
                            <a href="#" id="switchBackToCampaignsTab">Campaigns</a>
                        </li>
                        <li class="breadcrumb-item active" aria-current="page"><span id="currentCampaignName">Campaign</span></li>
                    </ol>
                </nav>
                <div>
                    <button class="btn btn-primary btn-sm btn-ic-span-align" id="saveCampaignButton" disabled>
                        <i class='fa-regular fa-floppy-disk'></i>
                        <span> Save</span>
                    </button>
                </div>
            </div>

            <!-- Tab Navigation for Campaigns -->
            <ul class="nav w-100" id="campaigns-manager-tab" role="tablist">
                <li class="nav-item me-2" role="presentation">
                    <button class="nav-link active" id="campaigns-manager-general-tab" data-bs-toggle="pill" data-bs-target="#campaigns-manager-general" type="button" role="tab" aria-controls="campaigns-manager-general" aria-selected="true">General</button>
                </li>
                <li class="nav-item me-2" role="presentation">
                    <button class="nav-link" id="campaigns-manager-agent-tab" data-bs-toggle="pill" data-bs-target="#campaigns-manager-agent" type="button" role="tab" aria-controls="campaigns-manager-agent" aria-selected="true">Agent</button>
                </li>
                <li class="nav-item me-2 d-none" role="presentation" id="campaigns-manager-numbers-tab-item">
                    <button class="nav-link" id="campaigns-manager-numbers-tab" data-bs-toggle="pill" data-bs-target="#campaigns-manager-numbers" type="button" role="tab" aria-controls="campaigns-manager-numbers" aria-selected="false">Numbers</button>
                </li>
                <li class="nav-item me-2 d-none" role="presentation" id="campaigns-manager-region-tab-item">
                    <button class="nav-link" id="campaigns-manager-region-tab" data-bs-toggle="pill" data-bs-target="#campaigns-manager-region" type="button" role="tab" aria-controls="campaigns-manager-region" aria-selected="false">Region</button>
                </li>
                <li class="nav-item me-2" role="presentation">
                    <button class="nav-link" id="campaigns-manager-configuration-tab" data-bs-toggle="pill" data-bs-target="#campaigns-manager-configuration" type="button" role="tab" aria-controls="campaigns-manager-configuration" aria-selected="true">Configuration</button>
                </li>
                <li class="nav-item me-2" role="presentation">
                    <button class="nav-link" id="campaigns-manager-voicemail-tab" data-bs-toggle="pill" data-bs-target="#campaigns-manager-voicemail" type="button" role="tab" aria-controls="campaigns-manager-voicemail" aria-selected="true">Voicemail Detection</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="campaigns-manager-actions-tab" data-bs-toggle="pill" data-bs-target="#campaigns-manager-actions" type="button" role="tab" aria-controls="campaigns-manager-actions" aria-selected="true">Actions</button>
                </li>
            </ul>
        </div>
    </div>

    <!-- Main Container -->
    <div class="inner-container">
        <div class="tab-content w-100 fade show" id="campaigns-list-tabContent">
            <!-- Telephony Campaigns List View -->
            <div class="tab-pane fade show active w-100" id="campaigns-list-telephony-campaigns" role="tabpanel" aria-labelledby="campaigns-list-telephony-campaigns-tab" tabindex="0">
                <div class="mb-4 d-flex flex-row align-items-center justify-content-between">
                    <div style="min-width: 300px" class="me-4">
                        <button class="w-100 mb-0 text-decoration-none fw-bold btn btn-primary" id="addNewTelephonyCampaignButton">
                            <span>+ Add New Telephony Campaign</span>
                        </button>
                    </div>
                    <div class="input-group w-100">
                        <input type="text" class="form-control" placeholder="Telephony campaign name..." aria-label="Telephony Campaign Name" aria-describedby="searchTelephonyCampaignButton">
                        <button class="input-group-button btn btn-primary" id="searchTelephonyCampaignButton">
                            <i class='fa-regular fa-magnifying-glass'></i>
                        </button>
                    </div>
                </div>
                <div class="row" id="telephonyCampaignsListTable">
                    <!-- Dynamically Generated Telephony Campaign Cards -->
                </div>
            </div>

            <!-- Web Campaigns List View -->
            <div class="tab-pane fade w-100" id="campaigns-list-web-campaigns" role="tabpanel" aria-labelledby="campaigns-list-web-campaigns-tab" tabindex="0">
                <div class="mb-4 d-flex flex-row align-items-center justify-content-between">
                    <div style="min-width: 300px" class="me-4">
                        <button class="w-100 mb-0 text-decoration-none fw-bold btn btn-primary" id="addNewWebCampaignButton">
                            <span>+ Add New Web Campaign</span>
                        </button>
                    </div>
                    <div class="input-group w-100">
                        <input type="text" class="form-control" placeholder="Web campaign name..." aria-label="Web Campaign Name" aria-describedby="searchWebCampaignButton">
                        <button class="input-group-button btn btn-primary" id="searchWebCampaignButton">
                            <i class='fa-regular fa-magnifying-glass'></i>
                        </button>
                    </div>
                </div>
                <div class="row" id="webCampaignsListTable">
                    <!-- Dynamically Generated Web Campaign Cards -->
                </div>
            </div>
        </div>

        <!-- Campaign Manager View -->
        <div class="fade d-none w-100" id="campaignManagerTab">
            <div class="tab-content w-100" id="campaigns-manager-tabContent">

                <!-- General Tab -->
                <div class="tab-pane fade show active w-100" id="campaigns-manager-general" role="tabpanel" aria-labelledby="campaigns-manager-general-tab" tabindex="0">
                    <div class="mb-3">
                        <label class="form-label" for="editCampaignNameInput">Name</label>
                        <div class="input-group">
                            <button class="btn btn-light" id="editCampaignIconInput">📣</button>
                            <input type="text" class="form-control" id="editCampaignNameInput" placeholder="Campaign Name">
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="editCampaignDescriptionInput">Description</label>
                        <input type="text" class="form-control" id="editCampaignDescriptionInput" placeholder="Campaign Description">
                    </div>
                </div>

                <!-- Agent Tab -->
                <div class="tab-pane fade w-100" id="campaigns-manager-agent" role="tabpanel" aria-labelledby="campaigns-manager-agent-tab" tabindex="0">
                    <!-- Agent Selection -->
                    <div class="mb-3">
                        <label class="form-label" for="editSelectedCampaignAgentName">
                            Campaign Agent
                        </label>
                        <div class="input-group">
                            <span class="input-group-text" id="editSelectedCampaignAgentIcon">-</span>
                            <input type="text" class="form-control" id="editSelectedCampaignAgentName" placeholder="Select Agent" disabled>
                            <button class="btn btn-primary" id="editChangeCampaignAgentButton" data-bs-toggle="modal" data-bs-target="#editChangeCampaignAgentModal">
                                Select
                            </button>
                        </div>
                    </div>
                    <!-- Opening Script -->
                    <div class="mb-3">
                        <label class="form-label" for="editCampaignAgentDefaultScriptSelect">Opening Script</label>
                        <select class="form-select" id="editCampaignAgentDefaultScriptSelect" disabled>
                            <option value="" disabled selected>Select Script</option>
                        </select>
                    </div>
                    <!-- Language Selection -->
                    <div class="mb-3">
                        <label class="form-label btn-ic-span-align" for="editCampaignAgentLanguageSelect">
                            <span>Language </span>
                            <a href="#" class="d-inline-block" data-bs-toggle="tooltip" data-bs-placement="right" data-bs-html="true" data-bs-title="Select the language the agent will use for this campaign. This affects voice synthesis and recognition.">
                                <i class="fa-regular fa-circle-question"></i>
                            </a>
                        </label>
                        <select class="form-select" id="editCampaignAgentLanguageSelect">
                            <option value="" disabled selected>Select Language</option>
                            <!-- Dynamically Generated -->
                        </select>
                    </div>
                    <!-- Timezone -->
                    <div class="mb-3">
                        <label class="form-label" for="editCampaignAgentTimezoneSelect">Timezone</label>
                        <select class="form-select" id="editCampaignAgentTimezoneSelect">
                            <option value="" selected disabled>Select Timezone</option>
                            <option value="-12:00">(GMT -12:00) Eniwetok, Kwajalein</option>
                            <option value="-11:00">(GMT -11:00) Midway Island, Samoa</option>
                            <option value="-10:00">(GMT -10:00) Hawaii</option>
                            <option value="-09:50">(GMT -9:30) Taiohae</option>
                            <option value="-09:00">(GMT -9:00) Alaska</option>
                            <option value="-08:00">(GMT -8:00) Pacific Time (US &amp; Canada)</option>
                            <option value="-07:00">(GMT -7:00) Mountain Time (US &amp; Canada)</option>
                            <option value="-06:00">
                                (GMT -6:00) Central Time (US &amp; Canada), Mexico
                                City
                            </option>
                            <option value="-05:00">
                                (GMT -5:00) Eastern Time (US &amp; Canada), Bogota,
                                Lima
                            </option>
                            <option value="-04:50">(GMT -4:30) Caracas</option>
                            <option value="-04:00">
                                (GMT -4:00) Atlantic Time (Canada), Caracas, La Paz
                            </option>
                            <option value="-03:50">(GMT -3:30) Newfoundland</option>
                            <option value="-03:00">
                                (GMT -3:00) Brazil, Buenos Aires, Georgetown
                            </option>
                            <option value="-02:00">(GMT -2:00) Mid-Atlantic</option>
                            <option value="-01:00">(GMT -1:00) Azores, Cape Verde Islands</option>
                            <option value="+00:00">
                                (GMT 0/UTC) Western Europe Time,
                                London, Lisbon, Casablanca
                            </option>
                            <option value="+01:00">
                                (GMT +1:00) Brussels, Copenhagen, Madrid, Paris
                            </option>
                            <option value="+02:00">(GMT +2:00) Kaliningrad, South Africa</option>
                            <option value="+03:00">
                                (GMT +3:00) Baghdad, Riyadh, Moscow, St. Petersburg
                            </option>
                            <option value="+03:50">(GMT +3:30) Tehran</option>
                            <option value="+04:00">
                                (GMT +4:00) Abu Dhabi, Muscat, Baku, Tbilisi
                            </option>
                            <option value="+04:50">(GMT +4:30) Kabul</option>
                            <option value="+05:00">
                                (GMT +5:00) Ekaterinburg, Islamabad, Karachi,
                                Tashkent
                            </option>
                            <option value="+05:50">
                                (GMT +5:30) Bombay, Calcutta, Madras, New Delhi
                            </option>
                            <option value="+05:75">(GMT +5:45) Kathmandu, Pokhara</option>
                            <option value="+06:00">(GMT +6:00) Almaty, Dhaka, Colombo</option>
                            <option value="+06:50">(GMT +6:30) Yangon, Mandalay</option>
                            <option value="+07:00">(GMT +7:00) Bangkok, Hanoi, Jakarta</option>
                            <option value="+08:00">
                                (GMT +8:00) Beijing, Perth, Singapore, Hong Kong
                            </option>
                            <option value="+08:75">(GMT +8:45) Eucla</option>
                            <option value="+09:00">
                                (GMT +9:00) Tokyo, Seoul, Osaka, Sapporo, Yakutsk
                            </option>
                            <option value="+09:50">(GMT +9:30) Adelaide, Darwin</option>
                            <option value="+10:00">
                                (GMT +10:00) Eastern Australia, Guam, Vladivostok
                            </option>
                            <option value="+10:50">(GMT +10:30) Lord Howe Island</option>
                            <option value="+11:00">
                                (GMT +11:00) Magadan, Solomon Islands, New Caledonia
                            </option>
                            <option value="+11:50">(GMT +11:30) Norfolk Island</option>
                            <option value="+12:00">
                                (GMT +12:00) Auckland, Wellington, Fiji, Kamchatka
                            </option>
                            <option value="+12:75">(GMT +12:45) Chatham Islands</option>
                            <option value="+13:00">(GMT +13:00) Apia, Nukualofa</option>
                            <option value="+14:00">(GMT +14:00) Line Islands, Tokelau</option>
                        </select>
                    </div>
                    <!-- Context Checks -->
                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input type="checkbox" role="switch" class="form-check-input" id="editCampaignAgentFromNumberInContextCheck" checked>
                            <label class="form-label mb-0" for="editCampaignAgentFromNumberInContextCheck">Include 'From' Number in Context</label>
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input type="checkbox" role="switch" class="form-check-input" id="editCampaignAgentToNumberInContextCheck" checked>
                            <label class="form-label mb-0" for="editCampaignAgentToNumberInContextCheck">Include 'To' Number in Context</label>
                        </div>
                    </div>
                </div>

                <!-- Numbers Tab (For Telephony Campaigns) -->
                <div class="tab-pane fade w-100" id="campaigns-manager-numbers" role="tabpanel" aria-labelledby="campaigns-manager-numbers-tab" tabindex="0">
                    <div class="mb-4 d-flex flex-row align-items-center justify-content-between">
                        <div style="min-width: 200px" class="me-4">
                            <button class="w-100 mb-0 text-decoration-none fw-bold btn btn-primary" id="addCampaignRegionRouteButton">
                                <span>+ Add Region Route</span>
                            </button>
                        </div>
                        <div class="input-group w-100">
                            <input type="text" class="form-control" placeholder="Search added regions..." aria-label="Region" aria-describedby="searchCampaignAddedRegion">
                            <button class="input-group-button btn btn-primary" id="searchCampaignAddedRegion">
                                <i class="fa-regular fa-magnifying-glass"></i>
                            </button>
                        </div>
                    </div>
                    <div>
                        <table id="campaignNumbersList" class="table w-100">
                            <thead>
                                <tr>
                                    <th scope="col">Region</th>
                                    <th scope="col">Number</th>
                                    <th scope="col">Provider</th>
                                    <th scope="col">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- Permanent Default Route Row -->
                                <tr data-region-code="default">
                                    <td class="fw-bold">Default</td>
                                    <td colspan="2" data-col="number-provider">
                                        <!-- This content will be dynamically updated by JS -->
                                        <span class="text-muted">No default number selected.</span>
                                    </td>
                                    <td>
                                        <button class="btn btn-secondary btn-sm" button-action="edit-region-route" title="Set/Change Default Number">
                                            <i class="fa-regular fa-pencil"></i>
                                            <span> Set Number</span>
                                        </button>
                                    </td>
                                </tr>
                                <!-- Dynamically Generated Region Routes will be appended here -->
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Region Tab (for Web Campaigns) -->
                <div class="tab-pane fade w-100" id="campaigns-manager-region" role="tabpanel" aria-labelledby="campaigns-manager-region-tab" tabindex="0">
                    <div class="card card-body">
                        <h5 class="mb-3">Default Region Routing Policy</h5>
                        <p class="text-muted small">
                            This setting determines which server region will handle incoming web calls if a specific region is not provided in the API request.
                        </p>

                        <!-- Policy Selection -->
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="webCampaignRegionPolicy" id="regionPolicyAutomatic" value="automatic" checked>
                            <label class="form-check-label" for="regionPolicyAutomatic">
                                <strong>Automatic (Recommended)</strong>
                                <br>
                                <span class="small text-muted">Automatically route the user to the nearest available region based on their IP address. This provides the best experience for most users.</span>
                            </label>
                        </div>

                        <hr>

                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="webCampaignRegionPolicy" id="regionPolicyFixed" value="fixed">
                            <label class="form-check-label" for="regionPolicyFixed">
                                <strong>Fixed Region</strong>
                                <br>
                                <span class="small text-muted">Force all calls for this campaign to be routed to a single, specific region.</span>
                            </label>
                        </div>

                        <!-- Fixed Region Options (shown only when 'Fixed' is selected) -->
                        <div class="mt-3 ps-4 d-none" id="fixedRegionOptionsContainer">
                            <label for="fixedRegionSelect" class="form-label">Select Target Region</label>
                            <select class="form-select" id="fixedRegionSelect">
                                <option value="" disabled selected>Select a region...</option>
                                <!-- This will be populated dynamically from your API -->
                                <!-- Example Options: -->
                                <!-- <option value="uae-dubai">UAE (Dubai)</option> -->
                                <!-- <option value="us-east-1">USA (N. Virginia)</option> -->
                                <!-- <option value="eu-central-1">Europe (Frankfurt)</option> -->
                            </select>
                        </div>

                    </div>
                </div>

                <!-- Configuration Tab -->
                <div class="tab-pane fade w-100" id="campaigns-manager-configuration" role="tabpanel" aria-labelledby="campaigns-manager-configuration-tab" tabindex="0">
                    <!-- Retry -->
                    <div class="mb-4 p-3 border rounded bg-dark">
                        <div class="form-check form-switch">
                            <input type="checkbox" role="switch" class="form-check-input" id="editCampaignRetryOnDeclineCheck">
                            <label class="form-check-label" for="editCampaignRetryOnDeclineCheck">Enable Retry on Decline/Busy</label>
                        </div>
                        <div class="d-none fade mt-3" id="editCampaignRetryOnDeclineOptionsContainer">
                            <div class="row g-2 align-items-center">
                                <div class="col-auto"><label for="editCampaignRetryDeclineCountInput" class="col-form-label">Retries:</label></div>
                                <div class="col-auto"><input type="number" class="form-control form-control-sm" id="editCampaignRetryDeclineCountInput" value="3" min="1"></div>
                                <div class="col-auto"><label for="editCampaignRetryDeclineDelayInput" class="col-form-label">Delay:</label></div>
                                <div class="col-auto"><input type="number" class="form-control form-control-sm" id="editCampaignRetryDeclineDelayInput" value="10" min="1"></div>
                                <div class="col-auto">
                                    <select class="form-select form-select-sm" id="editCampaignRetryDeclineUnitSelect">
                                        <option value="0">Seconds</option>
                                        <option value="1" selected>Minutes</option>
                                        <option value="2">Hours</option>
                                        <option value="3">Days</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="mb-4 p-3 border rounded bg-dark">
                        <div class="form-check form-switch">
                            <input type="checkbox" role="switch" class="form-check-input" id="editCampaignRetryOnMissCheck">
                            <label class="form-check-label" for="editCampaignRetryOnMissCheck">Enable Retry on No Answer</label>
                        </div>
                        <div class="d-none fade mt-3" id="editCampaignRetryOnMissOptionsContainer">
                            <div class="row g-2 align-items-center">
                                <div class="col-auto"><label for="editCampaignRetryMissCountInput" class="col-form-label">Retries:</label></div>
                                <div class="col-auto"><input type="number" class="form-control form-control-sm" id="editCampaignRetryMissCountInput" value="3" min="1"></div>
                                <div class="col-auto"><label for="editCampaignRetryMissDelayInput" class="col-form-label">Delay:</label></div>
                                <div class="col-auto"><input type="number" class="form-control form-control-sm" id="editCampaignRetryMissDelayInput" value="10" min="1"></div>
                                <div class="col-auto">
                                    <select class="form-select form-select-sm" id="editCampaignRetryMissUnitSelect">
                                        <option value="0">Seconds</option>
                                        <option value="1" selected>Minutes</option>
                                        <option value="2">Hours</option>
                                        <option value="3">Days</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Timeout Settings Section -->
                    <div class="mb-3">
                        <label class="form-label" for="editCampaignNumberPickupDelay">Pick up delay (ms)</label>
                        <input type="number" class="form-control" id="editCampaignNumberPickupDelay" value="0">
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="editCampaignNumberSilenceNotify">Notify on silence (ms)</label>
                        <input type="number" class="form-control" id="editCampaignNumberSilenceNotify" value="10000">
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="editCampaignNumberSilenceEnd">End call on silence (ms)</label>
                        <input type="number" class="form-control" id="editCampaignNumberSilenceEnd" value="30000">
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="editCampaignNumberTotalCallTime">Max call time (s)</label>
                        <input type="number" class="form-control" id="editCampaignNumberTotalCallTime" value="600">
                    </div>
                </div>

                <!-- Voicemail Detection Tab -->
                <div class="tab-pane fade w-100" id="campaigns-manager-voicemail" role="tabpanel" aria-labelledby="campaigns-manager-voicemail-tab" tabindex="0">
                    <div class="card card-body mb-4">
                        <div class="d-flex align-items-center justify-content-between">
                            <h6 class="mb-0">Voicemail Detection</h6>
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" role="switch" id="editCampaignVoicemailIsEnabled">
                                <label class="form-check-label" for="editCampaignVoicemailIsEnabled">Enable</label>
                            </div>
                        </div>
                    </div>
                    <div id="editCampaignVoicemailSettingsContainer" style="opacity: 0.5; pointer-events: none;">
                        <div class="card card-body mb-3">
                            <p class="fw-bold mb-2">Detection Timing & Method</p>
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label for="editCampaignVoicemailInitialCheckDelayMS" class="form-label">Initial Check Delay (ms)</label>
                                    <input type="number" class="form-control" id="editCampaignVoicemailInitialCheckDelayMS" value="1000" min="0">
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="editCampaignVoicemailMLCheckDurationMS" class="form-label">ML Check Duration (ms)</label>
                                    <input type="range" class="form-range" id="editCampaignVoicemailMLCheckDurationMS" min="1000" max="4000" step="100" value="1000">
                                    <div class="text-center small">
                                        <span id="editCampaignVoicemailMLCheckDurationMSValue">1000</span> ms
                                    </div>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="editCampaignVoicemailMaxMLCheckTries" class="form-label">Max ML Check Tries</label>
                                    <input type="number" class="form-control" id="editCampaignVoicemailMaxMLCheckTries" value="2" min="1">
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="editCampaignVoicemailVADSilenceThresholdMS" class="form-label">VAD Silence Threshold (ms)</label>
                                    <input type="number" class="form-control" id="editCampaignVoicemailVADSilenceThresholdMS" value="1000" min="0">
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="editCampaignVoicemailVADMaxSpeechDurationMS" class="form-label">VAD Max Speech Duration (ms)</label>
                                    <input type="number" class="form-control" id="editCampaignVoicemailVADMaxSpeechDurationMS" value="4000" min="0">
                                </div>
                            </div>
                        </div>
